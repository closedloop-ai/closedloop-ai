{
  "name": "@repo/database",
  "version": "0.0.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "db:generate": "prisma generate --no-hints --schema=./prisma/schema.prisma",
    "analyze": "node scripts/ensure-prisma-client.mjs",
    "prebuild": "tsx scripts/migrate.ts",
    "build": "node scripts/ensure-prisma-client.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "generate:rds-ca": "tsx scripts/generate-rds-ca-bundle.ts",
    "check:rds-ca": "tsx scripts/generate-rds-ca-bundle.ts --check",
    "seed": "tsx scripts/seed.ts",
    "pretest": "node scripts/ensure-prisma-client.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --exclude '**/integration/**'",
    "test:integration": "vitest run --config vitest.config.integration.ts --no-file-parallelism"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1003.0",
    "@prisma/adapter-pg": "~7.8.0",
    "@prisma/client": "~7.8.0",
    "@prisma/client-runtime-utils": "~7.8.0",
    "@repo/api": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@vercel/functions": "^3.4.3",
    "pg": "^8.20.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/pg": "8.20.0",
    "bufferutil": "^4.1.0",
    "dotenv": "^17.4.2",
    "prisma": "~7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
