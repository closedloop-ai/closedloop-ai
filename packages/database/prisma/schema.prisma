// =============================================================================
// API KEYS
// =============================================================================

model ApiKey {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  name           String
  scopes         String[]     @default([])
  keyHash        String       @unique @map("key_hash")
  keyPrefix      String       @map("key_prefix")
  expiresAt      DateTime?    @map("expires_at")
  lastUsedAt     DateTime?    @map("last_used_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  revokedAt      DateTime?    @map("revoked_at")
  // Phase A stores desktop bootstrap provenance and gateway binding metadata.
  source         ApiKeySource @default(USER_CREATED)
  gatewayId      String?      @map("gateway_id")
  boundPublicKey String?      @map("bound_public_key")

  @@index([organizationId])
  @@index([organizationId, userId, gatewayId])
  @@map("api_keys")
}

model OAuthRevokedToken {
  id               String   @id @default(uuid(7)) @db.Uuid
  tokenFingerprint String   @unique @map("token_fingerprint")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime @default(now()) @map("revoked_at")

  @@index([expiresAt])
  @@map("oauth_revoked_tokens")
}

model OAuthRateLimit {
  id              String   @id @default(uuid(7)) @db.Uuid
  bucket          String
  subject         String
  requestCount    Int      @default(0) @map("request_count")
  windowStartedAt DateTime @map("window_started_at")
  windowExpiresAt DateTime @map("window_expires_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([bucket, subject])
  @@index([windowExpiresAt])
  @@map("oauth_rate_limits")
}

model OAuthAuthorizationCode {
  id                  String    @id @default(uuid(7)) @db.Uuid
  code                String    @unique
  encryptedApiKey     String    @map("encrypted_api_key")
  keyId               String    @map("key_id")
  userId              String    @map("user_id") @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  clientId            String    @map("client_id")
  redirectUri         String    @map("redirect_uri")
  scopes              String[]
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @map("code_challenge_method")
  expiresAt           DateTime  @map("expires_at")
  consumedAt          DateTime? @map("consumed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([consumedAt])
  @@map("oauth_authorization_codes")
}

model OAuthRefreshToken {
  id                String    @id @default(uuid(7)) @db.Uuid
  tokenFingerprint  String    @unique @map("token_fingerprint")
  encryptedApiKey   String    @map("encrypted_api_key")
  keyId             String    @map("key_id")
  userId            String    @map("user_id") @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  clientId          String    @map("client_id")
  scopes            String[]
  familyId          String    @map("family_id") @db.Uuid
  expiresAt         DateTime  @map("expires_at")
  lastUsedAt        DateTime? @map("last_used_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([familyId, revokedAt])
  @@map("oauth_refresh_tokens")
}

model LocalGatewayChallengeJti {
  jti       String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("local_gateway_challenge_jtis")
}

model DesktopOnboardingAttempt {
  attemptId       String    @id @map("attempt_id")
  userId          String    @map("user_id") @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  webAppOrigin    String    @map("web_app_origin")
  expiresAt       DateTime  @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  flowType        String?   @map("flow_type")
  computeTargetId String?   @map("compute_target_id") @db.Uuid
  gatewayId       String?   @map("gateway_id")

  @@index([organizationId, userId])
  @@index([expiresAt])
  @@map("desktop_onboarding_attempts")
}

model DesktopOnboardingDeviceSession {
  id                                    String    @id @default(uuid(7)) @db.Uuid
  deviceSessionSecretHash               String    @map("device_session_secret_hash")
  userCode                              String    @unique @map("user_code")
  requestIpHash                         String?   @map("request_ip_hash")
  webAppOrigin                          String    @map("web_app_origin")
  gatewayId                             String    @map("gateway_id")
  gatewayPublicKeyPem                   String    @map("gateway_public_key_pem")
  machineName                           String    @map("machine_name")
  platform                              String
  desktopVersion                        String    @map("desktop_version")
  desktopSecurityUpgradeProtocolVersion Int       @map("desktop_security_upgrade_protocol_version")
  status                                String    @default("pending")
  userId                                String?   @map("user_id") @db.Uuid
  organizationId                        String?   @map("organization_id") @db.Uuid
  onboardingAttemptId                   String?   @map("onboarding_attempt_id")
  deniedAt                              DateTime? @map("denied_at")
  approvedAt                            DateTime? @map("approved_at")
  expiresAt                             DateTime  @map("expires_at")
  createdAt                             DateTime  @default(now()) @map("created_at")
  updatedAt                             DateTime  @updatedAt @map("updated_at")

  @@index([gatewayId, status, expiresAt], map: "desktop_device_sessions_gateway_status_exp_idx")
  @@index([requestIpHash, status, expiresAt], map: "desktop_device_sessions_ip_status_exp_idx")
  @@index([expiresAt])
  @@map("desktop_onboarding_device_sessions")
}

// =============================================================================
// CUSTOM FIELDS
// =============================================================================

model CustomField {
  id             String          @id @default(uuid(7)) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  name           String
  description    String?
  fieldType      CustomFieldType @map("field_type")
  createdById    String?         @map("created_by_id") @db.Uuid

  // Number-specific configuration
  precision           Int?
  numberFormat        NumberFormat?  @map("number_format")
  currencyCode        String?        @map("currency_code")
  customLabel         String?        @map("custom_label")
  customLabelPosition LabelPosition? @map("custom_label_position")

  // Behavior
  isGlobalToOrg Boolean @default(true) @map("is_global_to_org")

  // Entity type applicability — which entity types this field applies to
  entityTypes CustomFieldEntityType[] @default([]) @map("entity_types")

  // Display configuration
  showInTable  Boolean @default(false) @map("show_in_table")
  isSearchable Boolean @default(false) @map("is_searchable")
  isSortable   Boolean @default(false) @map("is_sortable")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id])
  createdBy    User?                   @relation(fields: [createdById], references: [id])
  enumOptions  CustomFieldEnumOption[]
  settings     CustomFieldSetting[]
  values       CustomFieldValue[]

  @@unique([organizationId, name])
  @@map("custom_fields")
}

model CustomFieldEnumOption {
  id            String  @id @default(uuid(7)) @db.Uuid
  customFieldId String  @map("custom_field_id") @db.Uuid
  name          String
  color         String  @default("none")
  enabled       Boolean @default(true)
  sortOrder     Int     @default(0) @map("sort_order")

  // Relations
  customField CustomField        @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  values      CustomFieldValue[]

  @@unique([customFieldId, name])
  @@index([customFieldId, sortOrder])
  @@map("custom_field_enum_options")
}

model CustomFieldSetting {
  id             String                @id @default(uuid(7)) @db.Uuid
  customFieldId  String                @map("custom_field_id") @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  entityType     CustomFieldEntityType @map("entity_type")
  entityId       String                @map("entity_id") @db.Uuid
  isImportant    Boolean               @default(false) @map("is_important")
  isRequired     Boolean               @default(false) @map("is_required")
  sortOrder      Int                   @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityType, entityId])
  @@index([organizationId, entityType, entityId])
  @@map("custom_field_settings")
}

model CustomFieldValue {
  id             String                @id @default(uuid(7)) @db.Uuid
  customFieldId  String                @map("custom_field_id") @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  entityType     CustomFieldEntityType @map("entity_type")
  entityId       String                @map("entity_id") @db.Uuid

  // Type-specific value columns (only one populated per row)
  textValue         String?   @map("text_value")
  numberValue       Float?    @map("number_value")
  dateValue         DateTime? @map("date_value")
  enumValueId       String?   @map("enum_value_id") @db.Uuid
  multiEnumValueIds String[]  @map("multi_enum_value_ids")
  peopleValueIds    String[]  @map("people_value_ids")

  // Cached display string (updated on write)
  displayValue String? @map("display_value")

  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") @db.Uuid

  // Relations
  customField CustomField            @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  enumValue   CustomFieldEnumOption? @relation(fields: [enumValueId], references: [id], onDelete: SetNull)
  updatedBy   User?                  @relation(fields: [updatedById], references: [id])

  @@unique([customFieldId, entityType, entityId])
  @@index([organizationId, entityType, entityId])
  @@map("custom_field_values")
}

