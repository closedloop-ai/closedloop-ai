// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// =============================================================================
// ENUMS
// =============================================================================

enum WorkstreamType {
  FEATURE_DELIVERY
  BUG_FIX
  TECH_DEBT
  SPIKE
}

enum WorkstreamState {
  INITIATED
  REQUIREMENTS_GENERATING
  REQUIREMENTS_PENDING_APPROVAL
  DESIGN_IN_PROGRESS
  DESIGN_PENDING_APPROVAL
  IMPLEMENTATION_PLANNING
  IMPLEMENTATION_IN_PROGRESS
  IMPLEMENTATION_PENDING_REVIEW
  CODE_REVIEW_RUNNING
  CODE_REVIEW_PENDING_APPROVAL
  VISUAL_QA_RUNNING
  VISUAL_QA_PENDING_APPROVAL
  MERGING
  DEPLOYED
  COMPLETED
  BLOCKED
  CANCELLED
}

enum IssueStatus {
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  OBSOLETE
}

enum ExternalLinkType {
  PULL_REQUEST
  FIGMA_DESIGN
  PREVIEW_DEPLOYMENT
}

// Entity types for polymorphic EntityLink
enum EntityType {
  ARTIFACT
  ISSUE
  EXTERNAL_LINK
}

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Issue blocks Issue)
  RELATES_TO // bidirectional association (Issue ↔ Issue)
}

enum ArtifactStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  OBSOLETE
}

enum ArtifactType {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE
}

enum EvaluationReportType {
  PLAN
  CODE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum WorkstreamEventType {
  STATE_CHANGED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  REVISION_REQUESTED
  LINEAR_ISSUE_CREATED
  LINEAR_ISSUE_UPDATED
  LINEAR_SUBTASK_CREATED
  GITHUB_PR_CREATED
  GITHUB_PR_MERGED
  GITHUB_PR_CLOSED
  GITHUB_PR_REVIEW_SUBMITTED
  GITHUB_PR_COMMENT_ADDED
  GITHUB_ACTION_TRIGGERED
  GITHUB_ACTION_COMPLETED
  GITHUB_CI_STATUS_CHANGED
  SLACK_NOTIFICATION_SENT
  COMMENT_ADDED
  ASSIGNEE_CHANGED
  BLOCKED
  UNBLOCKED
  LOOP_COMPLETED
}

enum LinearSyncStatus {
  SYNCED
  PENDING
  ERROR
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum GitHubActionStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
}

enum ChecksStatus {
  UNKNOWN
  PENDING
  PASSING
  FAILING
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum PRReviewCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LoopStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum LoopCommand {
  PLAN
  EXECUTE
  CHAT
  EXPLORE
  REQUEST_CHANGES
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model Organization {
  id              String   @id @default(uuid(7)) @db.Uuid
  clerkId         String   @unique @map("clerk_id")
  active          Boolean  @default(true) @map("active")
  name            String
  slug            String   @unique
  anthropicApiKey String?  @map("anthropic_api_key") // @deprecated - auto-migrated to claudeApiKeyEncrypted on read (see apiKeyService.resolveApiKey)
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  settings              Json     @default("{}")
  publicDashboardToken  String?  @unique @map("public_dashboard_token")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  teams              Team[]
  pullRequestRatings PullRequestRating[]
  pullRequests       GitHubPullRequest[]
  projects           Project[]
  workstreams        Workstream[]
  artifacts          Artifact[]
  issues             Issue[]
  externalLinks      ExternalLink[]
  githubInstallation GitHubInstallation?
  loops              Loop[]

  @@map("organizations")
}

model User {
  id              String       @id @default(uuid(7)) @db.Uuid
  clerkId         String       @map("clerk_id")
  organizationId  String       @map("organization_id") @db.Uuid
  active          Boolean      @default(true) @map("active")
  email           String
  firstName       String?      @map("first_name")
  lastName        String?      @map("last_name")
  avatarUrl       String?      @map("avatar_url")
  phoneNumber     String?      @map("phone_number")
  role            ApproverRole @default(ENGINEER)
  linearId        String?      @map("linear_id")
  slackId         String?      @map("slack_id")
  githubUsername  String?      @map("github_username")
  anthropicApiKey String?      @map("anthropic_api_key") // @deprecated - auto-migrated to claudeApiKeyEncrypted on read (see apiKeyService.resolveApiKey)
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  organization       Organization     @relation(fields: [organizationId], references: [id])
  teamMemberships    TeamMember[]
  pullRequestRatings PullRequestRating[]
  assignedProjects   Project[]    @relation("ProjectAssignee")
  createdProjects    Project[]    @relation("ProjectCreatedBy")
  assignedArtifacts  Artifact[]   @relation("ArtifactAssignee")
  createdArtifacts   Artifact[]   @relation("ArtifactCreatedBy")
  approvedArtifacts  Artifact[]   @relation("ArtifactApprover")
  assignedIssues     Issue[]      @relation("IssueAssignee")
  createdIssues      Issue[]      @relation("IssueCreator")
  createdWorkstreams  Workstream[] @relation("WorkstreamCreatedBy")
  assignedWorkstreams Workstream[] @relation("WorkstreamAssignee")
  loops               Loop[]

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model Project {
  id              String        @id @default(uuid(7)) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  name            String
  description     String?
  priority        Priority      @default(MEDIUM)
  status          ProjectStatus @default(NOT_STARTED)
  assigneeId      String?       @map("assignee_id") @db.Uuid
  createdById     String        @map("created_by_id") @db.Uuid
  slug            String?
  targetDate      DateTime?     @map("target_date")
  codebaseSummary String?       @map("codebase_summary")
  lastIndexedAt   DateTime?     @map("last_indexed_at")
  settings        Json          @default("{}")
  sortOrder       Int?          @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id])
  assignee      User?          @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  createdBy     User           @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  workstreams   Workstream[]
  artifacts     Artifact[]
  issues        Issue[]
  externalLinks ExternalLink[]
  teams         ProjectTeam[]

  @@unique([organizationId, slug])
  @@index([assigneeId])
  @@index([createdById])
  @@map("projects")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

// =============================================================================
// WORKSTREAM
// =============================================================================

model Workstream {
  id             String          @id @default(uuid(7)) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  title          String
  description    String?
  type           WorkstreamType  @default(FEATURE_DELIVERY)
  state          WorkstreamState @default(INITIATED)
  stateChangedAt DateTime        @default(now()) @map("state_changed_at")
  createdById    String          @map("created_by_id") @db.Uuid
  assigneeId     String?         @map("assigned_to_id") @db.Uuid
  priority       Priority        @default(MEDIUM)
  slug           String?
  hasUIChanges   Boolean         @default(false) @map("has_ui_changes")
  startedAt      DateTime        @default(now()) @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metrics        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("WorkstreamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignee      User?          @relation("WorkstreamAssignee", fields: [assigneeId], references: [id])
  artifacts     Artifact[]
  issues        Issue[]
  externalLinks ExternalLink[]
  loops         Loop[]
  pullRequests  GitHubPullRequest[]

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, state])
  @@index([organizationId, assigneeId])
  @@index([projectId])
  @@index([createdById])
  @@map("workstreams")
}

model WorkstreamEvent {
  id           String              @id @default(uuid(7)) @db.Uuid
  workstreamId String              @map("workstream_id") @db.Uuid
  type         WorkstreamEventType
  fromState    WorkstreamState?    @map("from_state")
  toState      WorkstreamState?    @map("to_state")
  actorId      String?             @map("actor_id") @db.Uuid
  actorType    String              @default("system") @map("actor_type")
  data         Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([workstreamId, type])
  @@index([workstreamId, createdAt])
  @@index([type])
  @@map("workstream_events")
}

// =============================================================================
// ARTIFACTS
// =============================================================================

model Artifact {
  id              String         @id @default(uuid(7)) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  workstreamId    String?        @map("workstream_id") @db.Uuid
  projectId       String?        @map("project_id") @db.Uuid
  type            ArtifactType   @map("type")
  title           String
  slug            String
  fileName        String?        @map("file_name")
  assigneeId      String?        @map("assignee_id") @db.Uuid
  approverId      String?        @map("approver_id") @db.Uuid
  status          ArtifactStatus @default(DRAFT)
  latestVersion   Int            @default(1) @map("latest_version")
  createdById     String         @map("created_by_id") @db.Uuid
  tokenUsage      Json?          @map("token_usage")
  targetRepo      String?        @map("target_repo")
  targetBranch    String?        @map("target_branch")
  templateForType ArtifactType?  @map("template_for_type")
  sortOrder       Int?           @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  organization Organization         @relation(fields: [organizationId], references: [id])
  workstream   Workstream?          @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?                @relation("ArtifactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("ArtifactCreatedBy", fields: [createdById], references: [id])
  approver     User?                @relation("ArtifactApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions         ArtifactVersion[]
  ratings          ArtifactRating[]
  evaluations      ArtifactEvaluation[]
  performances     GitHubActionRunPerformance[]
  pullRequests     GitHubPullRequest[]
  loops            Loop[]
  fileAttachments  FileAttachment[]

  @@unique([organizationId, slug])
  @@unique([organizationId, templateForType])
  @@index([organizationId, workstreamId, type])
  @@index([organizationId, projectId, type])
  @@index([organizationId, type, templateForType])
  @@index([workstreamId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([approverId])
  @@map("artifacts")
}

model ArtifactVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, version])
  @@map("artifact_versions")
}

model ArtifactEvaluation {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  actionRunId String?  @map("action_run_id") @db.Uuid
  loopId      String?  @map("loop_id") @db.Uuid
  reportType  EvaluationReportType @map("report_type")
  reportId    String   @map("report_id")
  reportData  Json     @map("report_data")
  createdAt   DateTime @default(now()) @map("created_at")

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  loop     Loop?    @relation(fields: [loopId], references: [id], onDelete: SetNull)

  @@unique([artifactId, reportId])
  @@map("artifact_evaluations")
}

// SECURITY: No organizationId column — org isolation is enforced exclusively
// via the artifact FK. All read-path queries MUST join through Artifact
// and filter by organizationId. This is an intentional design decision.
model GitHubActionRunPerformance {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  // Soft reference - no Prisma relation defined intentionally. Query GitHubActionRun separately if needed.
  actionRunId String   @map("action_run_id") @db.Uuid
  summaryData Json     @map("summary_data")
  createdAt   DateTime @default(now()) @map("created_at")

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, actionRunId])
  @@map("github_action_run_performances")
}

model ArtifactRating {
  id              String   @id @default(uuid(7)) @map("id") @db.Uuid
  artifactId      String   @map("artifact_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  // Score validation (1-5) enforced at API layer via Zod schema. Prisma relationMode = "prisma" doesn't support DB check constraints.
  score           Int
  comment         String?  @db.VarChar(500)
  artifactVersion Int      @map("artifact_version")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, userId, organizationId])
  @@index([artifactId, organizationId])
  @@map("artifact_ratings")
}

model FileAttachment {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  bucket      String
  key         String
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String   @map("created_by_id") @db.Uuid

  // Relations
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@map("file_attachments")
}

model PullRequestRating {
  id             String   @id @default(uuid(7)) @db.Uuid
  pullRequestId  String   @map("pull_request_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid // Enforced by check_pull_request_rating_organization_id trigger - must match github_pull_requests.organization_id
  // Score validation (1-5) enforced at API layer via Zod schema
  score          Int
  comment        String   @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  pullRequest  GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, userId, organizationId])
  @@index([pullRequestId, organizationId])
  @@map("pull_request_ratings")
}

// =============================================================================
// OTHER ENTITIES
// =============================================================================

model Issue {
  id             String        @id @default(uuid(7)) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  workstreamId   String?       @map("workstream_id") @db.Uuid
  projectId      String?       @map("project_id") @db.Uuid
  title          String
  slug           String
  description    String?       @db.Text
  status         IssueStatus   @default(NOT_STARTED)
  priority       Priority      @default(MEDIUM)
  assigneeId     String?       @map("assignee_id") @db.Uuid
  createdById    String        @map("created_by_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  workstream   Workstream?  @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("IssueCreator", fields: [createdById], references: [id])

  @@unique([organizationId, slug])
  @@index([organizationId, workstreamId, status])
  @@index([organizationId, projectId, status])
  @@index([organizationId, assigneeId, status])
  @@index([workstreamId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@map("issues")
}

model ExternalLink {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  workstreamId   String?          @map("workstream_id") @db.Uuid
  projectId      String?          @map("project_id") @db.Uuid
  type           ExternalLinkType
  title          String
  externalUrl    String           @map("external_url")
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  workstream   Workstream?  @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, workstreamId, type])
  @@index([organizationId, projectId, type])
  @@index([workstreamId])
  @@index([projectId])
  @@map("external_links")
}

model EntityLink {
  id            String     @id @default(uuid(7)) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  sourceId      String     @map("source_id") @db.Uuid
  sourceType    EntityType @map("source_type")
  sourceVersion Int?       @map("source_version")
  targetId      String     @map("target_id") @db.Uuid
  targetType    EntityType @map("target_type")
  targetVersion Int?       @map("target_version")
  linkType      LinkType   @map("link_type")
  metadata      Json?
  createdAt     DateTime   @default(now()) @map("created_at")

  @@index([organizationId, sourceId, sourceType, linkType])
  @@index([organizationId, targetId, targetType, linkType])
  @@map("entity_links")
}

// =============================================================================
// CONVERSATIONS
// =============================================================================

model Conversation {
  id           String   @id @default(uuid(7)) @db.Uuid
  workstreamId String   @map("workstream_id") @db.Uuid
  agentType    String   @map("agent_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, agentType])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid(7)) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String   @db.Text
  tokenUsage     Json?    @map("token_usage")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Comment {
  id           String   @id @default(uuid(7)) @db.Uuid
  workstreamId String   @map("workstream_id") @db.Uuid
  authorId     String   @map("author_id") @db.Uuid
  content      String   @db.Text
  artifactId   String?  @map("artifact_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, createdAt])
  @@index([authorId])
  @@index([artifactId])
  @@map("comments")
}

// =============================================================================
// LOOPS (Runtime v2 - Container-based compute)
// =============================================================================

model Loop {
  id             String      @id @default(uuid(7)) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  status         LoopStatus  @default(PENDING)
  command        LoopCommand

  // Optional relationships
  artifactId   String? @map("artifact_id") @db.Uuid
  workstreamId String? @map("workstream_id") @db.Uuid
  parentLoopId String? @map("parent_loop_id") @db.Uuid

  // Execution context
  prompt      String? @db.Text
  repo        Json? // { fullName: string, branch: string }
  contextRefs Json?   @map("context_refs") // Array<{ artifactId, include }>

  // Container tracking
  containerId String? @map("container_id") // ECS task ARN
  s3StateKey  String? @map("s3_state_key") // S3 prefix for state

  // PR and session tracking (populated by harness agent on completion)
  prUrl      String? @map("pr_url")
  prNumber   Int?    @map("pr_number")
  branchName String? @map("branch_name")
  sessionId  String? @map("session_id")

  // Cost tracking
  tokensInput    Int      @default(0) @map("tokens_input")
  tokensOutput   Int      @default(0) @map("tokens_output")
  tokensByModel  Json?    @map("tokens_by_model") // { "claude-opus-4": { input, output }, ... }
  estimatedCost  Decimal? @map("estimated_cost") @db.Decimal(10, 6)

  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Error info
  error Json? // { code: string, message: string }

  // Extensible metadata
  metadata Json @default("{}") @map("metadata")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  artifact     Artifact?    @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  workstream   Workstream?  @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  parentLoop   Loop?        @relation("LoopParent", fields: [parentLoopId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  childLoops   Loop[]       @relation("LoopParent")
  evaluations  ArtifactEvaluation[]
  events       LoopEvent[]

  @@index([organizationId, status])
  @@index([organizationId, userId, createdAt])
  @@index([artifactId])
  @@index([workstreamId])
  @@index([parentLoopId])
  @@map("loops")
}

model LoopEvent {
  id             String   @id @default(uuid(7)) @db.Uuid
  loopId         String   @map("loop_id") @db.Uuid
  type           String // "started" | "output" | "progress" | "tool_call" | "artifact_created" | "completed" | "error"
  data           Json     @default("{}")
  eventSource    String   @default("system") @map("event_source")
  eventId        String   @map("event_id")
  runnerTokenJti String?  @map("runner_token_jti")
  runnerNonce    String?  @map("runner_nonce") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  loop Loop @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@index([loopId, createdAt])
  @@index([loopId, type])
  @@unique([loopId, eventSource, eventId])
  @@map("loop_events")
}

