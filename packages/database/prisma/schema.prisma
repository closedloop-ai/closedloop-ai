  organizationId String   @map("organization_id") @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  linearId       String   @unique @map("linear_id")
  linearKey      String   @map("linear_key")
  linearUrl      String   @map("linear_url")
  title          String
  description    String?
  isCompleted    Boolean  @default(false) @map("is_completed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Artifact     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentId, isCompleted])
  @@map("linear_subtasks")
}

// =============================================================================
// GITHUB INTEGRATION
// =============================================================================

model GitHubInstallation {
  id                       String                   @id @default(uuid(7)) @db.Uuid
  organizationId           String?                  @unique @map("organization_id") @db.Uuid
  installationId           String                   @unique @map("installation_id")
  accountId                String                   @map("account_id")
  accountLogin             String                   @map("account_login")
  accountType              String                   @map("account_type")
  senderLogin              String                   @map("sender_login")
  senderId                 String                   @map("sender_id")
  status                   GitHubInstallationStatus @default(PENDING_CLAIM)
  permissions              Json?
  events                   Json?
  repositorySelection      String?                  @map("repository_selection")
  suspendedAt              DateTime?                @map("suspended_at")
  suspendedBy              String?                  @map("suspended_by")
  claimedAt                DateTime?                @map("claimed_at")
  claimedByUserId          String?                  @map("claimed_by_user_id") @db.Uuid
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  // PLN-634: set on the prior UNINSTALLED row when an OAuth callback detects
  // a different-account reconnect. The confirm-reset endpoint reads this
  // value to determine which new installation to claim, so a user-controlled
  // body cannot redirect the claim to an attacker's installation.
  pendingNewInstallationId String?                  @map("pending_new_installation_id")

  // Relations
  organization Organization?                  @relation(fields: [organizationId], references: [id])
  repositories GitHubInstallationRepository[]

  @@index([status])
  @@index([accountId])
  @@map("github_installations")
}

model GitHubInstallationRepository {
  id             String    @id @default(uuid(7)) @db.Uuid
  installationId String    @map("installation_id") @db.Uuid
  githubRepoId   String    @map("github_repo_id")
  fullName       String    @map("full_name")
  name           String
  owner          String
  private        Boolean
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastPushedAt   DateTime? @map("last_pushed_at")
  // Soft-tombstone marker set when a repo disappears from the installation
  // during a disconnect/reinstall window (PLN-634). Tombstoned rows are
  // filtered from active-pool reads (getRepositories, etc.) but remain
  // resolvable by FK so historical BranchDetail / PullRequestDetail records
  // can still render. Cleared if the same githubRepoId reappears on reconnect.
  removedAt      DateTime? @map("removed_at")

  // Relations
  installation       GitHubInstallation      @relation(fields: [installationId], references: [id], onDelete: Cascade)
  branchDetails      BranchDetail[]
  pullRequestDetails PullRequestDetail[]
  teamRepositories   TeamRepository[]
  dirtyScopeNudges   GitHubDirtyScopeNudge[]

  @@unique([installationId, githubRepoId])
  @@map("github_installation_repositories")
}

// Symphony's GitHub OAuth callback persists these per organization/user rows.
// The connection is not inferred from Clerk's social account metadata, and it
// intentionally does not fan out to every User row with the same clerkId: a
// write-capable GitHub token is scoped to the org where the user connected it.
model GitHubUserConnection {
  id                    String    @id @default(uuid(7)) @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  githubUserId          String    @map("github_user_id")
  githubNodeId          String?   @map("github_node_id")
  login                 String
  normalizedLogin       String    @map("normalized_login")
  avatarUrl             String?   @map("avatar_url")
  profileUrl            String?   @map("profile_url")
  accessTokenEncrypted  String    @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scopes                String[]  @default([])
  revokedAt             DateTime? @map("revoked_at")
  lastUsedAt            DateTime? @map("last_used_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@unique([organizationId, githubUserId])
  @@index([organizationId, normalizedLogin])
  @@index([revokedAt])
  @@map("github_user_connections")
}

model PublicRepository {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  githubRepoId   String   @map("github_repo_id")
  fullName       String   @map("full_name")
  owner          String
  name           String
  htmlUrl        String   @map("html_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, githubRepoId])
  @@map("public_repositories")
}

model GitHubPRReview {
  id                     String         @id @default(uuid(7)) @db.Uuid
  pullRequestId          String         @map("pull_request_id") @db.Uuid
  githubReviewId         String         @unique @map("github_review_id")
  authorLogin            String         @map("author_login")
  authorAvatarUrl        String?        @map("author_avatar_url")
  state                  ReviewDecision
  body                   String?        @db.Text
  htmlUrl                String         @map("html_url")
  submittedAt            DateTime       @map("submitted_at")
  fetchCredentialType    String?        @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId String?        @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism         String?        @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger           String?        @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt        DateTime?      @map("fetch_observed_at")
  fetchResultReason      String?        @map("fetch_result_reason") @db.VarChar(64)
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  // Relations
  pullRequestDetail PullRequestDetail @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, authorLogin])
  @@map("github_pr_reviews")
}

// =============================================================================
// SLACK INTEGRATION
// =============================================================================

model SlackIntegration {
  id                   String   @id @default(uuid(7)) @db.Uuid
  organizationId       String   @unique @map("organization_id") @db.Uuid
  accessToken          String   @map("access_token")
  accessTokenEncrypted String?  @map("access_token_encrypted") @db.Text
  botUserId            String   @map("bot_user_id")
  teamId               String   @map("team_id")
  teamName             String   @map("team_name")
  defaultChannelId     String?  @map("default_channel_id")
  defaultChannelName   String?  @map("default_channel_name")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("slack_integrations")
}

// =============================================================================
// API KEYS
// =============================================================================

model ApiKey {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  name           String
  scopes         String[]     @default([])
  keyHash        String       @unique @map("key_hash")
  keyPrefix      String       @map("key_prefix")
  expiresAt      DateTime?    @map("expires_at")
  lastUsedAt     DateTime?    @map("last_used_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  revokedAt      DateTime?    @map("revoked_at")
  // Phase A stores desktop bootstrap provenance and gateway binding metadata.
  source         ApiKeySource @default(USER_CREATED)
  gatewayId      String?      @map("gateway_id")
  boundPublicKey String?      @map("bound_public_key")

  @@index([organizationId])
  @@index([organizationId, userId, gatewayId])
  @@map("api_keys")
}

model OAuthRevokedToken {
  id               String   @id @default(uuid(7)) @db.Uuid
  tokenFingerprint String   @unique @map("token_fingerprint")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime @default(now()) @map("revoked_at")

  @@index([expiresAt])
  @@map("oauth_revoked_tokens")
}

model OAuthRateLimit {
  id              String   @id @default(uuid(7)) @db.Uuid
  bucket          String
  subject         String
  requestCount    Int      @default(0) @map("request_count")
  windowStartedAt DateTime @map("window_started_at")
  windowExpiresAt DateTime @map("window_expires_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([bucket, subject])
  @@index([windowExpiresAt])
  @@map("oauth_rate_limits")
}

model OAuthAuthorizationCode {
  id                  String    @id @default(uuid(7)) @db.Uuid
  // FEA-2775 EXPAND phase: `code` (plaintext) and `code_fingerprint` (SHA-256)
  // coexist so the independently-deployed MCP server can roll without a skew
  // outage. Both are nullable during the transition — old MCP sets `code`, new
  // MCP sets `codeFingerprint`. A follow-up CONTRACT migration drops `code` and
  // makes `codeFingerprint` required once the new MCP image is fully rolled out.
  code                String?   @unique
  codeFingerprint     String?   @unique @map("code_fingerprint")
  encryptedApiKey     String    @map("encrypted_api_key")
  keyId               String    @map("key_id")
  userId              String    @map("user_id") @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  clientId            String    @map("client_id")
  redirectUri         String    @map("redirect_uri")
  scopes              String[]
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @map("code_challenge_method")
  expiresAt           DateTime  @map("expires_at")
  consumedAt          DateTime? @map("consumed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([consumedAt])
  @@map("oauth_authorization_codes")
}

model OAuthRefreshToken {
  id                String    @id @default(uuid(7)) @db.Uuid
  tokenFingerprint  String    @unique @map("token_fingerprint")
