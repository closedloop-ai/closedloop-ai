// =============================================================================
// GITHUB INTEGRATION
// =============================================================================

model GitHubInstallation {
  id                  String                   @id @default(uuid(7)) @db.Uuid
  organizationId      String?                  @unique @map("organization_id") @db.Uuid
  installationId      Int                      @unique @map("installation_id")
  accountId           Int                      @map("account_id")
  accountLogin        String                   @map("account_login")
  accountType         String                   @map("account_type")
  senderLogin         String                   @map("sender_login")
  senderId            Int                      @map("sender_id")
  status              GitHubInstallationStatus @default(PENDING_CLAIM)
  permissions         Json?
  events              Json?
  repositorySelection String?                  @map("repository_selection")
  suspendedAt         DateTime?                @map("suspended_at")
  suspendedBy         String?                  @map("suspended_by")
  claimedAt           DateTime?                @map("claimed_at")
  claimedByUserId     String?                  @map("claimed_by_user_id") @db.Uuid
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  // Relations
  organization Organization?                  @relation(fields: [organizationId], references: [id])
  repositories GitHubInstallationRepository[]

  @@index([organizationId])
  @@index([status])
  @@index([accountId])
  @@map("github_installations")
}

model GitHubInstallationRepository {
  id             String    @id @default(uuid(7)) @db.Uuid
  installationId String    @map("installation_id") @db.Uuid
  githubRepoId   Int       @map("github_repo_id")
  fullName       String    @map("full_name")
  name           String
  owner          String
  private        Boolean
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastPushedAt   DateTime? @map("last_pushed_at")

  // Relations
  installation GitHubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, githubRepoId])
  @@map("github_installation_repositories")
}

model GitHubPullRequest {
  id             String        @id @default(uuid(7)) @db.Uuid
  workstreamId   String        @map("workstream_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid // Denormalized from workstream for defense-in-depth (org-scoped queries)
  repositoryId   String        @map("repository_id") @db.Uuid
  artifactId     String?       @map("artifact_id") @db.Uuid
  githubId       Int           @map("github_id")
  number         Int
  title          String
  body           String?         @db.Text
  htmlUrl        String          @map("html_url")
  headBranch     String          @map("head_branch")
  baseBranch     String          @map("base_branch")
  headSha        String?         @map("head_sha")
  state          GitHubPRState   @default(OPEN)
  isDraft        Boolean         @default(false) @map("is_draft")
  checksStatus   ChecksStatus    @default(UNKNOWN) @map("checks_status")
  reviewDecision ReviewDecision? @map("review_decision")
  closedAt       DateTime?       @map("closed_at")
  mergedAt       DateTime?       @map("merged_at")
  mergeCommitSha String?         @map("merge_commit_sha")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  workstream     Workstream              @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  artifact       Artifact?               @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  ratings        PullRequestRating[]
  reviewComments GitHubPRReviewComment[]
  reviews        GitHubPRReview[]

  @@unique([repositoryId, number])
  @@index([workstreamId, state])
  @@index([headSha])
  @@index([organizationId])
  @@index([artifactId])
  @@map("github_pull_requests")
}

model GitHubPRReviewComment {
  id              String               @id @default(uuid(7)) @db.Uuid
  pullRequestId   String               @map("pull_request_id") @db.Uuid
  githubCommentId BigInt               @unique @map("github_comment_id")
  reviewId        BigInt?              @map("review_id")
  body            String               @db.Text
  path            String?
  line            Int?
  authorLogin     String               @map("author_login")
  authorAvatarUrl String?              @map("author_avatar_url")
  state           PRReviewCommentState @default(PENDING)
  htmlUrl         String               @map("html_url")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  pullRequest GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId, state])
  @@map("github_pr_review_comments")
}

model GitHubPRReview {
  id              String         @id @default(uuid(7)) @db.Uuid
  pullRequestId   String         @map("pull_request_id") @db.Uuid
  githubReviewId  BigInt         @unique @map("github_review_id")
  authorLogin     String         @map("author_login")
  authorAvatarUrl String?        @map("author_avatar_url")
  state           ReviewDecision
  body            String?        @db.Text
  htmlUrl         String         @map("html_url")
  submittedAt     DateTime       @map("submitted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  pullRequest GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, authorLogin])
  @@map("github_pr_reviews")
}

model GitHubActionRun {
  id           String             @id @default(uuid(7)) @db.Uuid
  workstreamId String             @map("workstream_id") @db.Uuid
  repositoryId String             @map("repository_id") @db.Uuid
  runId        BigInt?            @map("run_id")
  workflowName String             @map("workflow_name")
  status       GitHubActionStatus @default(PENDING)
  conclusion   String?
  htmlUrl      String             @map("html_url")
  triggerEvent String             @map("trigger_event")
  triggerData  Json?              @map("trigger_data")
  sessionId    String?            @map("session_id")
  jobType      String?            @map("job_type")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([repositoryId, runId])
  @@index([workstreamId, status])
  @@index([workstreamId, workflowName])
  @@map("github_action_runs")
}

