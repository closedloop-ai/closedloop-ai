// Consolidated ratings for any artifact. Absorbs the prior DocumentRating
// and PullRequestRating tables — both now live at @@map("artifact_ratings").
// `artifactVersion` is nullable because PR/deployment ratings aren't
// version-scoped; document ratings keep it populated.
model ArtifactRating {
  id              String   @id @default(uuid(7)) @map("id") @db.Uuid
  artifactId      String   @map("artifact_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
