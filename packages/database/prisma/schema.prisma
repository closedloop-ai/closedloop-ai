model CommentThread {
  id               String       @id @default(uuid(7)) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  source           ThreadSource @default(NATIVE)
  externalId       String?      @map("external_id")
  roomId           String?      @map("room_id")
  artifactId       String?      @map("artifact_id") @db.Uuid
  status           ThreadStatus @default(OPEN)
  metadata         Json?
  createdAtVersion Int?         @map("created_at_version")
  resolvedAt       DateTime?    @map("resolved_at")
  resolvedById     String?      @map("resolved_by_id") @db.Uuid
  createdById      String?      @map("created_by_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization     Organization                   @relation(fields: [organizationId], references: [id])
  artifact         Artifact?                      @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  comments         Comment[]
  githubProjection GitHubCommentThreadProjection?

  @@unique([organizationId, externalId])
  @@unique([id, artifactId], map: "comment_threads_id_artifact_id_key")
  @@index([organizationId, artifactId, status])
  @@index([organizationId, roomId])
  @@index([organizationId, status, updatedAt])
  @@index([createdById])
  @@map("comment_threads")
}

// Provider-specific projection for GitHub review and issue-comment thread state.
// Generic artifact comments stay in CommentThread so future sources do not inherit GitHub columns.
model GitHubCommentThreadProjection {
  threadId               String                    @id @map("thread_id") @db.Uuid
  branchArtifactId       String                    @map("branch_artifact_id") @db.Uuid
  pullRequestDetailId    String                    @map("pull_request_detail_id") @db.Uuid
  threadKind             GitHubCommentThreadKind   @map("thread_kind")
  reviewThreadId         String?                   @map("review_thread_id")
  rootCommentId          String?                   @map("root_comment_id")
  reviewId               String?                   @map("review_id")
  path                   String?
  line                   Int?
  side                   GitHubDiffSide?
  startLine              Int?                      @map("start_line")
  startSide              GitHubDiffSide?           @map("start_side")
  commitSha              String?                   @map("commit_sha")
  htmlUrl                String?                   @map("html_url") @db.Text
  resolvable             Boolean                   @default(false)
  legacyState            GitHubLegacyCommentState? @map("legacy_state")
  deletedAt              DateTime?                 @map("deleted_at")
  lastSyncedAt           DateTime?                 @map("last_synced_at")
  fetchCredentialType    String?                   @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId String?                   @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism         String?                   @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger           String?                   @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt        DateTime?                 @map("fetch_observed_at")
  fetchResultReason      String?                   @map("fetch_result_reason") @db.VarChar(64)

  thread             CommentThread             @relation(fields: [threadId, branchArtifactId], references: [id, artifactId], onDelete: Cascade)
  branch             BranchDetail              @relation(fields: [branchArtifactId], references: [artifactId], onDelete: Cascade)
  pullRequestDetail  PullRequestDetail         @relation(fields: [pullRequestDetailId, branchArtifactId], references: [id, branchArtifactId], onDelete: Cascade)
  commentProjections GitHubCommentProjection[]

  @@unique([threadId, branchArtifactId], map: "github_comment_thread_projections_thread_branch_key")
  @@index([pullRequestDetailId, threadKind, rootCommentId], map: "github_comment_thread_projections_root_comment_idx")
  @@index([pullRequestDetailId, threadKind, reviewThreadId], map: "github_comment_thread_projections_review_thread_idx")
  @@index([pullRequestDetailId], map: "github_comment_thread_projections_pr_detail_idx")
  @@index([lastSyncedAt], map: "github_comment_thread_projections_last_synced_at_idx")
  @@map("github_comment_thread_projections")
}

model Comment {
  id              String    @id @default(uuid(7)) @db.Uuid
  threadId        String    @map("thread_id") @db.Uuid
  authorId        String    @map("author_id") @db.Uuid
  body            Json
  plainText       String?   @map("plain_text") @db.Text
  externalId      String?   @map("external_id")
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  editedAt        DateTime? @map("edited_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  thread           CommentThread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent           Comment?                 @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          Comment[]                @relation("CommentReplies")
  reactions        CommentReaction[]
  attachments      CommentAttachment[]
  githubProjection GitHubCommentProjection?

  @@unique([externalId])
  @@unique([id, threadId], map: "comments_id_thread_id_key")
  @@index([threadId, createdAt])
  @@index([parentCommentId])
  @@index([authorId])
  @@map("comments")
}

// Provider-specific projection for GitHub comment identity and reply metadata.
// Parent/child structure remains generic through Comment.parentCommentId.
model GitHubCommentProjection {
  commentId                String    @id @map("comment_id") @db.Uuid
  threadId                 String    @map("thread_id") @db.Uuid
  externalAuthorId         String?   @map("external_author_id") @db.Uuid
  githubCommentId          String?   @map("github_comment_id")
  githubInReplyToCommentId String?   @map("github_in_reply_to_comment_id")
  githubHtmlUrl            String?   @map("github_html_url") @db.Text
  githubUpdatedAt          DateTime? @map("github_updated_at")
  githubDeletedAt          DateTime? @map("github_deleted_at")
  fetchCredentialType      String?   @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId   String?   @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism           String?   @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger             String?   @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt          DateTime? @map("fetch_observed_at")
  fetchResultReason        String?   @map("fetch_result_reason") @db.VarChar(64)

  comment          Comment                       @relation(fields: [commentId, threadId], references: [id, threadId], onDelete: Cascade)
  threadProjection GitHubCommentThreadProjection @relation(fields: [threadId], references: [threadId], onDelete: Cascade)
  externalAuthor   ExternalCommentAuthor?        @relation(fields: [externalAuthorId], references: [id], onDelete: SetNull)

  @@unique([commentId, threadId], map: "github_comment_projections_comment_thread_key")
  @@index([threadId, githubCommentId], map: "github_comment_projections_thread_github_comment_idx")
  @@index([githubInReplyToCommentId], map: "github_comment_projections_in_reply_to_idx")
  @@index([externalAuthorId], map: "github_comment_projections_external_author_id_idx")
  @@map("github_comment_projections")
}

model ExternalCommentAuthor {
  id                      String                  @id @default(uuid(7)) @db.Uuid
  organizationId          String                  @map("organization_id") @db.Uuid
  provider                ExternalCommentProvider
  providerUserId          String                  @map("provider_user_id")
  providerNodeId          String?                 @map("provider_node_id")
  providerLogin           String                  @map("provider_login")
  normalizedProviderLogin String                  @map("normalized_provider_login")
  displayName             String?                 @map("display_name")
  avatarUrl               String?                 @map("avatar_url")
  profileUrl              String?                 @map("profile_url")
  userId                  String                  @map("user_id") @db.Uuid
  firstSeenAt             DateTime                @default(now()) @map("first_seen_at")
  lastSeenAt              DateTime                @default(now()) @map("last_seen_at")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")

  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubCommentProjections GitHubCommentProjection[]

  @@unique([organizationId, provider, providerUserId])
  @@index([organizationId, provider, normalizedProviderLogin])
  @@index([userId])
  @@map("external_comment_authors")
}

model CommentAttachment {
  id         String   @id @default(uuid(7)) @db.Uuid
  commentId  String   @map("comment_id") @db.Uuid
  externalId String?  @map("external_id")
  name       String
  size       Int?
  mimeType   String?  @map("mime_type")
  url        String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([externalId])
  @@index([commentId])
  @@map("comment_attachments")
}

model CommentReaction {
  id        String   @id @default(uuid(7)) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

// =============================================================================
// LOOPS (Runtime v2 - Container-based compute)
// =============================================================================

model Loop {
  id             String      @id @default(uuid(7)) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  status         LoopStatus  @default(PENDING)
  command        LoopCommand

  // Optional relationships
  artifactId   String? @map("artifact_id") @db.Uuid
  parentLoopId String? @map("parent_loop_id") @db.Uuid

  // Execution context
  prompt          String? @db.Text
  repo            Json? // { fullName: string, branch: string }
  additionalRepos Json?   @map("additional_repos") // Array<{ fullName: string, branch: string }>
  contextRefs     Json?   @map("context_refs") // Array<{ sourceId, sourceType, include }>

  // Harness selection — which AI harness to use for this loop
  harness String @default("claude")

  // Compute target (local machine) — null for cloud/legacy runs
  computeTargetId String? @map("compute_target_id") @db.Uuid

  // Container tracking
  containerId      String?   @map("container_id") // ECS task ARN
  s3StateKey       String?   @map("s3_state_key") // S3 prefix for state
  // Set by the loop-state retention sweep once this loop's S3 state (conversation
  // history, context-pack, logs) has been purged. Marks the loop done so the
  // daily cron skips it on subsequent runs. Null = state not yet purged.
  s3StateCleanedAt DateTime? @map("s3_state_cleaned_at")

  // PR and session tracking (populated by harness agent on completion)
  prUrl      String? @map("pr_url")
  prNumber   Int?    @map("pr_number")
  branchName String? @map("branch_name")
  sessionId  String? @map("session_id")

  // The SESSION-typed Artifact that materializes this loop in the unified
  // Sessions list (FEA-1718). Unique → at most one Session per loop.
  sessionArtifactId String? @unique @map("session_artifact_id") @db.Uuid

  // Cost tracking
  tokensInput   Int      @default(0) @map("tokens_input")
  tokensOutput  Int      @default(0) @map("tokens_output")
  tokensByModel Json?    @map("tokens_by_model") // { "claude-opus-4": { input, output }, ... }
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(10, 6)

  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Revival tracking
  revivalCount  Int       @default(0) @map("revival_count")
  lastRevivalAt DateTime? @map("last_revival_at")

  // Error info
  error Json? // { code: string, message: string }

  // Artifact version at loop creation time — used to detect stale evaluations
  // when a new document version is published while an evaluation is in flight.
  artifactVersion Int? @map("artifact_version")

  // Extensible metadata
  metadata          Json  @default("{}") @map("metadata")
  uploadedArtifacts Json? @map("uploaded_artifacts")

  // Runner token lifecycle — JTI pin-or-compare enforcement
  activeTokenJti        String?   @map("active_token_jti")
  tokenExpiresAt        DateTime? @map("token_expires_at")
  lastRunnerHeartbeatAt DateTime? @map("last_runner_heartbeat_at")
  runnerCapabilities    Json?     @map("runner_capabilities")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization                    Organization                         @relation(fields: [organizationId], references: [id])
  user                            User                                 @relation(fields: [userId], references: [id])
  artifact                        Artifact?                            @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  sessionArtifact                 Artifact?                            @relation("LoopSessionArtifact", fields: [sessionArtifactId], references: [id], onDelete: SetNull)
  computeTarget                   ComputeTarget?                       @relation(fields: [computeTargetId], references: [id])
  parentLoop                      Loop?                                @relation("LoopParent", fields: [parentLoopId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  childLoops                      Loop[]                               @relation("LoopParent")
  evaluations                     ArtifactEvaluation[]
  events                          LoopEvent[]
  tokenRefreshes                  LoopTokenRefresh[]
  executionCredentialConsumptions LoopExecutionCredentialConsumption[]
  tagLoops                        TagLoop[]

  // NOTE: A partial unique index on (artifact_id, command, artifact_version)
  // WHERE status IN ('PENDING', 'CLAIMED', 'RUNNING') is maintained via raw migrations.
  // Prisma cannot express partial indexes. Prisma 7.4+ falsely flags this as drift —
  // we pin to 7.3.0 until resolved. Do NOT drop it.
  // Only applies when both artifactId and artifactVersion are non-null (Postgres
  // treats NULL != NULL in unique indexes, so nullable rows never conflict).
  // Terminal loops (COMPLETED/FAILED/CANCELLED/TIMED_OUT) allow re-runs of the same
  // artifact+command+version without conflict.
  //
  // NOTE: A second partial unique index `loops_blocked_artifact_command_key` on
  // (artifact_id, command) WHERE status = 'BLOCKED' is maintained via raw
  // migration 20260624120000_add_partial_unique_blocked_loop_artifact_command.
  // It enforces at most one deferred (BLOCKED) loop per artifact+command, closing
  // a TOCTOU race in the dispatch idempotency guard. Prisma cannot express partial
  // indexes — do NOT drop it.
  @@index([artifactId, command, artifactVersion])
  @@index([organizationId, status])
  // Covers the (organizationId, artifactId, command) dispatch/idempotency lookups
  // (and the (organizationId, artifactId) prefix lookups). The leading column is
  // organizationId so the index is usable for org-scoped queries, unlike the
  // artifactId-leading index above.
  @@index([organizationId, artifactId, command])
  @@index([organizationId, userId, createdAt])
  @@index([parentLoopId])
  @@index([computeTargetId])
  // Serves the loop-state retention sweep (apps/api/app/cron/cleanup-loop-state):
  // `WHERE status IN (terminal) AND completedAt < cutoff ORDER BY completedAt`,
  // so the daily scan for purgeable terminal loops is an index scan rather than a
  // sequential scan that grows with the loops table.
  @@index([status, completedAt])
  @@map("loops")
}

model LoopEvent {
  id             String   @id @default(uuid(7)) @db.Uuid
  loopId         String   @map("loop_id") @db.Uuid
  type           String // "started" | "output" | "progress" | "tool_call" | "artifact_created" | "completed" | "error" | "tokens_cleared"
  data           Json     @default("{}")
  eventSource    String   @default("system") @map("event_source")
  eventId        String   @map("event_id")
  runnerTokenJti String?  @map("runner_token_jti")
  runnerNonce    String?  @map("runner_nonce") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  loop Loop @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@unique([loopId, eventSource, eventId])
  @@index([loopId, createdAt])
  @@index([loopId, type])
  @@map("loop_events")
}

/// Audit log of loop runner JWT token refreshes. Each row records a successful
/// token rotation so that stale or stolen tokens can be detected.
model LoopTokenRefresh {
  id          String   @id @default(uuid(7)) @db.Uuid
  loopId      String   @map("loop_id") @db.Uuid
  jti         String   @unique
  refreshedAt DateTime @map("refreshed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  loop Loop @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@index([loopId])
  @@map("loop_token_refresh")
}

