// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Feature blocks Feature)
  RELATES_TO // bidirectional association (Feature ↔ Feature)
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  EXECUTED
  DONE
  OBSOLETE
}

enum EvaluationReportType {
  PLAN
  CODE
  PRD
  FEATURE
}

enum EvalStatus {
  FAILED
  NEEDS_IMPROVEMENT
  PASSED
}

enum PromptType {
  AGENT
  JUDGE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum ChecksStatus {
  UNKNOWN
  PENDING
  PASSING
  FAILING
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

// Distinguishes manually created API keys from desktop-managed bootstrap keys.
enum ApiKeySource {
  USER_CREATED
  DESKTOP_MANAGED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LoopStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
  // Deferred at dispatch because a linked blocking artifact is still
  // non-terminal. Re-evaluated by the loop reconciliation cron, which
  // transitions BLOCKED -> PENDING once every blocker resolves. Non-claimable
  // (the orchestrator only claims PENDING loops) and non-terminal.
  BLOCKED
}

enum LoopCommand {
  PLAN
  EXECUTE
  CHAT
  EXPLORE
  REQUEST_CHANGES
  DECOMPOSE
  EVALUATE_PRD
  GENERATE_PRD
  EVALUATE_PLAN
  EVALUATE_CODE
  REQUEST_PRD_CHANGES
  BOOTSTRAP
  MANUAL
  EVALUATE_FEATURE
}

// Discriminates how a SessionDetail row was produced: a synced desktop agent
// run (DESKTOP_SYNC) vs. a materialized orchestration Loop (LOOP). Lets the
// unified Sessions list tell the two apart. See FEA-1718 / PLN-921.
enum SessionOrigin {
  DESKTOP_SYNC
  LOOP
}

enum CustomFieldType {
  TEXT
  NUMBER
  ENUM
  MULTI_ENUM
  DATE
  PEOPLE
}

enum CustomFieldEntityType {
  PROJECT
  DOCUMENT
}

enum NumberFormat {
  NONE
  CURRENCY
  PERCENTAGE
  CUSTOM
}

enum LabelPosition {
  PREFIX
  SUFFIX
}

enum ThreadSource {
  NATIVE
  LIVEBLOCKS
  GITHUB
}

enum ThreadStatus {
  OPEN
  RESOLVED
}

enum ExternalCommentProvider {
  GITHUB
}

enum GitHubCommentThreadKind {
  REVIEW_THREAD
  ISSUE_COMMENT
}

enum GitHubDiffSide {
  LEFT
  RIGHT
}

enum GitHubLegacyCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum PreferredComputeMode {
  LOCAL
  CLOUD
}

// FEA-1684: Relation type for session↔PR links (deterministic extraction).
// Shared with PRD-463 Stage 2 which adds PROBABILISTIC rows on top.
enum SessionPrRelationType {
  CREATED
  REFERENCED
}

// FEA-1684: Source confidence tier for session↔PR links.
enum SessionPrLinkSource {
  DETERMINISTIC
}

// Kinds of first-class artifacts tracked in the `artifacts` parent table.
// Added in Chunk 2a of PLN-321 alongside the Artifact/DocumentDetail models.
enum ArtifactType {
  DOCUMENT
  BRANCH
  DEPLOYMENT
  SESSION
}

// Narrower classification for DOCUMENT-typed artifacts (carries values that
// used to live on the legacy DocumentType enum). Null for PRs and deployments.
enum ArtifactSubtype {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE
  FEATURE
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model PreviewSchemaObservation {
  schemaName      String   @id @map("schema_name")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz

  @@map("preview_schemas_observations")
}

model Organization {
  id                    String    @id @default(uuid(7)) @db.Uuid
  clerkId               String    @unique @map("clerk_id")
  active                Boolean   @default(true) @map("active")
  name                  String
  slug                  String    @unique
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  settings              Json      @default("{}") // settings.computeMode deprecated -- use User.preferredComputeMode instead
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  users                     User[]
  teams                     Team[]
  artifactRatings           ArtifactRating[]
  projects                  Project[]
  artifacts                 Artifact[]
  githubInstallation        GitHubInstallation?
  loops                     Loop[]
  prompts                   Prompt[]
  computeTargets            ComputeTarget[]
  computeTargetHealthChecks ComputeTargetHealthCheck[]
  chatSessions              ChatSession[]
  judgeHumanScores          JudgeHumanScore[]
  customFields              CustomField[]
  commentThreads            CommentThread[]
  agents                    Agent[]
  repoBootstrapConfigs      RepoBootstrapConfig[]
  userPublicKeys            UserPublicKey[]
  publicRepositories        PublicRepository[]
  externalCommentAuthors    ExternalCommentAuthor[]
  githubUserConnections     GitHubUserConnection[]
  tags                      Tag[]
  linearSubtasks            LinearSubtask[]

  @@map("organizations")
}

model User {
  id                       String                @id @default(uuid(7)) @db.Uuid
  clerkId                  String                @map("clerk_id")
  organizationId           String                @map("organization_id") @db.Uuid
  active                   Boolean               @default(true) @map("active")
  email                    String
  firstName                String?               @map("first_name")
  lastName                 String?               @map("last_name")
  avatarUrl                String?               @map("avatar_url")
  phoneNumber              String?               @map("phone_number")
  role                     ApproverRole          @default(ENGINEER)
  linearId                 String?               @map("linear_id")
  slackId                  String?               @map("slack_id")
  githubUsername           String?               @map("github_username")
  claudeApiKeyEncrypted    String?               @map("claude_api_key_encrypted")
  claudeApiKeyLastFour     String?               @map("claude_api_key_last_four")
  claudeApiKeySetAt        DateTime?             @map("claude_api_key_set_at")
  preferredComputeMode     PreferredComputeMode? @map("preferred_compute_mode")
  preferredComputeTargetId String?               @map("preferred_compute_target_id") @db.Uuid
  preferredHarness         String?               @map("preferred_harness")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  // Relations
  organization                Organization                        @relation(fields: [organizationId], references: [id])
  preferredComputeTarget      ComputeTarget?                      @relation("UserPreferredComputeTarget", fields: [preferredComputeTargetId], references: [id])
  teamMemberships             TeamMember[]
  artifactRatings             ArtifactRating[]
  favoriteProjects            FavoriteProject[]
  favoriteArtifacts           FavoriteArtifact[]
  assignedProjects            Project[]                           @relation("ProjectAssignee")
  createdProjects             Project[]                           @relation("ProjectCreatedBy")
  assignedArtifacts           Artifact[]                          @relation("ArtifactAssignee")
  createdArtifacts            Artifact[]                          @relation("ArtifactCreatedBy")
  approvedDocumentDetails     DocumentDetail[]                    @relation("DocumentDetailApprover")
  loops                       Loop[]
  computeTargets              ComputeTarget[]
  sessionDetails              SessionDetail[]
  chatSessions                ChatSession[]
  judgeHumanScores            JudgeHumanScore[]
  createdCustomFields         CustomField[]
  updatedCustomFieldValues    CustomFieldValue[]
  dismissedGenerationStatuses DocumentGenerationStatusDismissal[]
  createdAgents               Agent[]                             @relation("AgentCreatedBy")
  agentVersionChanges         AgentVersion[]                      @relation("AgentVersionChangedBy")
  publicKeys                  UserPublicKey[]
  externalCommentAuthors      ExternalCommentAuthor[]
  githubUserConnections       GitHubUserConnection[]
  createdTags                 Tag[]                               @relation("TagCreatedBy")

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model UserPublicKey {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  publicKeyBase64 String   @map("public_key_base64")
  fingerprint     String
  createdAt       DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([organizationId])
  @@map("user_public_keys")
}

model ComputeTarget {
  id                     String    @id @default(uuid(7)) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  machineName            String    @map("machine_name")
  platform               String
  capabilities           Json      @default("{}")
  supportedOperations    Json      @default("[]") @map("supported_operations")
  lastSeenAt             DateTime  @default(now()) @map("last_seen_at")
  lastAgentSessionSyncAt DateTime? @map("last_agent_session_sync_at")
  isOnline               Boolean   @default(false) @map("is_online")
  isSharedWithOrg        Boolean   @default(false) @map("is_shared_with_org")
  gatewayId              String?   @map("gateway_id")
  selectedHarness        String    @default("claude") @map("selected_harness")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  user                                User                                 @relation(fields: [userId], references: [id])
  preferringUsers                     User[]                               @relation("UserPreferredComputeTarget")
  desktopCommands                     DesktopCommand[]
  loopExecutionCredentialConsumptions LoopExecutionCredentialConsumption[]
  loops                               Loop[]
  sessionDetails                      SessionDetail[]
  healthCheck                         ComputeTargetHealthCheck?

  @@unique([userId, machineName])
  @@index([organizationId, userId])
  // NOTE: A partial unique index on gateway_id WHERE gateway_id IS NOT NULL is
  // maintained via raw migration. Prisma cannot express partial indexes. Do NOT
  // add @@unique([gatewayId]) here; it would reject multiple NULL rows.
  // See migration: add_compute_targets_gateway_id_unique
  @@index([organizationId, userId, gatewayId])
  @@index([userId, isOnline])
  @@index([organizationId, isSharedWithOrg])
  @@map("compute_targets")
}

model ComputeTargetHealthCheck {
  id                      String   @id @default(uuid(7)) @db.Uuid
  organizationId          String   @map("organization_id") @db.Uuid
  computeTargetId         String   @unique @map("compute_target_id") @db.Uuid
  checkedAt               DateTime @map("checked_at")
  expectedMcpUrl          String?  @map("expected_mcp_url")
  latestVersion           String?  @map("latest_version")
  pluginAutoUpdateEnabled Boolean  @default(false) @map("plugin_auto_update_enabled")
  result                  Json
  allRequiredPassed       Boolean  @map("all_required_passed")
  requiredFailureIds      Json     @default("[]") @map("required_failure_ids")
  schemaVersion           Int      @default(1) @map("schema_version")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  computeTarget ComputeTarget @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)

  @@index([organizationId, checkedAt])
  @@map("compute_target_health_checks")
}

// Type-specific detail for SESSION-typed artifacts (captured agent/session
// runs synced from the desktop). 1:1 with `Artifact` via shared `artifact_id`
// primary key, mirroring document_detail / branch_detail / deployment_detail.
// Hoisted to the parent `artifacts` row: organizationId, projectId, name,
// status. The raw harness status string is stored on `artifacts.status`
// (free-form TEXT) — the curated session lifecycle is a deferred follow-up.
model SessionDetail {
  artifactId         String        @id @map("artifact_id") @db.Uuid
  // Session owner. Nullable + SetNull so a session survives its creator's
  // deletion as an org-owned artifact (matches assignee_id/created_by_id).
  userId             String?       @map("user_id") @db.Uuid
  computeTargetId    String        @map("compute_target_id") @db.Uuid
  externalSessionId  String        @map("external_session_id")
  harness            String        @default("unknown")
  // How this session row was produced: synced desktop run vs. materialized Loop
  // (FEA-1718). Existing rows default to DESKTOP_SYNC.
  origin             SessionOrigin @default(DESKTOP_SYNC)
  // Per-session billing mode resolved by the desktop (subscription vs. API-key
  // plan, from the desktop's billing_mode column). Opaque string; the usage
  // cost split classifies it for DESKTOP_SYNC sessions that have no source Loop.
  billingMode        String?       @map("billing_mode")
  cwd                String?
  repositoryFullName String?       @map("repository_full_name")
  worktreePath       String?       @map("worktree_path")
  model              String?
  deviceTimeZone     String?       @map("device_time_zone")
  sessionStartedAt   DateTime      @map("session_started_at")
  sessionUpdatedAt   DateTime      @map("session_updated_at")
  // Genuine-activity timestamp: MAX(agent_session_events.event_created_at)
  // floored at sessionStartedAt. Unlike sessionUpdatedAt (bumped by desktop
  // OTEL ingest / enrichment / sync bookkeeping) this advances only on real
  // agent activity, and is the default sort for the Sessions list. Nullable for
  // pre-backfill rows; readers fall back to sessionStartedAt.
  lastActivityAt     DateTime?     @map("last_activity_at")
  sessionEndedAt     DateTime?     @map("session_ended_at")
  awaitingInputSince DateTime?     @map("awaiting_input_since")
  sourceArtifactId   String?       @map("source_artifact_id")
  sourceLoopId       String?       @map("source_loop_id")
  issueId            String?       @map("issue_id")
  baseBranch         String?       @map("base_branch")
  state              String?
  branch             String?
  issues             Json?
  pullRequests       Json?         @map("pull_requests")
  wallClock          String?       @map("wall_clock")
  activeAgent        String?       @map("active_agent")
  waitingUser        String?       @map("waiting_user")
  linesAdded         Int?          @map("lines_added")
  linesRemoved       Int?          @map("lines_removed")
  filesChanged       Int?          @map("files_changed")
  // Provenance of the lines_*/files_changed scalars: "git" when the desktop
  // sent source-tagged gitDiffStats, null when only heuristic/agent-estimated
  // scalars were synced. Readers rehydrate gitDiffStats from this marker.
  locSource          String?       @map("loc_source")
  // Branch-level LOC (working-branch changes vs the author's contributed lines):
  // a distinct metric from the authored gitDiffStats scalars, so it lives in its
  // own columns. Readers rehydrate branchDiffStats from these; branch_loc_source
  // records its provenance independently of loc_source.
  branchLinesAdded   Int?          @map("branch_lines_added")
  branchLinesRemoved Int?          @map("branch_lines_removed")
  branchFilesChanged Int?          @map("branch_files_changed")
  branchLocSource    String?       @map("branch_loc_source")
  turns              Int?
  steeringEpisodes   Int?          @map("steering_episodes")
  autonomy           Int?
  activityBuckets    Json?         @map("activity_buckets")
  sessionSpan        Json?         @map("session_span")
  markers            Json?
  throttles          Json?
  tracePhaseSources  Json?         @map("trace_phase_sources")
  throttleSources    Json?         @map("throttle_sources")
  correctionSources  Json?         @map("correction_sources")
  phases             Json?
  phaseIterations    Json?         @map("phase_iterations")
  phaseLoopbacks     Json?         @map("phase_loopbacks")
  inputTokens        Int           @default(0) @map("input_tokens")
  outputTokens       Int           @default(0) @map("output_tokens")
  cacheReadTokens    Int           @default(0) @map("cache_read_tokens")
  cacheWriteTokens   Int           @default(0) @map("cache_write_tokens")
  estimatedCost      Decimal       @default(0) @map("estimated_cost") @db.Decimal(10, 6)
  agentCount         Int           @default(0) @map("agent_count")
  toolUseCount       Int           @default(0) @map("tool_use_count")
  errorCount         Int           @default(0) @map("error_count")
  metadata           Json?
  agents             Json          @default("[]")
  dataRevision       Int?          @map("data_revision")
  lastSyncedAt       DateTime      @default(now()) @map("last_synced_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  artifact          Artifact                 @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  user              User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  computeTarget     ComputeTarget            @relation(fields: [computeTargetId], references: [id], onDelete: Restrict)
  tokenUsageByModel AgentSessionTokenUsage[]
  events            AgentSessionEvent[]

  @@unique([computeTargetId, externalSessionId])
  @@index([sessionStartedAt])
  @@index([userId, sessionStartedAt])
  @@index([harness, sessionStartedAt])
  @@index([computeTargetId, sessionUpdatedAt])
  @@index([computeTargetId, lastActivityAt])
  @@index([lastActivityAt])
  @@map("session_detail")
}

model AgentSessionEvent {
  id              String   @id @default(uuid(7)) @db.Uuid
  agentSessionId  String   @map("agent_session_id") @db.Uuid
  externalEventId String   @map("external_event_id")
  agentExternalId String?  @map("agent_external_id")
  eventType       String   @map("event_type")
  toolName        String?  @map("tool_name")
  summary         String?
  data            Json?
  eventCreatedAt  DateTime @map("event_created_at")
  createdAt       DateTime @default(now()) @map("created_at")

  session SessionDetail @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)

  @@unique([agentSessionId, externalEventId])
  @@index([agentSessionId, eventCreatedAt])
  @@map("agent_session_events")
}

model AgentSessionTokenUsage {
  id               String   @id @default(uuid(7)) @db.Uuid
  agentSessionId   String   @map("agent_session_id") @db.Uuid
  model            String
  inputTokens      Int      @default(0) @map("input_tokens")
  outputTokens     Int      @default(0) @map("output_tokens")
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int      @default(0) @map("cache_write_tokens")
  estimatedCost    Decimal  @default(0) @map("estimated_cost") @db.Decimal(10, 6)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  session SessionDetail @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)

  @@unique([agentSessionId, model])
  @@index([model])
  @@map("agent_session_token_usage")
}

model DesktopCommand {
  id                 String    @id @default(uuid(7)) @db.Uuid
  computeTargetId    String    @map("compute_target_id") @db.Uuid
  idempotencyKey     String?   @map("idempotency_key")
  requestFingerprint String    @map("request_fingerprint")
  operationId        String    @map("operation_id")
  requestPayload     Json      @map("request_payload")
  status             String
  error              String?
  lastSequenceAcked  Int       @default(0) @map("last_sequence_acked")
  queuedTimeoutMs    Int?      @map("queued_timeout_ms")
  runningTimeoutMs   Int?      @map("running_timeout_ms")
  createdAt          DateTime  @default(now()) @map("created_at")
  startedAt          DateTime? @map("started_at")
  finishedAt         DateTime? @map("finished_at")

  computeTarget                      ComputeTarget                       @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  events                             DesktopCommandEvent[]
  loopExecutionCredentialConsumption LoopExecutionCredentialConsumption?

  // NOTE: A partial unique index on (compute_target_id, idempotency_key) WHERE
  // idempotency_key IS NOT NULL is maintained via raw migrations. Prisma cannot
  // express partial indexes. Prisma 7.4+ falsely flags this as drift — we pin
  // to 7.3.0 until resolved. Do NOT drop it.
  // See: https://github.com/prisma/prisma/issues/29289
  @@index([computeTargetId, status, createdAt])
  @@index([operationId])
  @@map("desktop_commands")
}

model LoopExecutionCredentialConsumption {
  commandId       String   @id @map("command_id") @db.Uuid
  loopId          String   @map("loop_id") @db.Uuid
  computeTargetId String   @map("compute_target_id") @db.Uuid
  gatewayId       String   @map("gateway_id")
  action          String
  consumedAt      DateTime @default(now()) @map("consumed_at")

  command       DesktopCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)
  computeTarget ComputeTarget  @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  loop          Loop           @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@index([loopId])
  @@index([computeTargetId, gatewayId], map: "loop_execution_credential_consumptions_compute_target_id_gatewa")
  @@map("loop_execution_credential_consumptions")
}

model DesktopCommandEvent {
  commandId    String   @map("command_id") @db.Uuid
  sequence     Int
  eventType    String   @map("event_type")
  eventPayload Json     @map("event_payload")
  createdAt    DateTime @default(now()) @map("created_at")

  command DesktopCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@id([commandId, sequence])
  @@map("desktop_command_events")
}

model Project {
  id                  String        @id @default(uuid(7)) @db.Uuid
  organizationId      String        @map("organization_id") @db.Uuid
  name                String
  description         String?
  priority            Priority      @default(MEDIUM)
  status              ProjectStatus @default(NOT_STARTED)
  assigneeId          String?       @map("assignee_id") @db.Uuid
  createdById         String        @map("created_by_id") @db.Uuid
  slug                String?
  targetDate          DateTime?     @map("target_date")
  codebaseSummary     String?       @map("codebase_summary")
  lastIndexedAt       DateTime?     @map("last_indexed_at")
  settings            Json          @default("{}")
  sortOrder           Int?          @map("sort_order")
  isTemplatesSentinel Boolean       @default(false) @map("is_templates_sentinel")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id])
  assignee     User?             @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  createdBy    User              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  artifacts    Artifact[]
  teams        ProjectTeam[]
  favoritedBy  FavoriteProject[]
  tagProjects  TagProject[]

  @@unique([organizationId, slug])
  @@index([assigneeId])
  @@index([createdById])
  @@index([organizationId, isTemplatesSentinel])
  @@map("projects")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]
  repositories TeamRepository[]

  @@unique([organizationId, slug])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Per-team curated list of GitHub repositories with default-selection and primary designation
model TeamRepository {
  id                       String   @id @default(uuid(7)) @db.Uuid
  teamId                   String   @map("team_id") @db.Uuid
  installationRepositoryId String   @map("installation_repository_id") @db.Uuid
  isDefaultSelected        Boolean  @default(false) @map("is_default_selected")
  isPrimary                Boolean  @default(false) @map("is_primary")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  team       Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  repository GitHubInstallationRepository @relation(fields: [installationRepositoryId], references: [id], onDelete: Cascade)

  @@unique([teamId, installationRepositoryId])
  @@index([installationRepositoryId])
  @@map("team_repositories")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

/// Per-user favorite projects for quick access in the sidebar
model FavoriteProject {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("favorite_projects")
}

/// Per-user favorite artifacts for quick access and filtering
model FavoriteArtifact {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  artifactId String   @map("artifact_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([userId, artifactId])
  @@index([artifactId])
  @@map("favorite_artifacts")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model DocumentGenerationStatusDismissal {
  id            String   @id @default(uuid(7)) @db.Uuid
  artifactId    String   @unique @map("artifact_id") @db.Uuid
  dismissedById String   @map("dismissed_by_id") @db.Uuid
  runKey        String   @map("run_key")
  dismissedAt   DateTime @default(now()) @map("dismissed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  artifact    Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  dismissedBy User     @relation(fields: [dismissedById], references: [id], onDelete: Restrict)

  @@index([dismissedById])
  @@map("artifact_generation_status_dismissals")
}

model DocumentVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  documentId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  documentDetail DocumentDetail @relation(fields: [documentId], references: [artifactId], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

model Artifact {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  // Nullable so machine-generated SESSION artifacts captured outside any project
  // can exist unparented. The project requirement for DOCUMENT/BRANCH/DEPLOYMENT
  // is enforced at the service layer (apps/api), not the column.
  projectId      String?          @map("project_id") @db.Uuid
  type           ArtifactType
  subtype        ArtifactSubtype?
  name           String
  slug           String?
  assigneeId     String?          @map("assignee_id") @db.Uuid
  status         String
  priority       Priority?
  dueDate        DateTime?        @map("due_date")
  externalUrl    String?          @map("external_url")
  sortOrder      Int?             @map("sort_order")
  createdAt      DateTime         @default(now()) @map("created_at")
  createdById    String?          @map("created_by_id") @db.Uuid
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  organization              Organization                       @relation(fields: [organizationId], references: [id])
  project                   Project?                           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee                  User?                              @relation("ArtifactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy                 User?                              @relation("ArtifactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  document                  DocumentDetail?
  branch                    BranchDetail?
  pullRequest               PullRequestDetail?
  deployment                DeploymentDetail?
  session                   SessionDetail?
  loopSession               Loop?                              @relation("LoopSessionArtifact")
  branchDeployments         DeploymentDetail[]                 @relation("DeploymentOfBranch")
  pullRequestDetails        PullRequestDetail[]                @relation("BranchPullRequests")
  sourceLinks               ArtifactLink[]                     @relation("ArtifactLinkSource")
  targetLinks               ArtifactLink[]                     @relation("ArtifactLinkTarget")
  sessionPrLinks            SessionPullRequestLink[]           @relation("SessionPrLinks")
  ratings                   ArtifactRating[]
  evaluations               ArtifactEvaluation[]
  commentThreads            CommentThread[]
  fileAttachments           FileAttachment[]
  loops                     Loop[]
  generationStatusDismissal DocumentGenerationStatusDismissal?
  tagArtifacts              TagArtifact[]
  favoritedBy               FavoriteArtifact[]
  linearSubtasks            LinearSubtask[]

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, type])
  @@index([organizationId, projectId, sortOrder])
  @@index([organizationId, type, status])
  @@index([organizationId, assigneeId])
  @@map("artifacts")
}

// Type-specific detail for DOCUMENT-typed artifacts. 1:1 with `Artifact` via
// shared `artifact_id` primary key. Other detail tables (pull_request_detail,
// deployment_detail) arrive in Chunk 2b.
model DocumentDetail {
  artifactId         String           @id @map("artifact_id") @db.Uuid
  fileName           String?          @map("file_name")
  approverId         String?          @map("approver_id") @db.Uuid
  templateForType    ArtifactSubtype? @map("template_for_type")
  latestVersion      Int              @default(1) @map("latest_version")
  repositorySnapshot Json             @map("repository_snapshot")

  artifact Artifact          @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  approver User?             @relation("DocumentDetailApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions DocumentVersion[]

  @@map("document_detail")
}

// Branch-owned detail for BRANCH-typed artifacts.
model BranchDetail {
  artifactId                    String       @id @map("artifact_id") @db.Uuid
  repositoryId                  String       @map("repository_id") @db.Uuid
  branchName                    String       @map("branch_name")
  baseBranch                    String?      @map("base_branch")
  baseBranchSource              String?      @map("base_branch_source")
  headSha                       String?      @map("head_sha")
  headShaSource                 String?      @map("head_sha_source")
  headShaObservedAt             DateTime?    @map("head_sha_observed_at")
  // Genuine-activity timestamp for the branch: monotonic GREATEST() of real
  // git/GitHub events — a pushed commit (headShaObservedAt), PR open/merge/close,
  // and PR review submission. Deliberately NOT bumped by CI check runs, file/
  // checks cache refreshes, sync bookkeeping, or session activity. Default sort
  // for the Branches list. Nullable for pre-backfill rows; readers fall back to
  // the Artifact createdAt.
  lastActivityAt                DateTime?    @map("last_activity_at")
  lastPushBeforeSha             String?      @map("last_push_before_sha")
  currentPullRequestDetailId    String?      @map("current_pull_request_detail_id") @db.Uuid
  deletedAt                     DateTime?    @map("deleted_at")
  checksStatus                  ChecksStatus @default(UNKNOWN) @map("checks_status")
  checksDetailHeadSha           String?      @map("checks_detail_head_sha")
  checksDetailTotalCount        Int          @default(0) @map("checks_detail_total_count")
  checksDetailTruncated         Boolean      @default(false) @map("checks_detail_truncated")
  checksDetailProviderState     String?      @map("checks_detail_provider_state")
  checksDetailUnavailableReason String?      @map("checks_detail_unavailable_reason")
  checksDetailUpdatedAt         DateTime?    @map("checks_detail_updated_at")
  fileCacheStatus               String       @default("absent") @map("file_cache_status")
  fileCacheHeadSha              String?      @map("file_cache_head_sha")
  fileCacheFileCount            Int          @default(0) @map("file_cache_file_count")
  fileCachePatchBytes           Int          @default(0) @map("file_cache_patch_bytes")
  fileCacheUpdatedAt            DateTime?    @map("file_cache_updated_at")
  syncStatus                    String       @default("idle") @map("sync_status")
  lastSyncStartedAt             DateTime?    @map("last_sync_started_at")
  lastSyncCompletedAt           DateTime?    @map("last_sync_completed_at")
  lastSyncErrorCode             String?      @map("last_sync_error_code")
  lastSyncErrorMessage          String?      @map("last_sync_error_message") @db.Text
  createdAt                     DateTime     @default(now()) @map("created_at")
  updatedAt                     DateTime     @updatedAt @map("updated_at")

  artifact                 Artifact                        @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  repository               GitHubInstallationRepository    @relation(fields: [repositoryId], references: [id])
  currentPullRequestDetail PullRequestDetail?              @relation("CurrentBranchPullRequest", fields: [currentPullRequestDetailId], references: [id], onDelete: SetNull)
  fileChanges              BranchFileChange[]
  statusChecks             BranchStatusCheck[]
  githubCommentProjections GitHubCommentThreadProjection[]

  @@unique([repositoryId, branchName])
  @@index([repositoryId, headSha])
  @@index([currentPullRequestDetailId])
  @@index([syncStatus])
  @@index([lastActivityAt])
  @@map("branch_detail")
}

// Bounded current-head GitHub status/check context projection for Branch View.
model BranchStatusCheck {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchArtifactId String   @map("branch_artifact_id") @db.Uuid
  headSha          String   @map("head_sha")
  providerKey      String   @map("provider_key") @db.VarChar(160)
  kind             String   @db.VarChar(32)
  providerNodeId   String?  @map("provider_node_id") @db.VarChar(255)
  name             String   @db.VarChar(255)
  status           String?  @db.VarChar(64)
  conclusion       String?  @db.VarChar(64)
  targetUrl        String?  @map("target_url") @db.VarChar(2048)
  position         Int
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  branch BranchDetail @relation(fields: [branchArtifactId], references: [artifactId], onDelete: Cascade)

  @@unique([branchArtifactId, headSha, providerKey], map: "branch_status_checks_branch_head_provider_key")
  @@index([branchArtifactId, headSha, position], map: "branch_status_checks_branch_head_position_idx")
  @@map("branch_status_checks")
}

// GitHub pull request conversation detail. These rows are nested under branch
// artifacts and preserve current or historical PR-specific review state.
model PullRequestDetail {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artifactId           String?         @unique @map("artifact_id") @db.Uuid
  branchArtifactId     String          @map("branch_artifact_id") @db.Uuid
  repositoryId         String          @map("repository_id") @db.Uuid
  githubId             String          @unique @map("github_id")
  number               Int
  title                String?
  htmlUrl              String?         @map("html_url")
  body                 String?         @db.Text
  prState              GitHubPRState   @default(OPEN) @map("pr_state")
  isDraft              Boolean         @default(false) @map("is_draft")
  reviewDecision       ReviewDecision? @map("review_decision")
  isCurrent            Boolean         @default(false) @map("is_current")
  closedAt             DateTime?       @map("closed_at")
  mergedAt             DateTime?       @map("merged_at")
  mergeCommitSha       String?         @map("merge_commit_sha")
  lastVerifiedAt       DateTime?       @map("last_verified_at")
  lastRefreshAttemptAt DateTime?       @map("last_refresh_attempt_at")

  artifact                       Artifact?                       @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  branchArtifact                 Artifact                        @relation("BranchPullRequests", fields: [branchArtifactId], references: [id], onDelete: Cascade)
  repository                     GitHubInstallationRepository    @relation(fields: [repositoryId], references: [id])
  reviews                        GitHubPRReview[]
  githubCommentThreadProjections GitHubCommentThreadProjection[]
  currentForBranches             BranchDetail[]                  @relation("CurrentBranchPullRequest")
  sessionPrLinks                 SessionPullRequestLink[]

  @@unique([repositoryId, number])
  @@unique([id, branchArtifactId], map: "pull_request_detail_id_branch_artifact_id_key")
  @@index([branchArtifactId, isCurrent])
  @@map("pull_request_detail")
}

// Bounded branch file-change metadata cache. Raw file contents stay in GitHub
// and are fetched only through explicit diff/content paths.
model BranchFileChange {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchArtifactId   String   @map("branch_artifact_id") @db.Uuid
  headSha            String   @map("head_sha")
  path               String
  previousPath       String?  @map("previous_path")
  status             String
  additions          Int?
  deletions          Int?
  changes            Int?
  patch              String?  @db.Text
  patchBytes         Int      @default(0) @map("patch_bytes")
  patchOmittedReason String?  @map("patch_omitted_reason")
  isBinary           Boolean  @default(false) @map("is_binary")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  branch BranchDetail @relation(fields: [branchArtifactId], references: [artifactId], onDelete: Cascade)

  @@unique([branchArtifactId, headSha, path])
  @@index([branchArtifactId, path])
  @@index([branchArtifactId, headSha])
  @@map("branch_file_changes")
}

// Type-specific detail for DEPLOYMENT-typed artifacts. 1:1 with `Artifact`
// via shared `artifact_id` primary key. Rows are backfilled from the
// PREVIEW_DEPLOYMENT rows in the legacy `external_links` table in
// Chunk 2B. All columns nullable because today's `DeploymentMetadata` is
// loosely shaped. Deployment state lives only on the parent `artifact.status`
// (plain TEXT so any vendor value round-trips).
model DeploymentDetail {
  artifactId          String   @id @map("artifact_id") @db.Uuid
  environment         String?
  ref                 String?
  sha                 String?
  githubStatusUrl     String?  @map("github_status_url")
  githubDeploymentUrl String?  @map("github_deployment_url")
  transient           Boolean?
  production          Boolean?
  branchArtifactId    String?  @map("branch_artifact_id") @db.Uuid

  artifact       Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  branchArtifact Artifact? @relation("DeploymentOfBranch", fields: [branchArtifactId], references: [id], onDelete: SetNull)

  @@index([branchArtifactId])
  @@index([ref, sha])
  @@map("deployment_detail")
}

// Replacement for polymorphic `EntityLink` with real FKs. Rows for
// DOCUMENT↔DOCUMENT links are backfilled in 2A; PR/Deployment links are
// added in 2B. Legacy `entity_links` table continues to coexist until 2F.
model ArtifactLink {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sourceId       String   @map("source_id") @db.Uuid
  targetId       String   @map("target_id") @db.Uuid
  linkType       LinkType @map("link_type")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  source Artifact @relation("ArtifactLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Artifact @relation("ArtifactLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([organizationId, sourceId, linkType])
  @@index([organizationId, targetId, linkType])
  @@map("artifact_links")
}

// FEA-1684 / PRD-463 7.1: Deterministic session↔PR associations extracted from
// desktop transcripts. Denormalized repo+number with nullable FK to
// PullRequestDetail (best-effort resolved). Stage 2 (LLM classification) adds
// PROBABILISTIC rows. Do not re-create this table.
model SessionPullRequestLink {
  id                  String                @id @default(uuid(7)) @db.Uuid
  organizationId      String                @map("organization_id") @db.Uuid
  sessionArtifactId   String                @map("session_artifact_id") @db.Uuid
  repositoryFullName  String                @map("repository_full_name")
  prNumber            Int                   @map("pr_number")
  prUrl               String                @map("pr_url")
  relationType        SessionPrRelationType @map("relation_type")
  source              SessionPrLinkSource   @default(DETERMINISTIC)
  confidence          Float?
  pullRequestDetailId String?               @map("pull_request_detail_id") @db.Uuid
  reviewStatus        String?               @map("review_status")
  extractorVersion    Int?                  @map("extractor_version")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  sessionArtifact     Artifact              @relation("SessionPrLinks", fields: [sessionArtifactId], references: [id], onDelete: Cascade)
  pullRequestDetail   PullRequestDetail?    @relation(fields: [pullRequestDetailId], references: [id], onDelete: SetNull)

  @@unique([sessionArtifactId, repositoryFullName, prNumber, relationType])
  @@index([organizationId, sessionArtifactId])
  @@index([organizationId, repositoryFullName, prNumber])
  @@map("session_pull_request_links")
}

model ArtifactEvaluation {
  id             String               @id @default(uuid(7)) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  artifactId     String               @map("artifact_id") @db.Uuid
  loopId         String?              @map("loop_id") @db.Uuid
  reportType     EvaluationReportType @map("report_type")
  reportId       String               @map("report_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  artifact         Artifact          @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  loop             Loop?             @relation(fields: [loopId], references: [id], onDelete: SetNull)
  judgeScores      JudgeScore[]
  judgeHumanScores JudgeHumanScore[]

  @@unique([artifactId, reportId])
  @@index([artifactId, createdAt])
  @@index([organizationId, createdAt])
  @@map("artifact_evaluations")
}

model JudgeScore {
  id            String     @id @default(uuid(7)) @db.Uuid
  evaluationId  String     @map("evaluation_id") @db.Uuid
  promptId      String?    @map("prompt_id") @db.Uuid
  caseId        String     @map("case_id")
  metricName    String     @map("metric_name")
  threshold     Float
  score         Float
  justification String     @map("justification") @db.Text
  finalStatus   EvalStatus @map("final_status")
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  evaluation       ArtifactEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  prompt           Prompt?            @relation(fields: [promptId], references: [id], onDelete: SetNull)
  judgeHumanScores JudgeHumanScore[]

  @@unique([evaluationId, caseId, metricName])
  @@index([promptId])
  @@map("judge_scores")
}

model JudgeHumanScore {
  id             String   @id @default(uuid(7)) @db.Uuid
  // Denormalized from judgeScore.evaluationId for query performance.
  evaluationId   String   @map("evaluation_id") @db.Uuid
  judgeScoreId   String   @map("judge_score_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  score          Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  evaluation   ArtifactEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  judgeScore   JudgeScore         @relation(fields: [judgeScoreId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([judgeScoreId, userId, organizationId])
  @@index([evaluationId])
  @@index([organizationId, userId])
  @@map("judge_human_scores")
}

// Consolidated ratings for any artifact. Absorbs the prior DocumentRating
// and PullRequestRating tables — both now live at @@map("artifact_ratings").
// `artifactVersion` is nullable because PR/deployment ratings aren't
// version-scoped; document ratings keep it populated.
model ArtifactRating {
  id              String   @id @default(uuid(7)) @map("id") @db.Uuid
  artifactId      String   @map("artifact_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  // Score validation (1-5) enforced at API layer via Zod schema.
  score           Int
  comment         String?  @db.VarChar(500)
  artifactVersion Int?     @map("artifact_version")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  artifact     Artifact     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([artifactId, userId, organizationId])
  @@index([artifactId, organizationId])
  @@map("artifact_ratings")
}

model FileAttachment {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String?  @map("artifact_id") @db.Uuid
  bucket      String
  key         String
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  purpose     String   @default("context")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String   @map("created_by_id") @db.Uuid

  // Relations
  artifact Artifact? @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@index([artifactId, purpose])
  @@map("file_attachments")
}

// =============================================================================
// OTHER ENTITIES
// =============================================================================

model SlugCounter {
  id             String @id @default(uuid(7)) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  typePrefix     String @map("type_prefix")
  currentValue   Int    @default(0) @map("current_value")

  @@unique([organizationId, typePrefix])
  @@map("slug_counters")
}

// =============================================================================
// CONVERSATIONS
// =============================================================================

model ChatSession {
  id              String   @id @default(uuid(7)) @db.Uuid
  chatKey         String   @map("chat_key")
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  provider        String
  model           String
  messages        Json     @default("[]")
  sessionId       String?  @map("session_id")
  sessionSourceId String?  @map("session_source_id")
  context         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, chatKey])
  @@index([userId])
  @@index([organizationId, userId])
  @@map("chat_sessions")
}

// =============================================================================
// COMMENT THREADS
// =============================================================================

model CommentThread {
  id               String       @id @default(uuid(7)) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  source           ThreadSource @default(NATIVE)
  externalId       String?      @map("external_id")
  roomId           String?      @map("room_id")
  artifactId       String?      @map("artifact_id") @db.Uuid
  status           ThreadStatus @default(OPEN)
  metadata         Json?
  createdAtVersion Int?         @map("created_at_version")
  resolvedAt       DateTime?    @map("resolved_at")
  resolvedById     String?      @map("resolved_by_id") @db.Uuid
  createdById      String?      @map("created_by_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization     Organization                   @relation(fields: [organizationId], references: [id])
  artifact         Artifact?                      @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  comments         Comment[]
  githubProjection GitHubCommentThreadProjection?

  @@unique([organizationId, externalId])
  @@unique([id, artifactId], map: "comment_threads_id_artifact_id_key")
  @@index([organizationId, artifactId, status])
  @@index([organizationId, roomId])
  @@index([organizationId, status, updatedAt])
  @@index([createdById])
  @@map("comment_threads")
}

// Provider-specific projection for GitHub review and issue-comment thread state.
// Generic artifact comments stay in CommentThread so future sources do not inherit GitHub columns.
model GitHubCommentThreadProjection {
  threadId            String                    @id @map("thread_id") @db.Uuid
  branchArtifactId    String                    @map("branch_artifact_id") @db.Uuid
