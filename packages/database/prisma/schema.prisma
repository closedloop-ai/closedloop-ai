// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// =============================================================================
// ENUMS
// =============================================================================

enum WorkstreamType {
  FEATURE_DELIVERY
  BUG_FIX
  TECH_DEBT
  SPIKE
}

enum WorkstreamState {
  INITIATED
  REQUIREMENTS_GENERATING
  REQUIREMENTS_PENDING_APPROVAL
  DESIGN_IN_PROGRESS
  DESIGN_PENDING_APPROVAL
  IMPLEMENTATION_PLANNING
  IMPLEMENTATION_IN_PROGRESS
  IMPLEMENTATION_PENDING_REVIEW
  CODE_REVIEW_RUNNING
  CODE_REVIEW_PENDING_APPROVAL
  VISUAL_QA_RUNNING
  VISUAL_QA_PENDING_APPROVAL
  MERGING
  DEPLOYED
  COMPLETED
  BLOCKED
  CANCELLED
}

enum ArtifactType {
  PRD
  FIGMA_DESIGN
  IMPLEMENTATION_PLAN
  CODE_REVIEW_REPORT
  VISUAL_QA_REPORT
  ACCESSIBILITY_REPORT
  TEST_REPORT
  COMPLETION_SUMMARY
}

enum ArtifactStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum FileUploadType {
  SCREENSHOT
  ATTACHMENT
  REPORT_IMAGE
}

enum WorkstreamEventType {
  STATE_CHANGED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  REVISION_REQUESTED
  LINEAR_ISSUE_CREATED
  LINEAR_ISSUE_UPDATED
  LINEAR_SUBTASK_CREATED
  GITHUB_PR_CREATED
  GITHUB_PR_MERGED
  GITHUB_ACTION_TRIGGERED
  GITHUB_ACTION_COMPLETED
  SLACK_NOTIFICATION_SENT
  COMMENT_ADDED
  ASSIGNEE_CHANGED
  BLOCKED
  UNBLOCKED
}

enum LinearSyncStatus {
  SYNCED
  PENDING
  ERROR
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum GitHubActionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectPriority {
  NOT_SET
  LOW
  MEDIUM
  HIGH
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model Organization {
  id              String   @id @default(cuid())
  clerkId         String   @unique @map("clerk_id")
  active          Boolean  @default(true) @map("active")
  name            String
  slug            String   @unique
  anthropicApiKey String?  @map("anthropic_api_key")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  projects Project[]
  users    User[]
  teams    Team[]

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  clerkId        String       @unique @map("clerk_id")
  organizationId String       @map("organization_id")
  active         Boolean      @default(true) @map("active")
  email          String
  firstName      String?      @map("first_name")
  lastName       String?      @map("last_name")
  avatarUrl      String?      @map("avatar_url")
  phoneNumber    String?      @map("phone_number")
  role           ApproverRole @default(ENGINEER)
  linearId       String?      @map("linear_id")
  slackId        String?      @map("slack_id")
  githubUsername String?      @map("github_username")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id])
  teamMemberships TeamMember[]
  ownedProjects   Project[]    @relation("ProjectOwner")

  @@unique([organizationId, email])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model Project {
  id              String          @id @default(cuid())
  organizationId  String          @map("organization_id")
  name            String
  description     String?
  priority        ProjectPriority @default(NOT_SET)
  ownerId         String?         @map("owner_id")
  targetDate      DateTime?       @map("target_date")
  codebaseSummary Json?           @map("codebase_summary")
  lastIndexedAt   DateTime?       @map("last_indexed_at")
  settings        Json            @default("{}")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  owner        User?         @relation("ProjectOwner", fields: [ownerId], references: [id])
  workstreams  Workstream[]
  repositories Repository[]
  artifacts    Artifact[]
  teams        ProjectTeam[]

  @@index([organizationId])
  @@index([ownerId])
  @@map("projects")
}

model Repository {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  githubId      Int      @unique @map("github_id")
  owner         String
  name          String
  fullName      String   @map("full_name")
  defaultBranch String   @default("main") @map("default_branch")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@unique([owner, name])
  @@index([projectId])
  @@map("repositories")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  teamId    String   @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id])
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

// =============================================================================
// WORKSTREAM
// =============================================================================

/// Note: Displayed as "Initiative" in the UI
model Workstream {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  title          String
  description    String?
  type           WorkstreamType  @default(FEATURE_DELIVERY)
  state          WorkstreamState @default(INITIATED)
  stateChangedAt DateTime        @default(now()) @map("state_changed_at")
  createdById    String          @map("created_by_id")
  assignedToId   String?         @map("assigned_to_id")
  hasUIChanges   Boolean         @default(false) @map("has_ui_changes")
  startedAt      DateTime        @default(now()) @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metrics        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  project   Project    @relation(fields: [projectId], references: [id])
  artifacts Artifact[]

  @@index([projectId, state])
  @@index([state])
  @@index([createdById])
  @@index([assignedToId])
  @@map("workstreams")
}

model WorkstreamEvent {
  id           String              @id @default(cuid())
  workstreamId String              @map("workstream_id")
  type         WorkstreamEventType
  fromState    WorkstreamState?    @map("from_state")
  toState      WorkstreamState?    @map("to_state")
  actorId      String?             @map("actor_id")
  actorType    String              @default("system") @map("actor_type")
  data         Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([workstreamId, type])
  @@index([workstreamId, createdAt])
  @@index([type])
  @@map("workstream_events")
}

// =============================================================================
// ARTIFACTS
// =============================================================================

model Artifact {
  id           String         @id @default(cuid())
  workstreamId String?        @map("workstream_id")
  projectId    String?        @map("project_id")
  type         ArtifactType
  title        String
  fileName     String?        @map("file_name")
  approver     String?
  status       ArtifactStatus @default(DRAFT)
  content      String?        @db.Text
  externalUrl  String?        @map("external_url")
  version      Int            @default(1)
  isLatest     Boolean        @default(true) @map("is_latest")
  parentId     String?        @map("parent_id")
  documentSlug String?        @map("document_slug")
  generatedBy  String?        @map("generated_by")
  sourcePrdId  String?        @map("source_prd_id")
  tokenUsage   Json?          @map("token_usage")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Relations
  workstream Workstream? @relation(fields: [workstreamId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])

  @@unique([workstreamId, projectId, type, documentSlug, version])
  @@index([projectId])
  @@index([workstreamId, type, isLatest])
  @@index([workstreamId, type, documentSlug])
  @@index([sourcePrdId])
  @@map("artifacts")
}

model FileUpload {
  id         String         @id @default(cuid())
  artifactId String?        @map("artifact_id")
  type       FileUploadType
  bucket     String
  key        String
  filename   String
  mimeType   String         @map("mime_type")
  sizeBytes  Int            @map("size_bytes")
  viewport   Json?
  pageUrl    String?        @map("page_url")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([artifactId])
  @@index([bucket, key])
  @@map("file_uploads")
}

// =============================================================================
// APPROVALS
// =============================================================================

model Approval {
  id           String         @id @default(cuid())
  projectId    String         @map("project_id")
  workstreamId String         @map("workstream_id")
  artifactId   String         @map("artifact_id")
  requiredRole ApproverRole   @map("required_role")
  approverId   String?        @map("approver_id")
  status       ApprovalStatus @default(PENDING)
  feedback     String?        @db.Text
  requestedAt  DateTime       @default(now()) @map("requested_at")
  decidedAt    DateTime?      @map("decided_at")

  @@index([projectId])
  @@index([workstreamId, status])
  @@index([artifactId])
  @@index([approverId, status])
  @@map("approvals")
}

// =============================================================================
// CONVERSATIONS
// =============================================================================

model Conversation {
  id           String   @id @default(cuid())
  workstreamId String   @map("workstream_id")
  agentType    String   @map("agent_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, agentType])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String   @db.Text
  tokenUsage     Json?    @map("token_usage")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Comment {
  id           String   @id @default(cuid())
  workstreamId String   @map("workstream_id")
  authorId     String   @map("author_id")
  content      String   @db.Text
  artifactId   String?  @map("artifact_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, createdAt])
  @@index([authorId])
  @@index([artifactId])
  @@map("comments")
}

// =============================================================================
// LINEAR INTEGRATION
// =============================================================================

model LinearIntegration {
  id             String    @id @default(cuid())
  organizationId String    @unique @map("organization_id")
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  linearOrgId    String    @map("linear_org_id")
  linearOrgName  String    @map("linear_org_name")
  defaultTeamId  String?   @map("default_team_id")
  webhookId      String?   @map("webhook_id")
  webhookSecret  String?   @map("webhook_secret")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("linear_integrations")
}

model LinearIssue {
  id           String           @id @default(cuid())
  workstreamId String           @unique @map("workstream_id")
  linearId     String           @unique @map("linear_id")
  linearKey    String           @map("linear_key")
  linearUrl    String           @map("linear_url")
  teamId       String           @map("team_id")
  teamKey      String           @map("team_key")
  syncStatus   LinearSyncStatus @default(SYNCED) @map("sync_status")
  lastSyncedAt DateTime         @default(now()) @map("last_synced_at")
  syncError    String?          @map("sync_error")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([linearKey])
  @@index([syncStatus])
  @@map("linear_issues")
}

model LinearSubtask {
  id           String   @id @default(cuid())
  workstreamId String   @map("workstream_id")
  linearId     String   @unique @map("linear_id")
  linearKey    String   @map("linear_key")
  linearUrl    String   @map("linear_url")
  title        String
  description  String?
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId])
  @@index([workstreamId, isCompleted])
  @@map("linear_subtasks")
}

// =============================================================================
// GITHUB INTEGRATION
// =============================================================================

model GitHubInstallation {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  installationId Int      @unique @map("installation_id")
  accountLogin   String   @map("account_login")
  accountType    String   @map("account_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("github_installations")
}

model GitHubPullRequest {
  id             String        @id @default(cuid())
  workstreamId   String        @map("workstream_id")
  repositoryId   String        @map("repository_id")
  githubId       Int           @map("github_id")
  number         Int
  title          String
  body           String?       @db.Text
  htmlUrl        String        @map("html_url")
  headBranch     String        @map("head_branch")
  baseBranch     String        @map("base_branch")
  headSha        String?       @map("head_sha")
  state          GitHubPRState @default(OPEN)
  mergedAt       DateTime?     @map("merged_at")
  mergeCommitSha String?       @map("merge_commit_sha")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([repositoryId, number])
  @@index([workstreamId, state])
  @@index([repositoryId])
  @@map("github_pull_requests")
}

model GitHubActionRun {
  id           String             @id @default(cuid())
  workstreamId String             @map("workstream_id")
  repositoryId String             @map("repository_id")
  runId        BigInt             @map("run_id")
  workflowName String             @map("workflow_name")
  status       GitHubActionStatus @default(PENDING)
  conclusion   String?
  htmlUrl      String             @map("html_url")
  triggerEvent String             @map("trigger_event")
  triggerData  Json?              @map("trigger_data")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([repositoryId, runId])
  @@index([workstreamId, status])
  @@index([workstreamId, workflowName])
  @@map("github_action_runs")
}

// =============================================================================
// SLACK INTEGRATION
// =============================================================================

model SlackIntegration {
  id                 String   @id @default(cuid())
  organizationId     String   @unique @map("organization_id")
  accessToken        String   @map("access_token")
  botUserId          String   @map("bot_user_id")
  teamId             String   @map("team_id")
  teamName           String   @map("team_name")
  defaultChannelId   String?  @map("default_channel_id")
  defaultChannelName String?  @map("default_channel_name")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("slack_integrations")
}
