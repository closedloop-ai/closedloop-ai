/// One-time OAuth authorization code for the desktop authorization-code + PKCE
/// loopback flow (FEA-2409 / PLN-843 Amendment 1). Minted by the Clerk-authed
/// authorize endpoint, bound to the resolved user/org, the desktop device
/// public key (PoP), the PKCE S256 challenge, and the exact loopback redirect
/// URI. Redeemed exactly once (`redeemedAt`) at the token endpoint, within a
/// short `expiresAt` window, in exchange for a first-party desktop session.
/// userId/organizationId are stored as plain columns (no FK relation), matching
/// DesktopOnboardingAttempt — the row is ephemeral and single-use.
model DesktopAuthorizationCode {
  id             String    @id @default(uuid(7)) @db.Uuid
  codeHash       String    @unique @map("code_hash")
  userId         String    @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  gatewayId      String    @map("gateway_id")
  boundPublicKey String    @map("bound_public_key")
  codeChallenge  String    @map("code_challenge")
  redirectUri    String    @map("redirect_uri")
  expiresAt      DateTime  @map("expires_at")
  redeemedAt     DateTime? @map("redeemed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("desktop_authorization_codes")
}

