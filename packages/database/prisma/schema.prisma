// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// =============================================================================
// ENUMS
// =============================================================================

enum WorkstreamType {
  FEATURE_DELIVERY
  BUG_FIX
  TECH_DEBT
  SPIKE
}

enum WorkstreamState {
  INITIATED
  REQUIREMENTS_GENERATING
  REQUIREMENTS_PENDING_APPROVAL
  DESIGN_IN_PROGRESS
  DESIGN_PENDING_APPROVAL
  IMPLEMENTATION_PLANNING
  IMPLEMENTATION_IN_PROGRESS
  IMPLEMENTATION_PENDING_REVIEW
  CODE_REVIEW_RUNNING
  CODE_REVIEW_PENDING_APPROVAL
  VISUAL_QA_RUNNING
  VISUAL_QA_PENDING_APPROVAL
  MERGING
  DEPLOYED
  COMPLETED
  BLOCKED
  CANCELLED
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExternalLinkType {
  PULL_REQUEST
  FIGMA_DESIGN
  PREVIEW_DEPLOYMENT
}

// Entity types for polymorphic EntityLink
enum EntityType {
  ARTIFACT
  ISSUE
  EXTERNAL_LINK
}

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Issue blocks Issue)
  RELATES_TO // bidirectional association (Issue ↔ Issue)
}

enum ArtifactStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum ArtifactType {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum WorkstreamEventType {
  STATE_CHANGED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  REVISION_REQUESTED
  LINEAR_ISSUE_CREATED
  LINEAR_ISSUE_UPDATED
  LINEAR_SUBTASK_CREATED
  GITHUB_PR_CREATED
  GITHUB_PR_MERGED
  GITHUB_PR_CLOSED
  GITHUB_PR_REVIEW_SUBMITTED
  GITHUB_PR_COMMENT_ADDED
  GITHUB_ACTION_TRIGGERED
  GITHUB_ACTION_COMPLETED
  SLACK_NOTIFICATION_SENT
  COMMENT_ADDED
  ASSIGNEE_CHANGED
  BLOCKED
  UNBLOCKED
}

enum LinearSyncStatus {
  SYNCED
  PENDING
  ERROR
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum GitHubActionStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum PRReviewCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectPriority {
  NOT_SET
  LOW
  MEDIUM
  HIGH
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model Organization {
  id              String   @id @default(uuid(7)) @db.Uuid
  clerkId         String   @unique @map("clerk_id")
  active          Boolean  @default(true) @map("active")
  name            String
  slug            String   @unique
  anthropicApiKey String?  @map("anthropic_api_key")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  teams              Team[]
  pullRequestRatings PullRequestRating[]
  pullRequests       GitHubPullRequest[]
  projects           Project[]
  workstreams        Workstream[]
  artifacts          Artifact[]
  issues             Issue[]
  externalLinks      ExternalLink[]
  githubInstallation GitHubInstallation?

  @@map("organizations")
}

model User {
  id             String       @id @default(uuid(7)) @db.Uuid
  clerkId        String       @map("clerk_id")
  organizationId String       @map("organization_id") @db.Uuid
  active         Boolean      @default(true) @map("active")
  email          String
  firstName      String?      @map("first_name")
  lastName       String?      @map("last_name")
  avatarUrl      String?      @map("avatar_url")
  phoneNumber    String?      @map("phone_number")
  role           ApproverRole @default(ENGINEER)
  linearId       String?      @map("linear_id")
  slackId        String?      @map("slack_id")
  githubUsername String?      @map("github_username")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  organization       Organization     @relation(fields: [organizationId], references: [id])
  teamMemberships    TeamMember[]
  pullRequestRatings PullRequestRating[]
  ownedProjects      Project[]    @relation("ProjectOwner")
  ownedArtifacts     Artifact[]   @relation("ArtifactOwner")
  approvedArtifacts  Artifact[]   @relation("ArtifactApprover")
  assignedIssues     Issue[]      @relation("IssueAssignee")
  createdIssues      Issue[]      @relation("IssueCreator")
  createdWorkstreams Workstream[] @relation("WorkstreamCreatedBy")

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model Project {
  id              String          @id @default(uuid(7)) @db.Uuid
  organizationId  String          @map("organization_id") @db.Uuid
  name            String
  description     String?
  priority        ProjectPriority @default(NOT_SET)
  ownerId         String?         @map("owner_id") @db.Uuid
  targetDate      DateTime?       @map("target_date")
  codebaseSummary String?         @map("codebase_summary")
  lastIndexedAt   DateTime?       @map("last_indexed_at")
  settings        Json            @default("{}")
  sortOrder       Int?            @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id])
  owner         User?          @relation("ProjectOwner", fields: [ownerId], references: [id])
  workstreams   Workstream[]
  repositories  Repository[]
  artifacts     Artifact[]
  issues        Issue[]
  externalLinks ExternalLink[]
  teams         ProjectTeam[]

  @@index([organizationId])
  @@index([ownerId])
  @@map("projects")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

// =============================================================================
// WORKSTREAM
// =============================================================================

model Workstream {
  id             String          @id @default(uuid(7)) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  title          String
  description    String?
  type           WorkstreamType  @default(FEATURE_DELIVERY)
  state          WorkstreamState @default(INITIATED)
  stateChangedAt DateTime        @default(now()) @map("state_changed_at")
  createdById    String          @map("created_by_id") @db.Uuid
  assignedToId   String?         @map("assigned_to_id") @db.Uuid
  hasUIChanges   Boolean         @default(false) @map("has_ui_changes")
  startedAt      DateTime        @default(now()) @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metrics        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("WorkstreamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  artifacts     Artifact[]
  issues        Issue[]
  externalLinks ExternalLink[]
  pullRequests  GitHubPullRequest[]

  @@index([organizationId])
  @@index([organizationId, projectId, state])
  @@index([organizationId, assignedToId])
  @@index([projectId])
  @@index([createdById])
  @@map("workstreams")
}

model WorkstreamEvent {
  id           String              @id @default(uuid(7)) @db.Uuid
  workstreamId String              @map("workstream_id") @db.Uuid
  type         WorkstreamEventType
  fromState    WorkstreamState?    @map("from_state")
  toState      WorkstreamState?    @map("to_state")
  actorId      String?             @map("actor_id") @db.Uuid
  actorType    String              @default("system") @map("actor_type")
  data         Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([workstreamId, type])
  @@index([workstreamId, createdAt])
  @@index([type])
  @@map("workstream_events")
}

// =============================================================================
// ARTIFACTS
// =============================================================================

model Artifact {
  id              String         @id @default(uuid(7)) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  workstreamId    String?        @map("workstream_id") @db.Uuid
  projectId       String?        @map("project_id") @db.Uuid
  type            ArtifactType   @map("type")
  title           String
  slug            String
  fileName        String?        @map("file_name")
  ownerId         String?        @map("owner_id") @db.Uuid
  approverId      String?        @map("approver_id") @db.Uuid
  status          ArtifactStatus @default(DRAFT)
  latestVersion   Int            @default(1) @map("latest_version")
  generatedBy     String?        @map("generated_by") @db.Uuid
  tokenUsage      Json?          @map("token_usage")
  targetRepo      String?        @map("target_repo")
  targetBranch    String?        @map("target_branch")
  templateForType ArtifactType?  @map("template_for_type")
  sortOrder       Int?           @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  organization Organization         @relation(fields: [organizationId], references: [id])
  workstream   Workstream?          @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner        User?                @relation("ArtifactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  approver     User?                @relation("ArtifactApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions     ArtifactVersion[]
  ratings      ArtifactRating[]
  evaluations  ArtifactEvaluation[]
  pullRequests GitHubPullRequest[]

  @@unique([organizationId, slug])
  @@unique([organizationId, templateForType])
  @@index([organizationId, workstreamId, type])
  @@index([organizationId, projectId, type])
  @@index([organizationId, type, templateForType])
  @@index([workstreamId])
  @@index([projectId])
  @@index([ownerId])
  @@index([approverId])
  @@map("artifacts")
}

model ArtifactVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, version])
  @@map("artifact_versions")
}

model ArtifactEvaluation {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  actionRunId String?  @map("action_run_id") @db.Uuid
  reportId    String   @map("report_id")
  reportData  Json     @map("report_data")
  createdAt   DateTime @default(now()) @map("created_at")

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, reportId])
  @@map("artifact_evaluations")
}

model ArtifactRating {
  id              String   @id @default(uuid(7)) @map("id") @db.Uuid
  artifactId      String   @map("artifact_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  // Score validation (1-5) enforced at API layer via Zod schema. Prisma relationMode = "prisma" doesn't support DB check constraints.
  score           Int
  comment         String?  @db.VarChar(500)
  artifactVersion Int      @map("artifact_version")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, userId, organizationId])
  @@index([artifactId, organizationId])
  @@map("artifact_ratings")
}

model PullRequestRating {
  id             String   @id @default(uuid(7)) @db.Uuid
  pullRequestId  String   @map("pull_request_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid // Enforced by check_pull_request_rating_organization_id trigger - must match github_pull_requests.organization_id
  // Score validation (1-5) enforced at API layer via Zod schema
  score          Int
  comment        String   @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  pullRequest  GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, userId, organizationId])
  @@index([pullRequestId, organizationId])
  @@map("pull_request_ratings")
}

// =============================================================================
// OTHER ENTITIES
// =============================================================================

model Issue {
  id             String        @id @default(uuid(7)) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  workstreamId   String?       @map("workstream_id") @db.Uuid
  projectId      String?       @map("project_id") @db.Uuid
  title          String
  slug           String
  description    String?       @db.Text
  status         IssueStatus   @default(TODO)
  priority       IssuePriority @default(MEDIUM)
  assigneeId     String?       @map("assignee_id") @db.Uuid
  createdById    String        @map("created_by_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  workstream   Workstream?  @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("IssueCreator", fields: [createdById], references: [id])

  @@unique([organizationId, slug])
  @@index([organizationId, workstreamId, status])
  @@index([organizationId, projectId, status])
  @@index([organizationId, assigneeId, status])
  @@index([workstreamId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@map("issues")
}

model ExternalLink {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  workstreamId   String?          @map("workstream_id") @db.Uuid
  projectId      String?          @map("project_id") @db.Uuid
  type           ExternalLinkType
  title          String
  externalUrl    String           @map("external_url")
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  workstream   Workstream?  @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, workstreamId, type])
  @@index([organizationId, projectId, type])
  @@index([workstreamId])
  @@index([projectId])
  @@map("external_links")
}

model EntityLink {
  id            String     @id @default(uuid(7)) @db.Uuid
  sourceId      String     @map("source_id") @db.Uuid
  sourceType    EntityType @map("source_type")
  sourceVersion Int?       @map("source_version")
  targetId      String     @map("target_id") @db.Uuid
  targetType    EntityType @map("target_type")
  targetVersion Int?       @map("target_version")
  linkType      LinkType   @map("link_type")
  metadata      Json?
  createdAt     DateTime   @default(now()) @map("created_at")

  @@index([sourceId, sourceType, linkType])
  @@index([targetId, targetType, linkType])
  @@map("entity_links")
}

// =============================================================================
// CONVERSATIONS
// =============================================================================

model Conversation {
  id           String   @id @default(uuid(7)) @db.Uuid
  workstreamId String   @map("workstream_id") @db.Uuid
  agentType    String   @map("agent_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, agentType])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid(7)) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String   @db.Text
  tokenUsage     Json?    @map("token_usage")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Comment {
  id           String   @id @default(uuid(7)) @db.Uuid
  workstreamId String   @map("workstream_id") @db.Uuid
  authorId     String   @map("author_id") @db.Uuid
  content      String   @db.Text
  artifactId   String?  @map("artifact_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId, createdAt])
  @@index([authorId])
  @@index([artifactId])
  @@map("comments")
}

// =============================================================================
// LINEAR INTEGRATION
// =============================================================================

model LinearIntegration {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @unique @map("organization_id") @db.Uuid
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  linearOrgId    String    @map("linear_org_id")
  linearOrgName  String    @map("linear_org_name")
  defaultTeamId  String?   @map("default_team_id")
  webhookId      String?   @map("webhook_id")
  webhookSecret  String?   @map("webhook_secret")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("linear_integrations")
}

model LinearIssue {
  id           String           @id @default(uuid(7)) @db.Uuid
  workstreamId String           @unique @map("workstream_id") @db.Uuid
  linearId     String           @unique @map("linear_id")
  linearKey    String           @map("linear_key")
  linearUrl    String           @map("linear_url")
  teamId       String           @map("team_id")
  teamKey      String           @map("team_key")
  syncStatus   LinearSyncStatus @default(SYNCED) @map("sync_status")
  lastSyncedAt DateTime         @default(now()) @map("last_synced_at")
  syncError    String?          @map("sync_error")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([linearKey])
  @@index([syncStatus])
  @@map("linear_issues")
}

model LinearSubtask {
  id           String   @id @default(uuid(7)) @db.Uuid
  workstreamId String   @map("workstream_id") @db.Uuid
  linearId     String   @unique @map("linear_id")
  linearKey    String   @map("linear_key")
  linearUrl    String   @map("linear_url")
  title        String
  description  String?
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([workstreamId])
  @@index([workstreamId, isCompleted])
  @@map("linear_subtasks")
}

// =============================================================================
// GITHUB INTEGRATION
// =============================================================================

model Repository {
  id            String   @id @default(uuid(7)) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  githubId      Int      @unique @map("github_id")
  owner         String
  name          String
  fullName      String   @map("full_name")
  defaultBranch String   @default("main") @map("default_branch")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([owner, name])
  @@index([projectId])
  @@map("repositories")
}

model GitHubInstallation {
  id                  String                   @id @default(uuid(7)) @db.Uuid
  organizationId      String?                  @unique @map("organization_id") @db.Uuid
  installationId      Int                      @unique @map("installation_id")
  accountId           Int                      @map("account_id")
  accountLogin        String                   @map("account_login")
  accountType         String                   @map("account_type")
  senderLogin         String                   @map("sender_login")
  senderId            Int                      @map("sender_id")
  status              GitHubInstallationStatus @default(PENDING_CLAIM)
  permissions         Json?
  events              Json?
  repositorySelection String?                  @map("repository_selection")
  suspendedAt         DateTime?                @map("suspended_at")
  suspendedBy         String?                  @map("suspended_by")
  claimedAt           DateTime?                @map("claimed_at")
  claimedByUserId     String?                  @map("claimed_by_user_id") @db.Uuid
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  // Relations
  organization Organization?                  @relation(fields: [organizationId], references: [id])
  repositories GitHubInstallationRepository[]

  @@index([organizationId])
  @@index([status])
  @@index([accountId])
  @@map("github_installations")
}

model GitHubInstallationRepository {
  id             String    @id @default(uuid(7)) @db.Uuid
  installationId String    @map("installation_id") @db.Uuid
  githubRepoId   Int       @map("github_repo_id")
  fullName       String    @map("full_name")
  name           String
  owner          String
  private        Boolean
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastPushedAt   DateTime? @map("last_pushed_at")

  // Relations
  installation GitHubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, githubRepoId])
  @@map("github_installation_repositories")
}

model GitHubPullRequest {
  id             String        @id @default(uuid(7)) @db.Uuid
  workstreamId   String        @map("workstream_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid // Denormalized from workstream for defense-in-depth (org-scoped queries)
  repositoryId   String        @map("repository_id") @db.Uuid
  artifactId     String?       @map("artifact_id") @db.Uuid
  githubId       Int           @map("github_id")
  number         Int
  title          String
  body           String?         @db.Text
  htmlUrl        String          @map("html_url")
  headBranch     String          @map("head_branch")
  baseBranch     String          @map("base_branch")
  headSha        String?         @map("head_sha")
  state          GitHubPRState   @default(OPEN)
  isDraft        Boolean         @default(false) @map("is_draft")
  reviewDecision ReviewDecision? @map("review_decision")
  closedAt       DateTime?       @map("closed_at")
  mergedAt       DateTime?       @map("merged_at")
  mergeCommitSha String?         @map("merge_commit_sha")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  workstream     Workstream              @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  artifact       Artifact?               @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  ratings        PullRequestRating[]
  reviewComments GitHubPRReviewComment[]
  reviews        GitHubPRReview[]

  @@unique([repositoryId, number])
  @@index([workstreamId, state])
  @@index([organizationId])
  @@index([artifactId])
  @@map("github_pull_requests")
}

model GitHubPRReviewComment {
  id              String               @id @default(uuid(7)) @db.Uuid
  pullRequestId   String               @map("pull_request_id") @db.Uuid
  githubCommentId BigInt               @unique @map("github_comment_id")
  reviewId        BigInt?              @map("review_id")
  body            String               @db.Text
  path            String?
  line            Int?
  authorLogin     String               @map("author_login")
  authorAvatarUrl String?              @map("author_avatar_url")
  state           PRReviewCommentState @default(PENDING)
  htmlUrl         String               @map("html_url")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  pullRequest GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId, state])
  @@map("github_pr_review_comments")
}

model GitHubPRReview {
  id              String         @id @default(uuid(7)) @db.Uuid
  pullRequestId   String         @map("pull_request_id") @db.Uuid
  githubReviewId  BigInt         @unique @map("github_review_id")
  authorLogin     String         @map("author_login")
  authorAvatarUrl String?        @map("author_avatar_url")
  state           ReviewDecision
  body            String?        @db.Text
  htmlUrl         String         @map("html_url")
  submittedAt     DateTime       @map("submitted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  pullRequest GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, authorLogin])
  @@map("github_pr_reviews")
}

model GitHubActionRun {
  id           String             @id @default(uuid(7)) @db.Uuid
  workstreamId String             @map("workstream_id") @db.Uuid
  repositoryId String             @map("repository_id") @db.Uuid
  runId        BigInt?            @map("run_id")
  workflowName String             @map("workflow_name")
  status       GitHubActionStatus @default(PENDING)
  conclusion   String?
  htmlUrl      String             @map("html_url")
  triggerEvent String             @map("trigger_event")
  triggerData  Json?              @map("trigger_data")
  sessionId    String?            @map("session_id")
  jobType      String?            @map("job_type")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([repositoryId, runId])
  @@index([workstreamId, status])
  @@index([workstreamId, workflowName])
  @@map("github_action_runs")
}

