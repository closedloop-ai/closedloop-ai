// =============================================================================
// LOOPS (Runtime v2 - Container-based compute)
// =============================================================================

model Loop {
  id             String      @id @default(uuid(7)) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  status         LoopStatus  @default(PENDING)
  command        LoopCommand

  // Optional relationships
  artifactId   String? @map("artifact_id") @db.Uuid
  workstreamId String? @map("workstream_id") @db.Uuid
  parentLoopId String? @map("parent_loop_id") @db.Uuid

  // Execution context
  prompt          String? @db.Text
  repo            Json? // { fullName: string, branch: string }
  additionalRepos Json?   @map("additional_repos") // Array<{ fullName: string, branch: string }>
  contextRefs     Json?   @map("context_refs") // Array<{ sourceId, sourceType, include }>

  // Compute target (local machine) — null for cloud/legacy runs
  computeTargetId String? @map("compute_target_id") @db.Uuid

  // Container tracking
  containerId String? @map("container_id") // ECS task ARN
  s3StateKey  String? @map("s3_state_key") // S3 prefix for state

  // PR and session tracking (populated by harness agent on completion)
  prUrl      String? @map("pr_url")
  prNumber   Int?    @map("pr_number")
  branchName String? @map("branch_name")
  sessionId  String? @map("session_id")

  // Cost tracking
  tokensInput   Int      @default(0) @map("tokens_input")
  tokensOutput  Int      @default(0) @map("tokens_output")
  tokensByModel Json?    @map("tokens_by_model") // { "claude-opus-4": { input, output }, ... }
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(10, 6)

  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Error info
  error Json? // { code: string, message: string }

  // Artifact version at loop creation time — used to detect stale evaluations
  // when a new document version is published while an evaluation is in flight.
  artifactVersion Int? @map("artifact_version")

  // Extensible metadata
  metadata          Json  @default("{}") @map("metadata")
  uploadedArtifacts Json? @map("uploaded_artifacts")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization                    Organization                         @relation(fields: [organizationId], references: [id])
  user                            User                                 @relation(fields: [userId], references: [id])
  artifact                        Artifact?                            @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  workstream                      Workstream?                          @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  computeTarget                   ComputeTarget?                       @relation(fields: [computeTargetId], references: [id])
  parentLoop                      Loop?                                @relation("LoopParent", fields: [parentLoopId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  childLoops                      Loop[]                               @relation("LoopParent")
  evaluations                     ArtifactEvaluation[]
  events                          LoopEvent[]
  executionCredentialConsumptions LoopExecutionCredentialConsumption[]

  // NOTE: A partial unique index on (artifact_id, command, artifact_version)
  // WHERE status IN ('PENDING', 'CLAIMED', 'RUNNING') is maintained via raw migrations.
  // Prisma cannot express partial indexes. Prisma 7.4+ falsely flags this as drift —
  // we pin to 7.3.0 until resolved. Do NOT drop it.
  // Only applies when both artifactId and artifactVersion are non-null (Postgres
  // treats NULL != NULL in unique indexes, so nullable rows never conflict).
  // Terminal loops (COMPLETED/FAILED/CANCELLED/TIMED_OUT) allow re-runs of the same
  // artifact+command+version without conflict.
  @@index([artifactId, command, artifactVersion])
  @@index([organizationId, status])
  @@index([organizationId, userId, createdAt])
  @@index([workstreamId])
  @@index([parentLoopId])
  @@index([computeTargetId])
  @@map("loops")
}

model LoopEvent {
  id             String   @id @default(uuid(7)) @db.Uuid
  loopId         String   @map("loop_id") @db.Uuid
  type           String // "started" | "output" | "progress" | "tool_call" | "artifact_created" | "completed" | "error"
  data           Json     @default("{}")
  eventSource    String   @default("system") @map("event_source")
  eventId        String   @map("event_id")
  runnerTokenJti String?  @map("runner_token_jti")
  runnerNonce    String?  @map("runner_nonce") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  loop Loop @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@unique([loopId, eventSource, eventId])
  @@index([loopId, createdAt])
  @@index([loopId, type])
  @@map("loop_events")
}

