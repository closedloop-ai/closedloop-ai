// =============================================================================
// AGENT COMPONENT INVENTORY + USAGE (FEA-2923 / T-6.1, T-6.2)
// Two independent representations — never conflate. See reconciled-decisions.md.
// =============================================================================

/// Inventory / Existence registry — one deduped row per distinct component
/// per compute target. Org-visible via org ↔ computeTarget join; org-scoped
/// reads filter through computeTarget.organizationId. Populated by event-driven
/// discovery (upsert-on-observe), synced desktop→api.
model AgentComponent {
  id                  String    @id @default(uuid(7)) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  computeTargetId     String    @map("compute_target_id") @db.Uuid
  componentKind       String    @map("component_kind")
  externalComponentId String    @map("external_component_id")
  harness             String?
  name                String?
  componentKey        String?   @map("component_key")
  version             String?
  description         String?
  sourceUrl           String?   @map("source_url")
  installPath         String?   @map("install_path")
  packId              String?   @map("pack_id")
  scope               String?
  projectPath         String?   @map("project_path")
  metadata            Json?
  firstSeenAt         DateTime? @map("first_seen_at")
  lastSeenAt          DateTime? @map("last_seen_at")
  uninstalledAt       DateTime? @map("uninstalled_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  computeTarget ComputeTarget @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  sessionUsages AgentComponentSessionUsage[]

  // Primary dedup key: one row per (device, kind, external component id).
  @@unique([computeTargetId, componentKind, externalComponentId])
  @@index([organizationId, componentKind])
  @@index([organizationId])
  @@map("agent_components")
}

/// Usage / Invocation stats — per session × component key. No organizationId:
/// org isolation is enforced through SessionDetail → Artifact.organizationId
/// (D4 decision, same precedent as AgentSessionTokenEvent). Independent from
/// AgentComponent existence: either can exist without the other.
model AgentComponentSessionUsage {
  id               String    @id @default(uuid(7)) @db.Uuid
  agentSessionId   String    @map("agent_session_id") @db.Uuid
  componentKind    String    @map("component_kind")
  componentKey     String    @map("component_key")
  // FEA-2990: the git branch this usage bucket ran on, from per-event
  // `events.git_branch` on the desktop. Empty string '' is the "no per-event
  // branch" sentinel (Codex, legacy pre-column events, non-tool kinds); those
  // rows fall back to session-level SessionBranch attribution. Part of the
  // natural key so a session that switched branches mid-run persists one row
  // per (component, branch). Defaulted to '' so older desktop builds that omit
  // the field upsert into the single session-level bucket exactly as before.
  gitBranch        String    @default("") @map("git_branch")
  // Nullable: usage can be recorded before the inventory row exists (e.g. built-in
  // tools), or inventory sync may not have run yet.
  agentComponentId String?   @map("agent_component_id") @db.Uuid
  harness          String?
  invocationCount  Int       @default(0) @map("invocation_count")
  errorCount       Int       @default(0) @map("error_count")
  firstInvokedAt   DateTime? @map("first_invoked_at")
  lastInvokedAt    DateTime? @map("last_invoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  session         SessionDetail   @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)
  agentComponent  AgentComponent? @relation(fields: [agentComponentId], references: [id], onDelete: SetNull)

  @@unique([agentSessionId, componentKind, componentKey, gitBranch], map: "idx_acsu_session_kind_key_branch")
  @@index([agentComponentId])
  @@index([agentSessionId, componentKind])
  // FEA-3160: the Agents-workspace time window filters usage on
  // `last_invoked_at >= startDate`. The nested `sessionUsages` read scopes by
  // last_invoked_at alone, so a plain index serves that range predicate…
  @@index([lastInvokedAt])
  // …while the org-scoped child-usage rollup and orphan-usage reads filter
  // `component_kind IN (...)` together with the same range, so a composite
  // (component_kind, last_invoked_at) serves those without a full scan.
  @@index([componentKind, lastInvokedAt])
  @@map("agent_component_session_usage")
}

// =============================================================================
// CATALOG + DISTRIBUTION PLATFORM (FEA-2923 / T-14.1–T-14.4, T-21.1)
// Admin-authored / curated distributable definitions and distribution tracking.
// =============================================================================

/// A distributable definition of any component kind (plugin, skill, command,
/// agent, hook, mcp). Source: org_custom (admin-uploaded, org-private),
/// curated (ClosedLoop best-practice, global, read-only), or marketplace
/// (future; leave hooks). organizationId is null for global/curated items.
///
/// Legacy Agent supersede (T-21.1): legacyAgentId traces migration provenance.
/// sourceRepo + role are preserved for Agent bootstrap idempotency (the
/// @@unique([organizationId, sourceRepo, role]) below mirrors Agent's constraint
/// for targetKind='agent' rows). In Prisma this is a full unique index; the
/// partial-index (WHERE target_kind = 'agent') variant is applied via a hand-
/// crafted migration on top so the full-unique index is dropped in favor of
/// the filtered one. See migration: add_agent_component_and_catalog_distribution.
model CatalogItem {
  id             String    @id @default(uuid(7)) @db.Uuid
  // Nullable for global/curated scope items (organizationId IS NULL).
  organizationId String?   @map("organization_id") @db.Uuid
  targetKind     String    @map("target_kind") // plugin|skill|command|agent|hook|mcp
  source         String    // org_custom|curated|marketplace
  scope          String    // org|global
  name           String
  description    String?
  version        String    @default("1.0.0")
  sortOrder      Int       @default(0) @map("sort_order")
  // S3 asset keys (written after upload confirmation in T-15.3)
  zipAssetBucket  String?  @map("zip_asset_bucket")
  zipAssetKey     String?  @map("zip_asset_key")
  logoAssetBucket String?  @map("logo_asset_bucket")
  logoAssetKey    String?  @map("logo_asset_key")
  filesAssetKey   String?  @map("files_asset_key")
  enabled        Boolean   @default(true)
  archived       Boolean   @default(false)
  // Coaching Packs sub-slice (T-22.1): coaching items carry signals[] payload
  // and are excluded from the generic plugin ranking/leaderboard.
  coaching       Boolean   @default(false)
  coachingConfig Json?     @map("coaching_config")
  // Legacy Agent supersede (T-21.1) — migration traceability
  legacyAgentId  String?   @map("legacy_agent_id") @db.Uuid
  // FEA-3050 promote idempotency: the discovered AgentComponent this item was
  // promoted from (best-of-breed promote, FEA-2923 §J). Bare traceability
  // column (mirrors legacyAgentId/sourceLoopId — no relation). A hand-written
  // partial unique index (organization_id, source_agent_component_id) WHERE
  // source_agent_component_id IS NOT NULL guards against double-promote creating
  // duplicate org-wide AutoInstall distributions; the pre-existing catalog_items
  // partial unique indexes only cover target_kind='agent' rows. Prisma cannot
  // express partial indexes, so the index lives in the migration, not here.
  sourceAgentComponentId String? @map("source_agent_component_id") @db.Uuid
  // Preserved for Agent bootstrap idempotency (T-21.1); mirrors Agent.sourceRepo/role
  sourceRepo     String?   @map("source_repo")
  role           String?
  // Stable, org-scoped-unique context-pack slug for targetKind='agent' items,
  // disambiguated with -2/-3 suffixes at ingest (mirrors the superseded
  // Agent.slug). Persisted so same-role agents from different sourceRepos keep
  // distinct harness file names (`.claude/agents/{slug}.md`) instead of
  // colliding on a role-derived slug recomputed on read (FEA-2923).
  agentSlug      String?   @map("agent_slug")
  sourceLoopId   String?   @map("source_loop_id")
  // Pack authoring (component container): a Pack is a top-level CatalogItem
  // (parentPackId IS NULL) that holds N child component CatalogItems
  // (skill/command/agent/hook/plugin/mcp). Cascade so archiving/deleting a Pack
  // removes its authored components. Null for standalone items + legacy rows.
  parentPackId   String?   @map("parent_pack_id") @db.Uuid
  // Content-addressed component identity: uuidv5(source + owner + normalized
  // content). Stable across author/import origin; the dedup + cloud-analytics
  // join key. Null for asset-only items and the Pack container itself.
  componentUuid  String?   @map("component_uuid") @db.Uuid
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?               @relation("CatalogItemCreatedBy", fields: [createdById], references: [id])
  parentPack     CatalogItem?        @relation("PackComponents", fields: [parentPackId], references: [id], onDelete: Cascade)
  components     CatalogItem[]       @relation("PackComponents")
  versions       CatalogItemVersion[]
  distributions  Distribution[]

  @@index([organizationId, archived])
  @@index([source, scope])
  @@index([organizationId, targetKind])
  @@index([parentPackId])
  @@index([organizationId, componentUuid])
  @@map("catalog_items")
}

/// Versioned history of a CatalogItem's content (prompt/config/content).
/// Mirrors AgentVersion. 1:N with CatalogItem.
model CatalogItemVersion {
  id            String   @id @default(uuid(7)) @db.Uuid
  catalogItemId String   @map("catalog_item_id") @db.Uuid
  version       Int
  name          String
  // Content/prompt: nullable to allow asset-only items (zip bundle, no inline text)
  content       String?  @db.Text
  changeNote    String?  @map("change_note")
  changedById   String?  @map("changed_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation("CatalogItemVersionChangedBy", fields: [changedById], references: [id])

  @@unique([catalogItemId, version])
  @@index([catalogItemId])
  @@map("catalog_item_versions")
}

/// A distribution assignment: a CatalogItem pushed to a targeting set with
/// a mode (auto_install = no user action; opt_in = user accepts). Org-scoped.
model Distribution {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  catalogItemId  String    @map("catalog_item_id") @db.Uuid
  mode           String    // auto_install|opt_in
  targetingType  String    @map("targeting_type") // all|specific
  desiredEnabled Boolean   @default(true) @map("desired_enabled")
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization     Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalogItem      CatalogItem                @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  createdBy        User?                      @relation("DistributionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  targetStatuses   DistributionTargetStatus[]
  targetingEntries DistributionTargetingEntry[]

  @@index([catalogItemId])
  @@index([organizationId])
  @@map("distributions")
}

/// Per-(distribution, computeTarget[/user]) install/enable status and version
/// tracking. Drives compliance dashboards.
model DistributionTargetStatus {
  id                String    @id @default(uuid(7)) @db.Uuid
  distributionId    String    @map("distribution_id") @db.Uuid
  // Nullable for user-only (non-target) opt-in scoping.
  computeTargetId   String?   @map("compute_target_id") @db.Uuid
  // Nullable; populated for user-scoped opt-in tracking.
  userId            String?   @map("user_id") @db.Uuid
  status            String    // pending|installed|enabled|failed|opted_in|declined
  installedVersion  String?   @map("installed_version")
  // Links to an audit trail row (e.g. pack_install_runs) when available.
  installRunId      String?   @map("install_run_id")
  // Coaching Packs sub-slice (T-22.1): true when the user has explicitly chosen
  // a different (or no) pack locally, overriding the org-distributed default.
  // Prevents auto-install from clobbering a recorded user choice.
  overriddenLocally Boolean   @default(false) @map("overridden_locally")
  failureReason     String?   @map("failure_reason")
  installedAt       DateTime? @map("installed_at")
  enabledAt         DateTime? @map("enabled_at")
  reportedAt        DateTime? @map("reported_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  distribution  Distribution   @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  computeTarget ComputeTarget? @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  user          User?          @relation("DistributionTargetStatusUser", fields: [userId], references: [id], onDelete: SetNull)

  // NOTE: The business rule is one status per (distributionId, computeTargetId)
  // where computeTargetId is non-null. A true partial unique index
  // (WHERE compute_target_id IS NOT NULL) is maintained via raw migration;
  // Prisma cannot express partial indexes. Do NOT add @@unique([distributionId,
  // computeTargetId]) here — it would reject rows where computeTargetId IS NULL.
  @@index([distributionId])
  @@index([computeTargetId])
  @@index([distributionId, status])
  @@map("distribution_target_status")
}

/// Specific-targeting rows: which compute targets or users a Distribution
/// explicitly targets when targetingType = 'specific'.
model DistributionTargetingEntry {
  id              String   @id @default(uuid(7)) @db.Uuid
  distributionId  String   @map("distribution_id") @db.Uuid
  computeTargetId String?  @map("compute_target_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  distribution  Distribution   @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  computeTarget ComputeTarget? @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)

  @@index([distributionId])
  @@index([computeTargetId])
  @@map("distribution_targeting_entries")
}
