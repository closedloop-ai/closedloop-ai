// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum WorkstreamType {
  FEATURE_DELIVERY
  BUG_FIX
  TECH_DEBT
  SPIKE
}

enum WorkstreamState {
  INITIATED
  REQUIREMENTS_GENERATING
  REQUIREMENTS_PENDING_APPROVAL
  DESIGN_IN_PROGRESS
  DESIGN_PENDING_APPROVAL
  IMPLEMENTATION_PLANNING
  IMPLEMENTATION_IN_PROGRESS
  IMPLEMENTATION_PENDING_REVIEW
  CODE_REVIEW_RUNNING
  CODE_REVIEW_PENDING_APPROVAL
  VISUAL_QA_RUNNING
  VISUAL_QA_PENDING_APPROVAL
  MERGING
  DEPLOYED
  COMPLETED
  BLOCKED
  CANCELLED
}

enum FeatureStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  EXECUTED
  DONE
  OBSOLETE

  @@map("IssueStatus")
}

enum ExternalLinkType {
  PULL_REQUEST
  FIGMA_DESIGN
  PREVIEW_DEPLOYMENT
}

// Entity types for polymorphic EntityLink
enum EntityType {
  DOCUMENT      @map("ARTIFACT")
  FEATURE       @map("ISSUE")
  EXTERNAL_LINK
}

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Feature blocks Feature)
  RELATES_TO // bidirectional association (Feature ↔ Feature)
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  EXECUTED
  DONE
  OBSOLETE

  @@map("ArtifactStatus")
}

enum DocumentType {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE

  @@map("ArtifactType")
}

enum EvaluationReportType {
  PLAN
  CODE
  PRD
}

enum EvalStatus {
  FAILED
  NEEDS_IMPROVEMENT
  PASSED
}

enum PromptType {
  AGENT
  JUDGE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum WorkstreamEventType {
  STATE_CHANGED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  REVISION_REQUESTED
  LINEAR_ISSUE_CREATED
  LINEAR_ISSUE_UPDATED
  LINEAR_SUBTASK_CREATED
  GITHUB_PR_CREATED
  GITHUB_PR_MERGED
  GITHUB_PR_CLOSED
  GITHUB_PR_REVIEW_SUBMITTED
  GITHUB_PR_COMMENT_ADDED
  GITHUB_PR_LINKED
  GITHUB_ACTION_TRIGGERED
  GITHUB_ACTION_COMPLETED
  GITHUB_CI_STATUS_CHANGED
  SLACK_NOTIFICATION_SENT
  COMMENT_ADDED
  ASSIGNEE_CHANGED
  BLOCKED
  UNBLOCKED
  LOOP_COMPLETED
}

enum LinearSyncStatus {
  SYNCED
  PENDING
  ERROR
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum GitHubActionStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
}

enum ChecksStatus {
  UNKNOWN
  PENDING
  PASSING
  FAILING
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum PRReviewCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LoopStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum LoopCommand {
  PLAN
  EXECUTE
  CHAT
  EXPLORE
  REQUEST_CHANGES
  DECOMPOSE
  EVALUATE_PRD
  GENERATE_PRD
  EVALUATE_PLAN
  EVALUATE_CODE
  REQUEST_PRD_CHANGES
}

enum CustomFieldType {
  TEXT
  NUMBER
  ENUM
  MULTI_ENUM
  DATE
  PEOPLE
}

enum CustomFieldEntityType {
  PROJECT
  WORKSTREAM
  FEATURE    @map("ISSUE")
  DOCUMENT   @map("ARTIFACT")
}

enum NumberFormat {
  NONE
  CURRENCY
  PERCENTAGE
  CUSTOM
}

enum LabelPosition {
  PREFIX
  SUFFIX
}

enum ThreadSource {
  NATIVE
  LIVEBLOCKS
}

enum ThreadStatus {
  OPEN
  RESOLVED
}

enum PreferredComputeMode {
  LOCAL
  CLOUD
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model Organization {
  id                    String    @id @default(uuid(7)) @db.Uuid
  clerkId               String    @unique @map("clerk_id")
  active                Boolean   @default(true) @map("active")
  name                  String
  slug                  String    @unique
  anthropicApiKey       String?   @map("anthropic_api_key") // @deprecated - auto-migrated to claudeApiKeyEncrypted on read (see apiKeyService.resolveApiKey)
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  settings              Json      @default("{}") // settings.computeMode deprecated -- use User.preferredComputeMode instead
  publicDashboardToken  String?   @unique @map("public_dashboard_token")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  users              User[]
  teams              Team[]
  pullRequestRatings PullRequestRating[]
  pullRequests       GitHubPullRequest[]
  projects           Project[]
  workstreams        Workstream[]
  documents          Document[]
  features           Feature[]
  externalLinks      ExternalLink[]
  githubInstallation GitHubInstallation?
  loops              Loop[]
  prompts            Prompt[]
  computeTargets     ComputeTarget[]
  chatSessions       ChatSession[]
  judgeHumanScores   JudgeHumanScore[]
  customFields       CustomField[]
  commentThreads     CommentThread[]

  @@map("organizations")
}

model User {
  id                       String                @id @default(uuid(7)) @db.Uuid
  clerkId                  String                @map("clerk_id")
  organizationId           String                @map("organization_id") @db.Uuid
  active                   Boolean               @default(true) @map("active")
  email                    String
  firstName                String?               @map("first_name")
  lastName                 String?               @map("last_name")
  avatarUrl                String?               @map("avatar_url")
  phoneNumber              String?               @map("phone_number")
  role                     ApproverRole          @default(ENGINEER)
  linearId                 String?               @map("linear_id")
  slackId                  String?               @map("slack_id")
  githubUsername           String?               @map("github_username")
  anthropicApiKey          String?               @map("anthropic_api_key") // @deprecated - auto-migrated to claudeApiKeyEncrypted on read (see apiKeyService.resolveApiKey)
  claudeApiKeyEncrypted    String?               @map("claude_api_key_encrypted")
  claudeApiKeyLastFour     String?               @map("claude_api_key_last_four")
  claudeApiKeySetAt        DateTime?             @map("claude_api_key_set_at")
  preferredComputeMode     PreferredComputeMode? @map("preferred_compute_mode")
  preferredComputeTargetId String?               @map("preferred_compute_target_id") @db.Uuid
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  // Relations
  organization             Organization        @relation(fields: [organizationId], references: [id])
  preferredComputeTarget   ComputeTarget?      @relation("UserPreferredComputeTarget", fields: [preferredComputeTargetId], references: [id])
  teamMemberships          TeamMember[]
  pullRequestRatings       PullRequestRating[]
  favoriteProjects         FavoriteProject[]
  assignedProjects         Project[]           @relation("ProjectAssignee")
  createdProjects          Project[]           @relation("ProjectCreatedBy")
  assignedDocuments        Document[]          @relation("DocumentAssignee")
  createdDocuments         Document[]          @relation("DocumentCreatedBy")
  approvedDocuments        Document[]          @relation("DocumentApprover")
  assignedFeatures         Feature[]           @relation("FeatureAssignee")
  createdFeatures          Feature[]           @relation("FeatureCreator")
  createdWorkstreams       Workstream[]        @relation("WorkstreamCreatedBy")
  assignedWorkstreams      Workstream[]        @relation("WorkstreamAssignee")
  loops                    Loop[]
  computeTargets           ComputeTarget[]
  chatSessions             ChatSession[]
  judgeHumanScores         JudgeHumanScore[]
  createdCustomFields      CustomField[]
  updatedCustomFieldValues CustomFieldValue[]
  dismissedGenerationStatuses DocumentGenerationStatusDismissal[]

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model ComputeTarget {
  id                  String   @id @default(uuid(7)) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  machineName         String   @map("machine_name")
  platform            String
  capabilities        Json     @default("{}")
  supportedOperations Json     @default("[]") @map("supported_operations")
  lastSeenAt          DateTime @default(now()) @map("last_seen_at")
  isOnline            Boolean  @default(false) @map("is_online")
  isSharedWithOrg     Boolean  @default(false) @map("is_shared_with_org")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  preferringUsers User[]           @relation("UserPreferredComputeTarget")
  desktopCommands DesktopCommand[]
  loops           Loop[]

  @@unique([userId, machineName])
  @@index([organizationId, userId])
  @@index([userId, isOnline])
  @@index([organizationId, isSharedWithOrg])
  @@map("compute_targets")
}

model DesktopCommand {
  id                 String    @id @default(uuid(7)) @db.Uuid
  computeTargetId    String    @map("compute_target_id") @db.Uuid
  idempotencyKey     String?   @map("idempotency_key")
  requestFingerprint String    @map("request_fingerprint")
  operationId        String    @map("operation_id")
  requestPayload     Json      @map("request_payload")
  status             String
  error              String?
  lastSequenceAcked  Int       @default(0) @map("last_sequence_acked")
  queuedTimeoutMs    Int?      @map("queued_timeout_ms")
  runningTimeoutMs   Int?      @map("running_timeout_ms")
  createdAt          DateTime  @default(now()) @map("created_at")
  startedAt          DateTime? @map("started_at")
  finishedAt         DateTime? @map("finished_at")

  computeTarget ComputeTarget         @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  events        DesktopCommandEvent[]

  // NOTE: A partial unique index on (compute_target_id, idempotency_key) WHERE
  // idempotency_key IS NOT NULL is maintained via raw migrations. Prisma cannot
  // express partial indexes. Prisma 7.4+ falsely flags this as drift — we pin
  // to 7.3.0 until resolved. Do NOT drop it.
  // See: https://github.com/prisma/prisma/issues/29289
  @@index([computeTargetId, status, createdAt])
  @@index([operationId])
  @@map("desktop_commands")
}

model DesktopCommandEvent {
  commandId    String   @map("command_id") @db.Uuid
  sequence     Int
  eventType    String   @map("event_type")
  eventPayload Json     @map("event_payload")
  createdAt    DateTime @default(now()) @map("created_at")

  command DesktopCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@id([commandId, sequence])
  @@map("desktop_command_events")
}

model Project {
  id              String        @id @default(uuid(7)) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  name            String
  description     String?
  priority        Priority      @default(MEDIUM)
  status          ProjectStatus @default(NOT_STARTED)
  assigneeId      String?       @map("assignee_id") @db.Uuid
  createdById     String        @map("created_by_id") @db.Uuid
  slug            String?
  targetDate      DateTime?     @map("target_date")
  codebaseSummary String?       @map("codebase_summary")
  lastIndexedAt   DateTime?     @map("last_indexed_at")
  settings        Json          @default("{}")
  sortOrder       Int?          @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  organization  Organization      @relation(fields: [organizationId], references: [id])
  assignee      User?             @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  createdBy     User              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  workstreams   Workstream[]
  documents     Document[]
  features      Feature[]
  externalLinks ExternalLink[]
  teams         ProjectTeam[]
  favoritedBy   FavoriteProject[]

  @@unique([organizationId, slug])
  @@index([assigneeId])
  @@index([createdById])
  @@map("projects")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]

  @@unique([organizationId, slug])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

/// Per-user favorite projects for quick access in the sidebar
model FavoriteProject {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("favorite_projects")
}

// =============================================================================
// WORKSTREAM
// =============================================================================

model Workstream {
  id             String          @id @default(uuid(7)) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  title          String
  description    String?
  type           WorkstreamType  @default(FEATURE_DELIVERY)
  state          WorkstreamState @default(INITIATED)
  stateChangedAt DateTime        @default(now()) @map("state_changed_at")
  createdById    String          @map("created_by_id") @db.Uuid
  assigneeId     String?         @map("assigned_to_id") @db.Uuid
  priority       Priority        @default(MEDIUM)
  slug           String?
  hasUIChanges   Boolean         @default(false) @map("has_ui_changes")
  startedAt      DateTime        @default(now()) @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metrics        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  organization  Organization        @relation(fields: [organizationId], references: [id])
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("WorkstreamCreatedBy", fields: [createdById], references: [id])
  assignee      User?               @relation("WorkstreamAssignee", fields: [assigneeId], references: [id])
  documents     Document[]
  features      Feature[]
  externalLinks ExternalLink[]
  loops         Loop[]
  pullRequests  GitHubPullRequest[]

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, state])
  @@index([organizationId, assigneeId])
  @@index([projectId])
  @@map("workstreams")
}

model WorkstreamEvent {
  id           String              @id @default(uuid(7)) @db.Uuid
  workstreamId String              @map("workstream_id") @db.Uuid
  type         WorkstreamEventType
  fromState    WorkstreamState?    @map("from_state")
  toState      WorkstreamState?    @map("to_state")
  actorId      String?             @map("actor_id") @db.Uuid
  actorType    String              @default("system") @map("actor_type")
  data         Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([workstreamId, type])
  @@index([workstreamId, createdAt])
  @@map("workstream_events")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model Document {
  id              String         @id @default(uuid(7)) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  workstreamId    String?        @map("workstream_id") @db.Uuid
  projectId       String?        @map("project_id") @db.Uuid // template documents don't have a project
  type            DocumentType   @map("type")
  title           String
  slug            String
  fileName        String?        @map("file_name")
  assigneeId      String?        @map("assignee_id") @db.Uuid
  approverId      String?        @map("approver_id") @db.Uuid
  status          DocumentStatus @default(DRAFT)
  priority        Priority       @default(MEDIUM)
  latestVersion   Int            @default(1) @map("latest_version")
  createdById     String         @map("created_by_id") @db.Uuid
  tokenUsage      Json?          @map("token_usage")
  targetRepo      String?        @map("target_repo")
  targetBranch    String?        @map("target_branch")
  templateForType DocumentType?  @map("template_for_type")
  sortOrder       Int?           @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  organization              Organization                        @relation(fields: [organizationId], references: [id])
  workstream                Workstream?                         @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  project                   Project?                            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee                  User?                               @relation("DocumentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy                 User                                @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  approver                  User?                               @relation("DocumentApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions                  DocumentVersion[]
  ratings                   DocumentRating[]
  evaluations               DocumentEvaluation[]
  performances              GitHubActionRunPerformance[]
  pullRequests              GitHubPullRequest[]
  loops                     Loop[]
  fileAttachments           FileAttachment[]
  generationStatusDismissal DocumentGenerationStatusDismissal?

  @@unique([organizationId, slug])
  @@unique([organizationId, templateForType])
  @@index([organizationId, type])
  @@index([organizationId, workstreamId, type])
  @@index([organizationId, projectId, type])
  @@index([workstreamId])
  @@index([projectId])
  @@map("artifacts")
}

model DocumentGenerationStatusDismissal {
  id            String   @id @default(uuid(7)) @db.Uuid
  documentId    String   @unique @map("artifact_id") @db.Uuid
  dismissedById String   @map("dismissed_by_id") @db.Uuid
  runKey        String   @map("run_key")
  dismissedAt   DateTime @default(now()) @map("dismissed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  dismissedBy User     @relation(fields: [dismissedById], references: [id], onDelete: Restrict)

  @@index([dismissedById])
  @@map("artifact_generation_status_dismissals")
}

model DocumentVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  documentId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("artifact_versions")
}

model DocumentEvaluation {
  id             String               @id @default(uuid(7)) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  entityId       String               @map("entity_id") @db.Uuid
  entityType     EntityType           @map("entity_type")
  documentId     String?              @map("artifact_id") @db.Uuid
  actionRunId    String?              @map("action_run_id") @db.Uuid
  loopId         String?              @map("loop_id") @db.Uuid
  reportType     EvaluationReportType @map("report_type")
  reportId       String               @map("report_id")
  reportData     Json?                @map("report_data")
  createdAt      DateTime             @default(now()) @map("created_at")

  document         Document?         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  loop             Loop?             @relation(fields: [loopId], references: [id], onDelete: SetNull)
  judgeScores      JudgeScore[]
  judgeHumanScores JudgeHumanScore[]

  @@unique([entityId, reportId])
  @@index([entityId, createdAt])
  @@index([organizationId, entityType, createdAt])
  @@map("artifact_evaluations")
}

// SECURITY: No organizationId column — org isolation is enforced via DocumentEvaluation.organizationId.
// JudgeScore rows are scoped to an org through the evaluationId FK:
// judgeScore.evaluationId → DocumentEvaluation.organizationId.
// All read-path queries MUST join through DocumentEvaluation and filter by organizationId directly.
model JudgeScore {
  id            String     @id @default(uuid(7)) @db.Uuid
  evaluationId  String     @map("evaluation_id") @db.Uuid
  promptId      String?    @map("prompt_id") @db.Uuid
  caseId        String     @map("case_id")
  metricName    String     @map("metric_name")
  threshold     Float
  score         Float
  justification String     @map("justification") @db.Text
  finalStatus   EvalStatus @map("final_status")
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  evaluation       DocumentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  prompt           Prompt?            @relation(fields: [promptId], references: [id], onDelete: SetNull)
  judgeHumanScores JudgeHumanScore[]

  @@unique([evaluationId, caseId, metricName])
  @@index([promptId])
  @@map("judge_scores")
}

model JudgeHumanScore {
  id             String   @id @default(uuid(7)) @db.Uuid
  // Denormalized from judgeScore.evaluationId for query performance.
  evaluationId   String   @map("evaluation_id") @db.Uuid
  judgeScoreId   String   @map("judge_score_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  score          Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  evaluation   DocumentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  judgeScore   JudgeScore         @relation(fields: [judgeScoreId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([judgeScoreId, userId, organizationId])
  @@index([evaluationId])
  @@index([organizationId, userId])
