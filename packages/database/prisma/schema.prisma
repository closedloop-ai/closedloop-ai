// GITHUB INTEGRATION
// =============================================================================

model GitHubInstallation {
  id                       String                   @id @default(uuid(7)) @db.Uuid
  organizationId           String?                  @unique @map("organization_id") @db.Uuid
  installationId           String                   @unique @map("installation_id")
  accountId                String                   @map("account_id")
  accountLogin             String                   @map("account_login")
  accountType              String                   @map("account_type")
  senderLogin              String                   @map("sender_login")
  senderId                 String                   @map("sender_id")
  status                   GitHubInstallationStatus @default(PENDING_CLAIM)
  permissions              Json?
  events                   Json?
  repositorySelection      String?                  @map("repository_selection")
  suspendedAt              DateTime?                @map("suspended_at")
  suspendedBy              String?                  @map("suspended_by")
  claimedAt                DateTime?                @map("claimed_at")
  claimedByUserId          String?                  @map("claimed_by_user_id") @db.Uuid
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  // PLN-634: set on the prior UNINSTALLED row when an OAuth callback detects
  // a different-account reconnect. The confirm-reset endpoint reads this
  // value to determine which new installation to claim, so a user-controlled
  // body cannot redirect the claim to an attacker's installation.
  pendingNewInstallationId String?                  @map("pending_new_installation_id")

  // Relations
  organization Organization?                  @relation(fields: [organizationId], references: [id])
  repositories GitHubInstallationRepository[]

  @@index([status])
  @@index([accountId])
  @@map("github_installations")
}

model GitHubInstallationRepository {
  id             String    @id @default(uuid(7)) @db.Uuid
  installationId String    @map("installation_id") @db.Uuid
  githubRepoId   String    @map("github_repo_id")
  fullName       String    @map("full_name")
  name           String
  owner          String
  private        Boolean
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastPushedAt   DateTime? @map("last_pushed_at")
  // Soft-tombstone marker set when a repo disappears from the installation
  // during a disconnect/reinstall window (PLN-634). Tombstoned rows are
  // filtered from active-pool reads (getRepositories, etc.) but remain
  // resolvable by FK so historical BranchDetail / PullRequestDetail records
  // can still render. Cleared if the same githubRepoId reappears on reconnect.
  removedAt      DateTime? @map("removed_at")

  // Relations
  installation       GitHubInstallation  @relation(fields: [installationId], references: [id], onDelete: Cascade)
  branchDetails      BranchDetail[]
  pullRequestDetails PullRequestDetail[]
  teamRepositories   TeamRepository[]

  @@unique([installationId, githubRepoId])
  @@map("github_installation_repositories")
}

// Symphony's GitHub OAuth callback persists these per organization/user rows.
// The connection is not inferred from Clerk's social account metadata, and it
// intentionally does not fan out to every User row with the same clerkId: a
// write-capable GitHub token is scoped to the org where the user connected it.
model GitHubUserConnection {
  id                    String    @id @default(uuid(7)) @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  githubUserId          String    @map("github_user_id")
  githubNodeId          String?   @map("github_node_id")
  login                 String
  normalizedLogin       String    @map("normalized_login")
  avatarUrl             String?   @map("avatar_url")
  profileUrl            String?   @map("profile_url")
  accessTokenEncrypted  String    @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scopes                String[]  @default([])
  revokedAt             DateTime? @map("revoked_at")
  lastUsedAt            DateTime? @map("last_used_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@unique([organizationId, githubUserId])
  @@index([organizationId, normalizedLogin])
  @@index([revokedAt])
  @@map("github_user_connections")
}

model PublicRepository {
