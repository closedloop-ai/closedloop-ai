// =============================================================================
// DESKTOP SESSION AUTH (FEA-1514 / FEA-2215)
// First-party desktop sessions. Short-lived access tokens are stateless JWTs
// (see packages/auth/desktop-session-jwt.ts); only the rotating refresh-token
// family is persisted here, and only as a hash. Session + refresh-token family
// are bound to the desktop device public key so a stolen refresh token alone
// cannot mint a new access token.
// =============================================================================

model DesktopSession {
  id             String    @id @default(uuid(7)) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  gatewayId      String    @map("gateway_id")
  boundPublicKey String    @map("bound_public_key")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastUsedAt     DateTime? @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  expiresAt      DateTime  @map("expires_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens DesktopRefreshToken[]

  @@index([userId])
  @@index([organizationId])
  @@index([expiresAt])
  @@map("desktop_sessions")
}

model DesktopRefreshToken {
  id                 String    @id @default(uuid(7)) @db.Uuid
  sessionId          String    @map("session_id") @db.Uuid
  familyId           String    @map("family_id") @db.Uuid
  tokenHash          String    @unique @map("token_hash")
  createdAt          DateTime  @default(now()) @map("created_at")
  expiresAt          DateTime  @map("expires_at")
  lastUsedAt         DateTime? @map("last_used_at")
  revokedAt          DateTime? @map("revoked_at")
  replacedByTokenId  String?   @map("replaced_by_token_id") @db.Uuid
  rotatedFromTokenId String?   @map("rotated_from_token_id") @db.Uuid

  session DesktopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, revokedAt])
  @@index([familyId, revokedAt])
  @@index([expiresAt])
  @@map("desktop_refresh_tokens")
}

model Project {
  id                  String        @id @default(uuid(7)) @db.Uuid
