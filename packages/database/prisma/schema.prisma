  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  artifact    Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  dismissedBy User     @relation(fields: [dismissedById], references: [id], onDelete: Restrict)

  @@index([dismissedById])
  @@map("artifact_generation_status_dismissals")
}

model DocumentVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  documentId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  documentDetail DocumentDetail @relation(fields: [documentId], references: [artifactId], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

model Artifact {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  // Nullable so machine-generated SESSION artifacts captured outside any project
  // can exist unparented. The project requirement for DOCUMENT/BRANCH/DEPLOYMENT
  // is enforced at the service layer (apps/api), not the column.
  projectId      String?          @map("project_id") @db.Uuid
  type           ArtifactType
  subtype        ArtifactSubtype?
  name           String
  slug           String?
  assigneeId     String?          @map("assignee_id") @db.Uuid
  // Freeform per-subtype lifecycle status. Intentionally NOT bound to a DB enum:
  // a single column carries multiple disjoint vocabularies — DocumentStatus
  // (PRD/IMPLEMENTATION_PLAN/TEMPLATE), FeatureStatus (FEATURE), plus the
  // Branch/Deployment/Session vocabularies. The authoritative contracts are the
  // TypeScript SSOTs in @closedloop-ai/loops-api/document; the DocumentStatus /
  // FeatureStatus enums below are advisory documentation only. See PRD-495.
  status         String
  priority       Priority?
  dueDate        DateTime?        @map("due_date")
  externalUrl    String?          @map("external_url")
  sortOrder      Int?             @map("sort_order")
  createdAt      DateTime         @default(now()) @map("created_at")
  createdById    String?          @map("created_by_id") @db.Uuid
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  organization              Organization                       @relation(fields: [organizationId], references: [id])
  project                   Project?                           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee                  User?                              @relation("ArtifactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy                 User?                              @relation("ArtifactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  document                  DocumentDetail?
  branch                    BranchDetail?
  pullRequest               PullRequestDetail?
  deployment                DeploymentDetail?
  session                   SessionDetail?
  loopSession               Loop?                              @relation("LoopSessionArtifact")
  branchDeployments         DeploymentDetail[]                 @relation("DeploymentOfBranch")
  pullRequestDetails        PullRequestDetail[]                @relation("BranchPullRequests")
  branchCommits             CommitDetail[]                     @relation("BranchCommits")
  sourceLinks               ArtifactLink[]                     @relation("ArtifactLinkSource")
  targetLinks               ArtifactLink[]                     @relation("ArtifactLinkTarget")
  ratings                   ArtifactRating[]
  evaluations               ArtifactEvaluation[]
  commentThreads            CommentThread[]
  fileAttachments           FileAttachment[]
  loops                     Loop[]
  generationStatusDismissal DocumentGenerationStatusDismissal?
  tagArtifacts              TagArtifact[]
  favoritedBy               FavoriteArtifact[]
  linearSubtasks            LinearSubtask[]

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, type])
  @@index([organizationId, projectId, sortOrder])
  @@index([organizationId, type, status])
  @@index([organizationId, assigneeId])
  @@index([organizationId, createdById])
  @@map("artifacts")
}

// Type-specific detail for DOCUMENT-typed artifacts. 1:1 with `Artifact` via
// shared `artifact_id` primary key. Other detail tables (pull_request_detail,
// deployment_detail) arrive in Chunk 2b.
model DocumentDetail {
  artifactId         String           @id @map("artifact_id") @db.Uuid
  fileName           String?          @map("file_name")
  approverId         String?          @map("approver_id") @db.Uuid
  templateForType    ArtifactSubtype? @map("template_for_type")
  latestVersion      Int              @default(1) @map("latest_version")
  repositorySnapshot Json             @map("repository_snapshot")

  artifact Artifact          @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  approver User?             @relation("DocumentDetailApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions DocumentVersion[]

  @@map("document_detail")
}

// Branch-owned detail for BRANCH-typed artifacts.
model BranchDetail {
  artifactId                    String       @id @map("artifact_id") @db.Uuid
  // Write-once denormalization of the parent Artifact.organizationId (the org
  // SSOT — PRD-510 FR13). Present only because the D2 unique index cannot span
  // the Artifact join; set once at creation from the parent Artifact and never
  // updated independently (guarded by the FR13 invariant test).
  organizationId                String       @map("organization_id") @db.Uuid
  // Installation-repo surrogate id — nullable enrichment only (PRD-510 D2). App
  // repos carry it (webhook/status/file-cache lookups); desktop-produced
  // branches in non-App repos have none. Branch identity keys on
  // repositoryFullName (D2), not this id.
  repositoryId                  String?      @map("repository_id") @db.Uuid
  // Normalized `owner/name` (normalizeRepoFullName) — the producer-independent
  // branch identity component (PRD-510 D2), uniform across desktop sync and the
  // GitHub webhook regardless of whether the App is installed.
  repositoryFullName            String       @map("repository_full_name")
  branchName                    String       @map("branch_name")
  baseBranch                    String?      @map("base_branch")
  baseBranchSource              String?      @map("base_branch_source")
  headSha                       String?      @map("head_sha")
  headShaSource                 String?      @map("head_sha_source")
  headShaObservedAt             DateTime?    @map("head_sha_observed_at")
  // Genuine-activity timestamp for the branch: monotonic GREATEST() of real
  // git/GitHub events — a pushed commit (headShaObservedAt), PR open/merge/close,
  // and PR review submission. Deliberately NOT bumped by CI check runs, file/
  // checks cache refreshes, sync bookkeeping, or session activity. Default sort
  // for the Branches list. Nullable for pre-backfill rows; readers fall back to
  // the Artifact createdAt.
  lastActivityAt                DateTime?    @map("last_activity_at")
  lastPushBeforeSha             String?      @map("last_push_before_sha")
  // Explicit set-once push state (PRD-510 FR2, mirroring FEA-2531 Phase C).
  // `firstPushedAt` is the earliest verified push (earliest wins); `pushSource`
  // is `session` | `webhook`. Deliberately NEVER derived from the volatile
  // headShaSource (the stale_push trap) or from row existence (D3: existence
  // means "observed", not "pushed"). Drives the FR12 display predicate.
  firstPushedAt                 DateTime?    @map("first_pushed_at")
  pushSource                    String?      @map("push_source")
  currentPullRequestDetailId    String?      @map("current_pull_request_detail_id") @db.Uuid
  deletedAt                     DateTime?    @map("deleted_at")
  checksStatus                  ChecksStatus @default(UNKNOWN) @map("checks_status")
  checksDetailHeadSha           String?      @map("checks_detail_head_sha")
  checksDetailTotalCount        Int          @default(0) @map("checks_detail_total_count")
  checksDetailTruncated         Boolean      @default(false) @map("checks_detail_truncated")
  checksDetailProviderState     String?      @map("checks_detail_provider_state")
  checksDetailUnavailableReason String?      @map("checks_detail_unavailable_reason")
  checksDetailUpdatedAt         DateTime?    @map("checks_detail_updated_at")
  checkRunRetryState            String?      @map("check_run_retry_state") @db.VarChar(32)
  checkRunRetryHeadSha          String?      @map("check_run_retry_head_sha")
  checkRunRetryResourceId       String?      @map("check_run_retry_resource_id") @db.VarChar(255)
  checkRunRetryIdempotencyKey   String?      @map("check_run_retry_idempotency_key") @db.VarChar(255)
  checkRunRetryAttempts         Int          @default(0) @map("check_run_retry_attempts")
  checkRunRetryNextAt           DateTime?    @map("check_run_retry_next_at")
  checkRunRetryLastAttemptAt    DateTime?    @map("check_run_retry_last_attempt_at")
  checkRunRetryReason           String?      @map("check_run_retry_reason") @db.VarChar(64)
  fileCacheStatus               String       @default("absent") @map("file_cache_status")
  fileCacheHeadSha              String?      @map("file_cache_head_sha")
  fileCacheFileCount            Int          @default(0) @map("file_cache_file_count")
  fileCachePatchBytes           Int          @default(0) @map("file_cache_patch_bytes")
  fileCacheUpdatedAt            DateTime?    @map("file_cache_updated_at")
  syncStatus                    String       @default("idle") @map("sync_status")
  lastSyncStartedAt             DateTime?    @map("last_sync_started_at")
  lastSyncCompletedAt           DateTime?    @map("last_sync_completed_at")
  lastSyncErrorCode             String?      @map("last_sync_error_code")
  lastSyncErrorMessage          String?      @map("last_sync_error_message") @db.Text
  fetchCredentialType           String?      @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId        String?      @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism                String?      @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger                  String?      @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt               DateTime?    @map("fetch_observed_at")
  fetchResultReason             String?      @map("fetch_result_reason") @db.VarChar(64)
  createdAt                     DateTime     @default(now()) @map("created_at")
  updatedAt                     DateTime     @updatedAt @map("updated_at")

  artifact                 Artifact                        @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  organization             Organization                    @relation(fields: [organizationId], references: [id])
  repository               GitHubInstallationRepository?   @relation(fields: [repositoryId], references: [id])
  currentPullRequestDetail PullRequestDetail?              @relation("CurrentBranchPullRequest", fields: [currentPullRequestDetailId], references: [id], onDelete: SetNull)
  fileChanges              BranchFileChange[]
  statusChecks             BranchStatusCheck[]
  githubCommentProjections GitHubCommentThreadProjection[]

  // PRD-510 D2 branch identity: one row per (org, normalized repo full name,
  // branch name) — uniform across producers, independent of App installation.
  // Explicit map: the default name exceeds Postgres's 63-char identifier limit.
  @@unique([organizationId, repositoryFullName, branchName], map: "branch_detail_org_repo_full_name_branch_key")
  // FR12 display predicate: org-scoped scans filtering on push evidence.
  @@index([organizationId, firstPushedAt], map: "branch_detail_org_first_pushed_at_idx")
  @@index([repositoryId, headSha])
  // NOTE: branch_detail_remote_head_evidence_idx is a partial index on
  // head_sha_source, last_activity_at DESC, and artifact_id where head_sha is
  // present and deleted_at is null. Prisma cannot express partial indexes.
  @@index([currentPullRequestDetailId])
  @@index([syncStatus])
  @@index([lastActivityAt])
  @@index([checkRunRetryState, checkRunRetryNextAt], map: "branch_detail_check_run_retry_due_idx")
  @@index([repositoryId, checkRunRetryHeadSha], map: "branch_detail_check_run_retry_repo_head_idx")
  @@map("branch_detail")
}

// Bounded current-head GitHub status/check context projection for Branch View.
model BranchStatusCheck {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchArtifactId       String    @map("branch_artifact_id") @db.Uuid
  headSha                String    @map("head_sha")
  providerKey            String    @map("provider_key") @db.VarChar(160)
  kind                   String    @db.VarChar(32)
  providerNodeId         String?   @map("provider_node_id") @db.VarChar(255)
  name                   String    @db.VarChar(255)
  status                 String?   @db.VarChar(64)
  conclusion             String?   @db.VarChar(64)
  targetUrl              String?   @map("target_url") @db.VarChar(2048)
  position               Int
  fetchCredentialType    String?   @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId String?   @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism         String?   @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger           String?   @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt        DateTime? @map("fetch_observed_at")
  fetchResultReason      String?   @map("fetch_result_reason") @db.VarChar(64)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  branch BranchDetail @relation(fields: [branchArtifactId], references: [artifactId], onDelete: Cascade)

  @@unique([branchArtifactId, headSha, providerKey], map: "branch_status_checks_branch_head_provider_key")
  @@index([branchArtifactId, headSha, position], map: "branch_status_checks_branch_head_position_idx")
  @@map("branch_status_checks")
}

// GitHub pull request conversation detail. These rows are nested under branch
// artifacts and preserve current or historical PR-specific review state.
model PullRequestDetail {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artifactId             String?         @unique @map("artifact_id") @db.Uuid
  branchArtifactId       String          @map("branch_artifact_id") @db.Uuid
  // FEA-2732 / PRD-510 D2: write-once denormalization of the parent branch
  // Artifact's organizationId (the org SSOT). Set once at creation from the
  // branch's org and never updated independently. Present because a PR detail row
  // has no Artifact of its own to scope by, and the repo-less desktop identity
  // index must span the org (two orgs can sync the same public repo's PR number).
  organizationId         String          @map("organization_id") @db.Uuid
  // Installation-repo surrogate id — nullable enrichment only (PRD-510 D2). App
  // repos carry it (webhook/adoption lookups); desktop-produced PRs in non-App
  // repos have none until a later App installation adopts the row. PR identity
  // keys on repositoryFullName (repo-less) or repositoryId (App); never on both.
  repositoryId           String?         @map("repository_id") @db.Uuid
  // Normalized `owner/name` (normalizeRepoFullName) — the producer-independent PR
  // identity component for repo-less desktop rows (PRD-510 D2), uniform across
  // desktop sync and the GitHub webhook. Enrichment for App rows.
  repositoryFullName     String?         @map("repository_full_name")
  // Nullable for desktop-only rows until `gh` enrichment / App adoption supplies
  // the canonical GitHub node id. The unique constraint still holds across all
  // non-null values (Postgres treats NULLs as distinct).
  githubId               String?         @unique @map("github_id")
  number                 Int
  title                  String?
  htmlUrl                String?         @map("html_url")
  body                   String?         @db.Text
  prState                GitHubPRState   @default(OPEN) @map("pr_state")
  isDraft                Boolean         @default(false) @map("is_draft")
  additions              Int?
  deletions              Int?
  changedFiles           Int?            @map("changed_files")
  reviewDecision         ReviewDecision? @map("review_decision")
  isCurrent              Boolean         @default(false) @map("is_current")
  closedAt               DateTime?       @map("closed_at")
  mergedAt               DateTime?       @map("merged_at")
  mergeCommitSha         String?         @map("merge_commit_sha")
  lastVerifiedAt         DateTime?       @map("last_verified_at")
  lastRefreshAttemptAt   DateTime?       @map("last_refresh_attempt_at")
  fetchCredentialType    String?         @map("fetch_credential_type") @db.VarChar(32)
  fetchCredentialOwnerId String?         @map("fetch_credential_owner_id") @db.Uuid
  fetchMechanism         String?         @map("fetch_mechanism") @db.VarChar(32)
  fetchTrigger           String?         @map("fetch_trigger") @db.VarChar(32)
  fetchObservedAt        DateTime?       @map("fetch_observed_at")
  fetchResultReason      String?         @map("fetch_result_reason") @db.VarChar(64)

  artifact                       Artifact?                       @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  branchArtifact                 Artifact                        @relation("BranchPullRequests", fields: [branchArtifactId], references: [id], onDelete: Cascade)
  repository                     GitHubInstallationRepository?   @relation(fields: [repositoryId], references: [id])
  organization                   Organization                    @relation(fields: [organizationId], references: [id])
  reviews                        GitHubPRReview[]
  githubCommentThreadProjections GitHubCommentThreadProjection[]
  currentForBranches             BranchDetail[]                  @relation("CurrentBranchPullRequest")

  // App-repo identity (webhook/backfill producers). Repo-less desktop rows have a
  // null repositoryId, so this index never constrains them (NULLs are distinct).
  @@unique([repositoryId, number])
  @@unique([id, branchArtifactId], map: "pull_request_detail_id_branch_artifact_id_key")
  @@index([branchArtifactId, isCurrent])
  @@index([organizationId])
  // NOTE: pull_request_detail_org_repo_full_name_number_key is a PARTIAL unique
  // index on (organization_id, repository_full_name, number) WHERE repository_id
  // IS NULL — the producer-independent identity for desktop-produced non-App PRs
  // (FEA-2732). Prisma cannot express partial indexes, so it lives in the raw
  // migration. A later App installation fills repository_id (adoption), moving the
  // row out of this index and under @@unique([repositoryId, number]).
  @@map("pull_request_detail")
}

// Cloud SSOT for git commits observed on a branch (PRD-510 D7 / FEA-2731).
// Deliberately a STANDALONE table, NOT an Artifact subtype — commits are git
// objects; no COMMIT ArtifactType exists and none is added. The row attaches to
// the platform only via `branchArtifactId` (the branch's Artifact); there is no
// commit slug and no ArtifactLink. Fed by two producers reconciled on the
// identity key: desktop sync (non-App repos, no GitHub App required) and the
// GitHub `push` webhook (App repos). Reads are join-reached per branch.
model CommitDetail {
  id                 String    @id @default(uuid(7)) @db.Uuid
  // Write-once denormalization of the owning org (from the API key at ingest /
  // the branch Artifact's org). Present only so the identity index can span for
  // cross-tenant dedup (non-App repos carry no repositoryId, mirroring D2) — it
  // is NOT a query-scoping column (D4: reads reach it via the branch). Set once
  // at creation and never independently updated.
  organizationId     String    @map("organization_id") @db.Uuid
  // Normalized `owner/name` (normalizeRepoFullName) — the producer-independent
  // commit identity component (PRD-510 D2), uniform across desktop sync and the
  // GitHub webhook regardless of whether the App is installed.
  repositoryFullName String    @map("repository_full_name")
  sha                String
  // The branch the commit was observed on. Single FK, Cascade; no ArtifactLink.
  // Many-to-many (a commit on multiple branches) is deferred (Q10).
  branchArtifactId   String    @map("branch_artifact_id") @db.Uuid
  message            String?   @db.Text
  committedAt        DateTime? @map("committed_at")
  authoredAt         DateTime? @map("authored_at")
  authorName         String?   @map("author_name")
  authorEmail        String?   @map("author_email")
  authorLogin        String?   @map("author_login")
  linesAdded         Int?      @map("lines_added")
  linesRemoved       Int?      @map("lines_removed")
  filesChanged       Int?      @map("files_changed")
  isMerge            Boolean   @default(false) @map("is_merge")
  mergeCommitSha     String?   @map("merge_commit_sha")
  // Provenance of the last authoritative writer per the field-level merge rules
  // (Phase 4): `desktop_sync` | `push_webhook` | `github_api`. Freeform String,
  // matching BranchDetail's pushSource/headShaSource convention; the allowed
  // values are the CommitSource SSOT in @repo/api (packages/api/src/types).
  source             String
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Artifact     @relation("BranchCommits", fields: [branchArtifactId], references: [id], onDelete: Cascade)

  // PRD-510 D7 commit identity: one row per (org, normalized repo full name,
  // sha) — cross-tenant dedup and the convergence point for the desktop + webhook
  // producers. Explicit map keeps the constraint name well under Postgres's
  // 63-char identifier limit.
  @@unique([organizationId, repositoryFullName, sha], map: "commit_detail_org_repo_full_name_sha_key")
  // Branch-detail read pattern: a branch's commits, most-recent first.
  @@index([branchArtifactId, committedAt], map: "commit_detail_branch_committed_at_idx")
  @@map("commit_detail")
}

// Bounded branch file-change metadata cache. Raw file contents stay in GitHub
// and are fetched only through explicit diff/content paths.
model BranchFileChange {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchArtifactId   String   @map("branch_artifact_id") @db.Uuid
  headSha            String   @map("head_sha")
  path               String
  previousPath       String?  @map("previous_path")
  status             String
  additions          Int?
  deletions          Int?
  changes            Int?
  patch              String?  @db.Text
  patchBytes         Int      @default(0) @map("patch_bytes")
  patchOmittedReason String?  @map("patch_omitted_reason")
  isBinary           Boolean  @default(false) @map("is_binary")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  branch BranchDetail @relation(fields: [branchArtifactId], references: [artifactId], onDelete: Cascade)

  @@unique([branchArtifactId, headSha, path])
  @@index([branchArtifactId, path])
  @@index([branchArtifactId, headSha])
  @@map("branch_file_changes")
}

// Type-specific detail for DEPLOYMENT-typed artifacts. 1:1 with `Artifact`
// via shared `artifact_id` primary key. Rows are backfilled from the
// PREVIEW_DEPLOYMENT rows in the legacy `external_links` table in
// Chunk 2B. All columns nullable because today's `DeploymentMetadata` is
// loosely shaped. Deployment state lives only on the parent `artifact.status`
// (plain TEXT so any vendor value round-trips).
model DeploymentDetail {
  artifactId          String   @id @map("artifact_id") @db.Uuid
  environment         String?
  ref                 String?
  sha                 String?
  githubStatusUrl     String?  @map("github_status_url")
  githubDeploymentUrl String?  @map("github_deployment_url")
  transient           Boolean?
  production          Boolean?
  branchArtifactId    String?  @map("branch_artifact_id") @db.Uuid

  artifact       Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  branchArtifact Artifact? @relation("DeploymentOfBranch", fields: [branchArtifactId], references: [id], onDelete: SetNull)

  @@index([branchArtifactId])
  @@index([ref, sha])
  @@map("deployment_detail")
}

// Replacement for polymorphic `EntityLink` with real FKs. Rows for
// DOCUMENT↔DOCUMENT links are backfilled in 2A; PR/Deployment links are
// added in 2B. Legacy `entity_links` table continues to coexist until 2F.
model ArtifactLink {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sourceId       String   @map("source_id") @db.Uuid
  targetId       String   @map("target_id") @db.Uuid
  linkType       LinkType @map("link_type")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  source Artifact @relation("ArtifactLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Artifact @relation("ArtifactLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([organizationId, sourceId, linkType])
  @@index([organizationId, targetId, linkType])
  @@map("artifact_links")
}

model ArtifactEvaluation {
  id             String               @id @default(uuid(7)) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  artifactId     String               @map("artifact_id") @db.Uuid
  loopId         String?              @map("loop_id") @db.Uuid
  reportType     EvaluationReportType @map("report_type")
  reportId       String               @map("report_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  artifact         Artifact          @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  loop             Loop?             @relation(fields: [loopId], references: [id], onDelete: SetNull)
  judgeScores      JudgeScore[]
  judgeHumanScores JudgeHumanScore[]

  @@unique([artifactId, reportId])
  @@index([artifactId, createdAt])
  @@index([organizationId, createdAt])
  @@map("artifact_evaluations")
}

model JudgeScore {
  id            String     @id @default(uuid(7)) @db.Uuid
  evaluationId  String     @map("evaluation_id") @db.Uuid
  promptId      String?    @map("prompt_id") @db.Uuid
  caseId        String     @map("case_id")
  metricName    String     @map("metric_name")
  threshold     Float
  score         Float
  justification String     @map("justification") @db.Text
  finalStatus   EvalStatus @map("final_status")
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  evaluation       ArtifactEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  prompt           Prompt?            @relation(fields: [promptId], references: [id], onDelete: SetNull)
  judgeHumanScores JudgeHumanScore[]

  @@unique([evaluationId, caseId, metricName])
  @@index([promptId])
  @@map("judge_scores")
}

model JudgeHumanScore {
  id             String   @id @default(uuid(7)) @db.Uuid
  // Denormalized from judgeScore.evaluationId for query performance.
  evaluationId   String   @map("evaluation_id") @db.Uuid
  judgeScoreId   String   @map("judge_score_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  score          Float
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  evaluation   ArtifactEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  judgeScore   JudgeScore         @relation(fields: [judgeScoreId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([judgeScoreId, userId, organizationId])
  @@index([evaluationId])
  @@index([organizationId, userId])
  @@map("judge_human_scores")
}

// Consolidated ratings for any artifact. Absorbs the prior DocumentRating
// and PullRequestRating tables — both now live at @@map("artifact_ratings").
// `artifactVersion` is nullable because PR/deployment ratings aren't
// version-scoped; document ratings keep it populated.
model ArtifactRating {
  id              String   @id @default(uuid(7)) @map("id") @db.Uuid
  artifactId      String   @map("artifact_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  // Score validation (1-5) enforced at API layer via Zod schema.
  score           Int
  comment         String?  @db.VarChar(500)
  artifactVersion Int?     @map("artifact_version")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  artifact     Artifact     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([artifactId, userId, organizationId])
  @@index([artifactId, organizationId])
  @@map("artifact_ratings")
}

model FileAttachment {
  id          String   @id @default(uuid(7)) @db.Uuid
  artifactId  String?  @map("artifact_id") @db.Uuid
  bucket      String
  key         String
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  purpose     String   @default("context")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String   @map("created_by_id") @db.Uuid

  // Relations
  artifact Artifact? @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([artifactId])
  @@index([artifactId, purpose])
  // Serves the attachment reconcile sweep's `(bucket, key IN (...))` orphan
  // lookup, run once per list page over the whole table. Without it that lookup
  // is a seq-scan that grows unbounded with the table.
  @@index([bucket, key])
  @@map("file_attachments")
}

