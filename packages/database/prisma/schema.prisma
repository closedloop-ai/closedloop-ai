  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  pullRequestDetail PullRequestDetail @relation(fields: [pullRequestId], references: [artifactId], onDelete: Cascade)

  @@index([pullRequestId, state])
  @@map("github_pr_review_comments")
}

model GitHubPRReview {
  id              String         @id @default(uuid(7)) @db.Uuid
  pullRequestId   String         @map("pull_request_id") @db.Uuid
  githubReviewId  String         @unique @map("github_review_id")
