  body            String?        @db.Text
  htmlUrl         String         @map("html_url")
  submittedAt     DateTime       @map("submitted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  pullRequestDetail PullRequestDetail @relation(fields: [pullRequestId], references: [artifactId], onDelete: Cascade)

  @@unique([pullRequestId, authorLogin])
  @@map("github_pr_reviews")
}

model GitHubActionRun {
  id           String             @id @default(uuid(7)) @db.Uuid
  workstreamId String             @map("workstream_id") @db.Uuid
  repositoryId String             @map("repository_id") @db.Uuid
  runId        String?            @map("run_id")
  workflowName String             @map("workflow_name")
  status       GitHubActionStatus @default(PENDING)
  conclusion   String?
  htmlUrl      String             @map("html_url")
  triggerEvent String             @map("trigger_event")
  triggerData  Json?              @map("trigger_data")
  sessionId    String?            @map("session_id")
  jobType      String?            @map("job_type")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
