// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Feature blocks Feature)
  RELATES_TO // bidirectional association (Feature ↔ Feature)
}

// Advisory only — not bound to any column (Artifact.status is a freeform
// String). Documents are PRD/IMPLEMENTATION_PLAN/TEMPLATE subtypes; their
// authoring/approval lifecycle. SSOT: @closedloop-ai/loops-api/document. PRD-495.
enum DocumentStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  EXECUTED
  OBSOLETE
}

// Advisory only — not bound to any column. Features (subtype = FEATURE); their
// delivery / issue-tracker lifecycle. SSOT: @closedloop-ai/loops-api/document.
enum FeatureStatus {
  TRIAGE
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELED
}

enum EvaluationReportType {
  PLAN
  CODE
  PRD
  FEATURE
}

enum EvalStatus {
  FAILED
  NEEDS_IMPROVEMENT
  PASSED
}

enum PromptType {
  AGENT
  JUDGE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum ChecksStatus {
  UNKNOWN
  PENDING
  PASSING
  FAILING
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

// Distinguishes manually created API keys from desktop-managed bootstrap keys.
enum ApiKeySource {
  USER_CREATED
  DESKTOP_MANAGED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LoopStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
  // Deferred at dispatch because a linked blocking artifact is still
  // non-terminal. Re-evaluated by the loop reconciliation cron, which
  // transitions BLOCKED -> PENDING once every blocker resolves. Non-claimable
  // (the orchestrator only claims PENDING loops) and non-terminal.
  BLOCKED
}

enum LoopCommand {
  PLAN
  EXECUTE
  CHAT
  EXPLORE
  REQUEST_CHANGES
  DECOMPOSE
  EVALUATE_PRD
  GENERATE_PRD
  EVALUATE_PLAN
  EVALUATE_CODE
  REQUEST_PRD_CHANGES
  BOOTSTRAP
  MANUAL
  EVALUATE_FEATURE
}

// Discriminates how a SessionDetail row was produced: a synced desktop agent
// run (DESKTOP_SYNC) vs. a materialized orchestration Loop (LOOP). Lets the
// unified Sessions list tell the two apart. See FEA-1718 / PLN-921.
enum SessionOrigin {
  DESKTOP_SYNC
  LOOP
}

enum CustomFieldType {
  TEXT
  NUMBER
  ENUM
  MULTI_ENUM
  DATE
  PEOPLE
}

enum CustomFieldEntityType {
  PROJECT
  DOCUMENT
}

enum NumberFormat {
  NONE
  CURRENCY
  PERCENTAGE
  CUSTOM
}

enum LabelPosition {
  PREFIX
  SUFFIX
}

enum ThreadSource {
  NATIVE
  LIVEBLOCKS
  GITHUB
}

enum ThreadStatus {
  OPEN
  RESOLVED
}

enum ExternalCommentProvider {
  GITHUB
}

enum GitHubCommentThreadKind {
  REVIEW_THREAD
  ISSUE_COMMENT
}

enum GitHubDiffSide {
  LEFT
  RIGHT
}

enum GitHubLegacyCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum PreferredComputeMode {
  LOCAL
  CLOUD
}

// Kinds of first-class artifacts tracked in the `artifacts` parent table.
// Added in Chunk 2a of PLN-321 alongside the Artifact/DocumentDetail models.
enum ArtifactType {
  DOCUMENT
  BRANCH
  DEPLOYMENT
  SESSION
}

// Narrower classification for DOCUMENT-typed artifacts (carries values that
// used to live on the legacy DocumentType enum). Null for PRs and deployments.
enum ArtifactSubtype {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE
  FEATURE
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model PreviewSchemaObservation {
  schemaName      String   @id @map("schema_name")
  firstObservedAt DateTime @default(now()) @map("first_observed_at") @db.Timestamptz

  @@map("preview_schemas_observations")
}

model Organization {
  id                    String    @id @default(uuid(7)) @db.Uuid
  clerkId               String    @unique @map("clerk_id")
  active                Boolean   @default(true) @map("active")
  name                  String
  slug                  String    @unique
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  settings              Json      @default("{}") // settings.computeMode deprecated -- use User.preferredComputeMode instead
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  users                     User[]
  teams                     Team[]
  artifactRatings           ArtifactRating[]
  projects                  Project[]
  artifacts                 Artifact[]
  githubInstallation        GitHubInstallation?
  loops                     Loop[]
  prompts                   Prompt[]
  computeTargets            ComputeTarget[]
  computeTargetHealthChecks ComputeTargetHealthCheck[]
  sessionTranscripts        SessionTranscript[]
  chatSessions              ChatSession[]
  judgeHumanScores          JudgeHumanScore[]
  customFields              CustomField[]
  commentThreads            CommentThread[]
  agents                    Agent[]
  repoBootstrapConfigs      RepoBootstrapConfig[]
  userPublicKeys            UserPublicKey[]
  agentComponents           AgentComponent[]
  catalogItems              CatalogItem[]
  distributions             Distribution[]
  publicRepositories        PublicRepository[]
  externalCommentAuthors    ExternalCommentAuthor[]
  githubUserConnections     GitHubUserConnection[]
  tags                      Tag[]
  linearSubtasks            LinearSubtask[]
  desktopSessions           DesktopSession[]
  githubDirtyScopeNudges    GitHubDirtyScopeNudge[]
  branchDetails             BranchDetail[]
  pullRequestDetails        PullRequestDetail[]
  commitDetails             CommitDetail[]

  @@map("organizations")
}

model User {
  id                       String                @id @default(uuid(7)) @db.Uuid
  clerkId                  String                @map("clerk_id")
  organizationId           String                @map("organization_id") @db.Uuid
  active                   Boolean               @default(true) @map("active")
  email                    String
  firstName                String?               @map("first_name")
  lastName                 String?               @map("last_name")
  avatarUrl                String?               @map("avatar_url")
  phoneNumber              String?               @map("phone_number")
  role                     ApproverRole          @default(ENGINEER)
  linearId                 String?               @map("linear_id")
  slackId                  String?               @map("slack_id")
  githubUsername           String?               @map("github_username")
  claudeApiKeyEncrypted    String?               @map("claude_api_key_encrypted")
  claudeApiKeyLastFour     String?               @map("claude_api_key_last_four")
  claudeApiKeySetAt        DateTime?             @map("claude_api_key_set_at")
  preferredComputeMode     PreferredComputeMode? @map("preferred_compute_mode")
  preferredComputeTargetId String?               @map("preferred_compute_target_id") @db.Uuid
  preferredHarness         String?               @map("preferred_harness")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  // Relations
  organization                Organization                        @relation(fields: [organizationId], references: [id])
  preferredComputeTarget      ComputeTarget?                      @relation("UserPreferredComputeTarget", fields: [preferredComputeTargetId], references: [id])
  teamMemberships             TeamMember[]
  artifactRatings             ArtifactRating[]
  favoriteProjects            FavoriteProject[]
  favoriteArtifacts           FavoriteArtifact[]
  assignedProjects            Project[]                           @relation("ProjectAssignee")
  createdProjects             Project[]                           @relation("ProjectCreatedBy")
  assignedArtifacts           Artifact[]                          @relation("ArtifactAssignee")
  createdArtifacts            Artifact[]                          @relation("ArtifactCreatedBy")
  approvedDocumentDetails     DocumentDetail[]                    @relation("DocumentDetailApprover")
  loops                       Loop[]
  computeTargets              ComputeTarget[]
  sessionDetails              SessionDetail[]
  chatSessions                ChatSession[]
  judgeHumanScores            JudgeHumanScore[]
  createdCustomFields         CustomField[]
  updatedCustomFieldValues    CustomFieldValue[]
  dismissedGenerationStatuses DocumentGenerationStatusDismissal[]
  createdAgents               Agent[]                             @relation("AgentCreatedBy")
  agentVersionChanges         AgentVersion[]                      @relation("AgentVersionChangedBy")
  publicKeys                  UserPublicKey[]
  externalCommentAuthors      ExternalCommentAuthor[]
  githubUserConnections       GitHubUserConnection[]
  createdTags                 Tag[]                               @relation("TagCreatedBy")
  desktopSessions             DesktopSession[]
  createdCatalogItems         CatalogItem[]                       @relation("CatalogItemCreatedBy")
  changedCatalogItemVersions  CatalogItemVersion[]                @relation("CatalogItemVersionChangedBy")
  createdDistributions        Distribution[]                      @relation("DistributionCreatedBy")
  distributionTargetStatuses  DistributionTargetStatus[]          @relation("DistributionTargetStatusUser")

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model UserPublicKey {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  publicKeyBase64 String   @map("public_key_base64")
  fingerprint     String
  createdAt       DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([organizationId])
  @@map("user_public_keys")
}

model ComputeTarget {
  id                     String    @id @default(uuid(7)) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  machineName            String    @map("machine_name")
  platform               String
  capabilities           Json      @default("{}")
  supportedOperations    Json      @default("[]") @map("supported_operations")
  lastSeenAt             DateTime  @default(now()) @map("last_seen_at")
  lastAgentSessionSyncAt DateTime? @map("last_agent_session_sync_at")
  isOnline               Boolean   @default(false) @map("is_online")
  isSharedWithOrg        Boolean   @default(false) @map("is_shared_with_org")
  // FEA-2923 (Gap A): marks a synthetic per-org "cloud" compute target that
  // owns cloud-authored AgentComponent rows (org-custom agents backfilled from
  // catalog_items). These rows have NO real device. The sentinel keeps
  // AgentComponent.computeTargetId a non-null FK without a nullable-FK ripple
  // through desktop sync / listing / analytics, and its distinct id guarantees
  // device sync upserts (keyed by the real device computeTargetId) never
  // collide with cloud rows. Device-facing listings filter it out
  // (isCloudSentinel = false). See migration
  // 20260712000000_add_compute_target_cloud_sentinel_and_backfill_agent_components.
  isCloudSentinel        Boolean   @default(false) @map("is_cloud_sentinel")
  gatewayId              String?   @map("gateway_id")
  selectedHarness        String    @default("claude") @map("selected_harness")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  user                                User                                 @relation(fields: [userId], references: [id])
  preferringUsers                     User[]                               @relation("UserPreferredComputeTarget")
  desktopCommands                     DesktopCommand[]
  loopExecutionCredentialConsumptions LoopExecutionCredentialConsumption[]
  loops                               Loop[]
  sessionDetails                      SessionDetail[]
  sessionTranscripts                  SessionTranscript[]
  githubDirtyScopeNudges              GitHubDirtyScopeNudge[]
  healthCheck                         ComputeTargetHealthCheck?
  agentComponents                     AgentComponent[]
  distributionTargetStatuses          DistributionTargetStatus[]
  distributionTargetingEntries        DistributionTargetingEntry[]

  @@unique([userId, machineName])
  @@index([organizationId, userId])
  // NOTE: A partial unique index on gateway_id WHERE gateway_id IS NOT NULL is
  // maintained via raw migration. Prisma cannot express partial indexes. Do NOT
  // add @@unique([gatewayId]) here; it would reject multiple NULL rows.
  // See migration: add_compute_targets_gateway_id_unique
  @@index([organizationId, userId, gatewayId])
  @@index([userId, isOnline])
  @@index([organizationId, isSharedWithOrg])
  @@map("compute_targets")
}

model ComputeTargetHealthCheck {
  id                      String   @id @default(uuid(7)) @db.Uuid
  organizationId          String   @map("organization_id") @db.Uuid
  computeTargetId         String   @unique @map("compute_target_id") @db.Uuid
  checkedAt               DateTime @map("checked_at")
  expectedMcpUrl          String?  @map("expected_mcp_url")
  latestVersion           String?  @map("latest_version")
  pluginAutoUpdateEnabled Boolean  @default(false) @map("plugin_auto_update_enabled")
  result                  Json
  allRequiredPassed       Boolean  @map("all_required_passed")
  requiredFailureIds      Json     @default("[]") @map("required_failure_ids")
  schemaVersion           Int      @default(1) @map("schema_version")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  computeTarget ComputeTarget @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)

  @@index([organizationId, checkedAt])
  @@map("compute_target_health_checks")
}

// Type-specific detail for SESSION-typed artifacts (captured agent/session
// runs synced from the desktop). 1:1 with `Artifact` via shared `artifact_id`
// primary key, mirroring document_detail / branch_detail / deployment_detail.
// Hoisted to the parent `artifacts` row: organizationId, projectId, name,
// status. The raw harness status string is stored on `artifacts.status`
// (free-form TEXT) — the curated session lifecycle is a deferred follow-up.
model SessionDetail {
  artifactId         String        @id @map("artifact_id") @db.Uuid
  // Session owner. Nullable + SetNull so a session survives its creator's
  // deletion as an org-owned artifact (matches assignee_id/created_by_id).
  userId             String?       @map("user_id") @db.Uuid
  computeTargetId    String        @map("compute_target_id") @db.Uuid
  externalSessionId  String        @map("external_session_id")
  harness            String        @default("unknown")
  // How this session row was produced: synced desktop run vs. materialized Loop
  // (FEA-1718). Existing rows default to DESKTOP_SYNC.
  origin             SessionOrigin @default(DESKTOP_SYNC)
  // Per-session billing mode resolved by the desktop (subscription vs. API-key
  // plan, from the desktop's billing_mode column). Opaque string; the usage
  // cost split classifies it for DESKTOP_SYNC sessions that have no source Loop.
  billingMode        String?       @map("billing_mode")
  cwd                String?
  repositoryFullName String?       @map("repository_full_name")
  worktreePath       String?       @map("worktree_path")
  model              String?
  deviceTimeZone     String?       @map("device_time_zone")
  sessionStartedAt   DateTime      @map("session_started_at")
  sessionUpdatedAt   DateTime      @map("session_updated_at")
  // Genuine-activity timestamp: MAX(agent_session_events.event_created_at)
  // floored at sessionStartedAt. Unlike sessionUpdatedAt (bumped by desktop
  // OTEL ingest / enrichment / sync bookkeeping) this advances only on real
  // agent activity, and is the default sort for the Sessions list. Nullable for
  // pre-backfill rows; readers fall back to sessionStartedAt.
  lastActivityAt     DateTime?     @map("last_activity_at")
  sessionEndedAt     DateTime?     @map("session_ended_at")
  awaitingInputSince DateTime?     @map("awaiting_input_since")
  sourceArtifactId   String?       @map("source_artifact_id")
  sourceLoopId       String?       @map("source_loop_id")
  baseBranch         String?       @map("base_branch")
  state              String?
  branch             String?
  pullRequests       Json?         @map("pull_requests")
  wallClock          String?       @map("wall_clock")
  activeAgent        String?       @map("active_agent")
  waitingUser        String?       @map("waiting_user")
  linesAdded         Int?          @map("lines_added")
  linesRemoved       Int?          @map("lines_removed")
  filesChanged       Int?          @map("files_changed")
  // Provenance of the lines_*/files_changed scalars: "git" when the desktop
  // sent source-tagged gitDiffStats, null when only heuristic/agent-estimated
  // scalars were synced. Readers rehydrate gitDiffStats from this marker.
  locSource          String?       @map("loc_source")
  // Branch-level LOC (working-branch changes vs the author's contributed lines):
  // a distinct metric from the authored gitDiffStats scalars, so it lives in its
  // own columns. Readers rehydrate branchDiffStats from these; branch_loc_source
  // records its provenance independently of loc_source.
  branchLinesAdded   Int?          @map("branch_lines_added")
  branchLinesRemoved Int?          @map("branch_lines_removed")
  branchFilesChanged Int?          @map("branch_files_changed")
  branchLocSource    String?       @map("branch_loc_source")
  turns              Int?
  steeringEpisodes   Int?          @map("steering_episodes")
  autonomy           Int?
  activityBuckets    Json?         @map("activity_buckets")
  sessionSpan        Json?         @map("session_span")
  markers            Json?
  throttles          Json?
  tracePhaseSources  Json?         @map("trace_phase_sources")
  throttleSources    Json?         @map("throttle_sources")
  correctionSources  Json?         @map("correction_sources")
  phases             Json?
  phaseIterations    Json?         @map("phase_iterations")
  phaseLoopbacks     Json?         @map("phase_loopbacks")
  inputTokens        BigInt        @default(0) @map("input_tokens")
  outputTokens       BigInt        @default(0) @map("output_tokens")
  cacheReadTokens    BigInt        @default(0) @map("cache_read_tokens")
  cacheWriteTokens   BigInt        @default(0) @map("cache_write_tokens")
  estimatedCost      Decimal       @default(0) @map("estimated_cost") @db.Decimal(14, 6)
  agentCount         Int           @default(0) @map("agent_count")
  toolUseCount       Int           @default(0) @map("tool_use_count")
  errorCount         Int           @default(0) @map("error_count")
  metadata           Json?
  agents             Json          @default("[]")
  dataRevision       Int?          @map("data_revision")
  lastSyncedAt       DateTime      @default(now()) @map("last_synced_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  artifact           Artifact                         @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  user               User?                            @relation(fields: [userId], references: [id], onDelete: SetNull)
  computeTarget      ComputeTarget                    @relation(fields: [computeTargetId], references: [id], onDelete: Restrict)
  tokenUsageByModel  AgentSessionTokenUsage[]
  events             AgentSessionEvent[]
  tokenEvents        AgentSessionTokenEvent[]
  usageRollup        AgentSessionUsageRollup?
  sessionTranscripts SessionTranscript[]
  componentUsages    AgentComponentSessionUsage[]

  @@unique([computeTargetId, externalSessionId])
  @@index([sessionStartedAt])
  @@index([userId, sessionStartedAt])
  @@index([harness, sessionStartedAt])
  @@index([computeTargetId, sessionUpdatedAt])
  @@index([computeTargetId, lastActivityAt])
  @@index([lastActivityAt])
  @@index([repositoryFullName])
  // Sessions-list autonomy-tier and cost-bucket facets filter these columns with
  // range predicates (gte/lt), unlike the equality-based harness facet. A range
  // predicate can't share a composite index with the lastActivityAt sort column
  // (the range breaks the ordering), so single-column indexes on each filtered
  // column are the useful shape — mirroring the single-column repositoryFullName
  // facet index. autonomy is nullable ("unknown" tier = IS NULL). (FEA-2504)
  @@index([autonomy])
  @@index([estimatedCost])
  @@map("session_detail")
}

/// Cloud-side metadata for a raw session transcript archived to S3 (FEA-2714).
/// One row per transcript FILE: a logical session owns one `main` transcript
/// plus zero or more `subagent:{fileId}` sidechain files, discriminated by
/// `fileKey`. Metadata only — transcript bytes live in the S3 transcripts
/// bucket and never transit apps/api (PLN-1285 decision 2).
model SessionTranscript {
  id                     String    @id @default(uuid(7)) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  computeTargetId        String    @map("compute_target_id") @db.Uuid
  externalSessionId      String    @map("external_session_id")
  // Resolved from (computeTargetId, externalSessionId); nullable because a
  // transcript can arrive before the metadata lane creates the SessionDetail
  // row. FK targets SessionDetail.artifactId (its primary key). Subagent rows
  // share the parent session's sessionDetailId. Both routes attempt resolution
  // while unset.
  sessionDetailId        String?   @map("session_detail_id") @db.Uuid
  // Harness that produced the transcript: `claude_code`, `codex`, …
  sourceHarness          String    @map("source_harness")
  // `main` for the session transcript, `subagent:{fileId}` for sidechain files.
  fileKey                String    @map("file_key")
  objectStorageKey       String    @map("object_storage_key")
  // pending | uploading | uploaded | failed
  uploadStatus           String    @default("pending") @map("upload_status")
  // Archive identity (client-computed sha256); set once verified on complete.
  rawSha256              String?   @map("raw_sha256")
  // S3-verified full-object CRC64NVME checksum; set on complete.
  crc64nvme              String?   @map("crc64nvme")
  rawByteSize            BigInt?   @map("raw_byte_size")
  // Current-version ETag, used as If-Match on the next copy-append.
  storedEtag             String?   @map("stored_etag")
  // Last VERIFIED byte offset — advances only on a successful complete
  // (recovery invariant 1). Clients recompute their delta from this.
  syncedByteOffset       BigInt    @default(0) @map("synced_byte_offset")
  sourceMtime            DateTime? @map("source_mtime")
  // Hash of the local file path — no raw local paths in cloud (PRD security req).
  sourcePathHash         String?   @map("source_path_hash")
  // In-flight multipart upload id + start time, for resume and staleness abort.
  pendingUploadId        String?   @map("pending_upload_id")
  pendingUploadStartedAt DateTime? @map("pending_upload_started_at")
  firstSeenAt            DateTime  @default(now()) @map("first_seen_at")
  lastObservedAt         DateTime  @default(now()) @map("last_observed_at")
  uploadedAt             DateTime? @map("uploaded_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  computeTarget ComputeTarget  @relation(fields: [computeTargetId], references: [id], onDelete: Restrict)
  sessionDetail SessionDetail? @relation(fields: [sessionDetailId], references: [artifactId], onDelete: SetNull)

  // Session identity (matches SessionDetail) plus the per-file discriminator.
  @@unique([computeTargetId, externalSessionId, fileKey])
  @@index([organizationId])
  @@index([sessionDetailId])
  @@map("session_transcript")
}

// FEA-2718: conversation turn text left the database. The `summary` and `data`
// columns (turn/tool content) were dropped — the cloud transcript archive
// (FEA-2717) is the sole source of turn/tool detail. Only columnar metadata
// used by the timeline/markers/analytics remains here.
model AgentSessionEvent {
  id              String   @id @default(uuid(7)) @db.Uuid
  agentSessionId  String   @map("agent_session_id") @db.Uuid
  externalEventId String   @map("external_event_id")
  agentExternalId String?  @map("agent_external_id")
  eventType       String   @map("event_type")
  toolName        String?  @map("tool_name")
  eventCreatedAt  DateTime @map("event_created_at")
  createdAt       DateTime @default(now()) @map("created_at")

  session SessionDetail @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)

  @@unique([agentSessionId, externalEventId])
  @@index([agentSessionId, eventCreatedAt])
  @@map("agent_session_events")
}

model AgentSessionTokenUsage {
  id               String   @id @default(uuid(7)) @db.Uuid
  agentSessionId   String   @map("agent_session_id") @db.Uuid
  model            String
  inputTokens      BigInt   @default(0) @map("input_tokens")
  outputTokens     BigInt   @default(0) @map("output_tokens")
  cacheReadTokens  BigInt   @default(0) @map("cache_read_tokens")
  cacheWriteTokens BigInt   @default(0) @map("cache_write_tokens")
  estimatedCost    Decimal  @default(0) @map("estimated_cost") @db.Decimal(14, 6)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  session SessionDetail @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)

  @@unique([agentSessionId, model])
  @@index([model])
  @@map("agent_session_token_usage")
}

/// FEA-2730 (PRD-510 FR4 G1): raw per-event token usage synced from the
/// desktop's keep-all `token_events` log (retention/rollup deferred, Q3).
/// Append-only and idempotent: the desktop source table has no primary key, so
/// `externalEventId` is a content hash the desktop synthesizes per row (mirrors
/// the SessionActivitySegment.id precedent), and the
/// `@@unique([agentSessionId, externalEventId])` + createMany(skipDuplicates)
/// makes re-sync a no-op.
///
/// D4 (PRD-510) decision — this table is JOIN-REACHED, so it carries NO
/// `organizationId` and no org-wide index. Org isolation is enforced through the
/// `session → artifact.organizationId` relation, exactly as its sibling
/// `AgentSessionTokenUsage` already is; every cloud read enters through a
/// SessionDetail join (getSessionTokenEvents, the insights/usage aggregations).
/// `SessionDetail` itself has no `organizationId` (org lives on the parent
/// `Artifact`). The `[agentSessionId, eventCreatedAt]` index covers the
/// per-session, optionally date-bounded focus-page reads. Revisit only if a
/// future read must scan token events org-wide WITHOUT entering through
/// SessionDetail (e.g. "every token event for the org in a time window") — that
/// would justify adding `organizationId` + an `[organizationId, eventCreatedAt]`
/// index in a follow-up migration. No such read exists today.
model AgentSessionTokenEvent {
  id               String   @id @default(uuid(7)) @db.Uuid
  agentSessionId   String   @map("agent_session_id") @db.Uuid
  externalEventId  String   @map("external_event_id")
  agentExternalId  String?  @map("agent_external_id")
  model            String
  inputTokens      BigInt   @default(0) @map("input_tokens")
  outputTokens     BigInt   @default(0) @map("output_tokens")
  cacheReadTokens  BigInt   @default(0) @map("cache_read_tokens")
  cacheWriteTokens BigInt   @default(0) @map("cache_write_tokens")
  estimatedCost    Decimal  @default(0) @map("estimated_cost") @db.Decimal(14, 6)
  eventCreatedAt   DateTime @map("event_created_at")
  createdAt        DateTime @default(now()) @map("created_at")

  session SessionDetail @relation(fields: [agentSessionId], references: [artifactId], onDelete: Cascade)

  @@unique([agentSessionId, externalEventId])
  @@index([agentSessionId, eventCreatedAt])
  @@map("agent_session_token_events")
}

/// FEA-2730 (PRD-510 FR4 G10): the desktop's one-row-per-session usage rollup
/// (source table `session_analytics`), synced as-is and authoritative (Q16). 1:1
/// with SessionDetail — the PK IS the session's artifact id, so re-sync upserts
/// in place. Token columns are widened to BigInt and cost to Decimal(14,6) for
/// numeric fidelity (FEA-2728), though the desktop rollup stores them narrower;
/// `isHuman` is a boolean cloud-side (0/1 on the desktop). No `organizationId`
/// (join-reached via the session, per the D4 decision on AgentSessionTokenEvent
/// above). Named `UsageRollup` rather than `Analytics` to avoid colliding with
/// the unrelated org-wide `AgentSessionAnalytics` viewer-analytics API type.
model AgentSessionUsageRollup {
  artifactId       String    @id @map("artifact_id") @db.Uuid
  startedAt        DateTime? @map("started_at")
  startedDay       String?   @map("started_day")
  status           String?
  harness          String?
  isHuman          Boolean   @default(false) @map("is_human")
  humanTurns       Int       @default(0) @map("human_turns")
  agentTurns       Int       @default(0) @map("agent_turns")
  eventCount       Int       @default(0) @map("event_count")
  toolInvocations  Int       @default(0) @map("tool_invocations")
  errorEvents      Int       @default(0) @map("error_events")
  inputTokens      BigInt    @default(0) @map("input_tokens")
  outputTokens     BigInt    @default(0) @map("output_tokens")
  cacheReadTokens  BigInt    @default(0) @map("cache_read_tokens")
  cacheWriteTokens BigInt    @default(0) @map("cache_write_tokens")
  estimatedCost    Decimal   @default(0) @map("estimated_cost") @db.Decimal(14, 6)
  runtimeMs        BigInt?   @map("runtime_ms")
  // When the desktop last recomputed this rollup (distinct from the cloud's own
  // updatedAt bookkeeping below).
  rollupUpdatedAt  DateTime? @map("rollup_updated_at")
  lastSyncedAt     DateTime  @default(now()) @map("last_synced_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  session SessionDetail @relation(fields: [artifactId], references: [artifactId], onDelete: Cascade)

  @@map("agent_session_usage_rollups")
}

model DesktopCommand {
  id                 String    @id @default(uuid(7)) @db.Uuid
  computeTargetId    String    @map("compute_target_id") @db.Uuid
  idempotencyKey     String?   @map("idempotency_key")
