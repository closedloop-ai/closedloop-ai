// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum WorkstreamType {
  FEATURE_DELIVERY
  BUG_FIX
  TECH_DEBT
  SPIKE
}

enum WorkstreamState {
  INITIATED
  REQUIREMENTS_GENERATING
  REQUIREMENTS_PENDING_APPROVAL
  DESIGN_IN_PROGRESS
  DESIGN_PENDING_APPROVAL
  IMPLEMENTATION_PLANNING
  IMPLEMENTATION_IN_PROGRESS
  IMPLEMENTATION_PENDING_REVIEW
  CODE_REVIEW_RUNNING
  CODE_REVIEW_PENDING_APPROVAL
  VISUAL_QA_RUNNING
  VISUAL_QA_PENDING_APPROVAL
  MERGING
  DEPLOYED
  COMPLETED
  BLOCKED
  CANCELLED
}

// Relationship types between entities (source → target, where source is the origin/cause)
enum LinkType {
  PRODUCES // source produces target (PRD → Plan, Plan → PR, PR → Preview)
  BLOCKS // source blocks target (Feature blocks Feature)
  RELATES_TO // bidirectional association (Feature ↔ Feature)
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  EXECUTED
  DONE
  OBSOLETE
}

enum EvaluationReportType {
  PLAN
  CODE
  PRD
  FEATURE
}

enum EvalStatus {
  FAILED
  NEEDS_IMPROVEMENT
  PASSED
}

enum PromptType {
  AGENT
  JUDGE
}

enum ApproverRole {
  PM
  DESIGNER
  TECH_LEAD
  ENGINEER
  STAKEHOLDER
}

enum WorkstreamEventType {
  STATE_CHANGED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_REJECTED
  REVISION_REQUESTED
  LINEAR_ISSUE_CREATED
  LINEAR_ISSUE_UPDATED
  LINEAR_SUBTASK_CREATED
  GITHUB_PR_CREATED
  GITHUB_PR_MERGED
  GITHUB_PR_CLOSED
  GITHUB_PR_REVIEW_SUBMITTED
  GITHUB_PR_COMMENT_ADDED
  GITHUB_PR_LINKED
  GITHUB_ACTION_TRIGGERED
  GITHUB_ACTION_COMPLETED
  GITHUB_CI_STATUS_CHANGED
  SLACK_NOTIFICATION_SENT
  COMMENT_ADDED
  ASSIGNEE_CHANGED
  BLOCKED
  UNBLOCKED
  LOOP_COMPLETED
}

enum LinearSyncStatus {
  SYNCED
  PENDING
  ERROR
}

enum GitHubPRState {
  OPEN
  MERGED
  CLOSED
}

enum GitHubActionStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
}

enum ChecksStatus {
  UNKNOWN
  PENDING
  PASSING
  FAILING
}

enum ReviewDecision {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  DISMISSED
}

enum PRReviewCommentState {
  PENDING
  ADDRESSED
  DISMISSED
}

enum GitHubInstallationStatus {
  PENDING_CLAIM
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

// Distinguishes manually created API keys from desktop-managed bootstrap keys.
enum ApiKeySource {
  USER_CREATED
  DESKTOP_MANAGED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LoopStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum LoopCommand {
  PLAN
  EXECUTE
  CHAT
  EXPLORE
  REQUEST_CHANGES
  DECOMPOSE
  EVALUATE_PRD
  GENERATE_PRD
  EVALUATE_PLAN
  EVALUATE_CODE
  REQUEST_PRD_CHANGES
  BOOTSTRAP
  MANUAL
  EVALUATE_FEATURE
}

enum CustomFieldType {
  TEXT
  NUMBER
  ENUM
  MULTI_ENUM
  DATE
  PEOPLE
}

enum CustomFieldEntityType {
  PROJECT
  WORKSTREAM
  DOCUMENT
}

enum NumberFormat {
  NONE
  CURRENCY
  PERCENTAGE
  CUSTOM
}

enum LabelPosition {
  PREFIX
  SUFFIX
}

enum ThreadSource {
  NATIVE
  LIVEBLOCKS
}

enum ThreadStatus {
  OPEN
  RESOLVED
}

enum PreferredComputeMode {
  LOCAL
  CLOUD
}

// Kinds of first-class artifacts tracked in the `artifacts` parent table.
// Added in Chunk 2a of PLN-321 alongside the Artifact/DocumentDetail models.
enum ArtifactType {
  DOCUMENT
  PULL_REQUEST
  DEPLOYMENT
}

// Narrower classification for DOCUMENT-typed artifacts (carries values that
// used to live on the legacy DocumentType enum). Null for PRs and deployments.
enum ArtifactSubtype {
  PRD
  IMPLEMENTATION_PLAN
  TEMPLATE
  FEATURE
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

model PreviewSchema {
  schemaName String   @id @map("schema_name")
  branch     String?
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  @@map("preview_schemas")
}

model Organization {
  id                    String    @id @default(uuid(7)) @db.Uuid
  clerkId               String    @unique @map("clerk_id")
  active                Boolean   @default(true) @map("active")
  name                  String
  slug                  String    @unique
  claudeApiKeyEncrypted String?   @map("claude_api_key_encrypted")
  claudeApiKeyLastFour  String?   @map("claude_api_key_last_four")
  claudeApiKeySetAt     DateTime? @map("claude_api_key_set_at")
  settings              Json      @default("{}") // settings.computeMode deprecated -- use User.preferredComputeMode instead
  publicDashboardToken  String?   @unique @map("public_dashboard_token")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  users                     User[]
  teams                     Team[]
  artifactRatings           ArtifactRating[]
  projects                  Project[]
  workstreams               Workstream[]
  artifacts                 Artifact[]
  githubInstallation        GitHubInstallation?
  loops                     Loop[]
  prompts                   Prompt[]
  computeTargets            ComputeTarget[]
  computeTargetHealthChecks ComputeTargetHealthCheck[]
  chatSessions              ChatSession[]
  judgeHumanScores          JudgeHumanScore[]
  customFields              CustomField[]
  commentThreads            CommentThread[]
  agents                    Agent[]
  repoBootstrapConfigs      RepoBootstrapConfig[]
  userPublicKeys            UserPublicKey[]

  @@map("organizations")
}

model User {
  id                       String                @id @default(uuid(7)) @db.Uuid
  clerkId                  String                @map("clerk_id")
  organizationId           String                @map("organization_id") @db.Uuid
  active                   Boolean               @default(true) @map("active")
  email                    String
  firstName                String?               @map("first_name")
  lastName                 String?               @map("last_name")
  avatarUrl                String?               @map("avatar_url")
  phoneNumber              String?               @map("phone_number")
  role                     ApproverRole          @default(ENGINEER)
  linearId                 String?               @map("linear_id")
  slackId                  String?               @map("slack_id")
  githubUsername           String?               @map("github_username")
  claudeApiKeyEncrypted    String?               @map("claude_api_key_encrypted")
  claudeApiKeyLastFour     String?               @map("claude_api_key_last_four")
  claudeApiKeySetAt        DateTime?             @map("claude_api_key_set_at")
  preferredComputeMode     PreferredComputeMode? @map("preferred_compute_mode")
  preferredComputeTargetId String?               @map("preferred_compute_target_id") @db.Uuid
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  // Relations
  organization                Organization                        @relation(fields: [organizationId], references: [id])
  preferredComputeTarget      ComputeTarget?                      @relation("UserPreferredComputeTarget", fields: [preferredComputeTargetId], references: [id])
  teamMemberships             TeamMember[]
  artifactRatings             ArtifactRating[]
  favoriteProjects            FavoriteProject[]
  assignedProjects            Project[]                           @relation("ProjectAssignee")
  createdProjects             Project[]                           @relation("ProjectCreatedBy")
  assignedArtifacts           Artifact[]                          @relation("ArtifactAssignee")
  createdArtifacts            Artifact[]                          @relation("ArtifactCreatedBy")
  approvedDocumentDetails     DocumentDetail[]                    @relation("DocumentDetailApprover")
  createdWorkstreams          Workstream[]                        @relation("WorkstreamCreatedBy")
  assignedWorkstreams         Workstream[]                        @relation("WorkstreamAssignee")
  loops                       Loop[]
  computeTargets              ComputeTarget[]
  chatSessions                ChatSession[]
  judgeHumanScores            JudgeHumanScore[]
  createdCustomFields         CustomField[]
  updatedCustomFieldValues    CustomFieldValue[]
  dismissedGenerationStatuses DocumentGenerationStatusDismissal[]
  createdAgents               Agent[]                             @relation("AgentCreatedBy")
  agentVersionChanges         AgentVersion[]                      @relation("AgentVersionChangedBy")
  publicKeys                  UserPublicKey[]

  @@unique([organizationId, email])
  @@unique([clerkId, organizationId])
  @@index([clerkId])
  @@index([linearId])
  @@index([slackId])
  @@index([githubUsername])
  @@map("users")
}

model UserPublicKey {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  publicKeyBase64 String   @map("public_key_base64")
  fingerprint     String
  createdAt       DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([organizationId])
  @@map("user_public_keys")
}

model ComputeTarget {
  id                  String   @id @default(uuid(7)) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  machineName         String   @map("machine_name")
  platform            String
  capabilities        Json     @default("{}")
  supportedOperations Json     @default("[]") @map("supported_operations")
  lastSeenAt          DateTime @default(now()) @map("last_seen_at")
  isOnline            Boolean  @default(false) @map("is_online")
  isSharedWithOrg     Boolean  @default(false) @map("is_shared_with_org")
  gatewayId           String?  @map("gateway_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  user                                User                                 @relation(fields: [userId], references: [id])
  preferringUsers                     User[]                               @relation("UserPreferredComputeTarget")
  desktopCommands                     DesktopCommand[]
  loopExecutionCredentialConsumptions LoopExecutionCredentialConsumption[]
  loops                               Loop[]
  healthCheck                         ComputeTargetHealthCheck?

  @@unique([userId, machineName])
  @@index([organizationId, userId])
  // NOTE: A partial unique index on gateway_id WHERE gateway_id IS NOT NULL is
  // maintained via raw migration. Prisma cannot express partial indexes. Do NOT
  // add @@unique([gatewayId]) here; it would reject multiple NULL rows.
  // See migration: add_compute_targets_gateway_id_unique
  @@index([organizationId, userId, gatewayId])
  @@index([userId, isOnline])
  @@index([organizationId, isSharedWithOrg])
  @@map("compute_targets")
}

model ComputeTargetHealthCheck {
  id                 String   @id @default(uuid(7)) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  computeTargetId    String   @unique @map("compute_target_id") @db.Uuid
  checkedAt          DateTime @map("checked_at")
  expectedMcpUrl     String?  @map("expected_mcp_url")
  latestVersion      String?  @map("latest_version")
  result             Json
  allRequiredPassed  Boolean  @map("all_required_passed")
  requiredFailureIds Json     @default("[]") @map("required_failure_ids")
  schemaVersion      Int      @default(1) @map("schema_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id])
  computeTarget ComputeTarget @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)

  @@index([organizationId, checkedAt])
  @@map("compute_target_health_checks")
}

model DesktopCommand {
  id                 String    @id @default(uuid(7)) @db.Uuid
  computeTargetId    String    @map("compute_target_id") @db.Uuid
  idempotencyKey     String?   @map("idempotency_key")
  requestFingerprint String    @map("request_fingerprint")
  operationId        String    @map("operation_id")
  requestPayload     Json      @map("request_payload")
  status             String
  error              String?
  lastSequenceAcked  Int       @default(0) @map("last_sequence_acked")
  queuedTimeoutMs    Int?      @map("queued_timeout_ms")
  runningTimeoutMs   Int?      @map("running_timeout_ms")
  createdAt          DateTime  @default(now()) @map("created_at")
  startedAt          DateTime? @map("started_at")
  finishedAt         DateTime? @map("finished_at")

  computeTarget                      ComputeTarget                       @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  events                             DesktopCommandEvent[]
  loopExecutionCredentialConsumption LoopExecutionCredentialConsumption?

  // NOTE: A partial unique index on (compute_target_id, idempotency_key) WHERE
  // idempotency_key IS NOT NULL is maintained via raw migrations. Prisma cannot
  // express partial indexes. Prisma 7.4+ falsely flags this as drift — we pin
  // to 7.3.0 until resolved. Do NOT drop it.
  // See: https://github.com/prisma/prisma/issues/29289
  @@index([computeTargetId, status, createdAt])
  @@index([operationId])
  @@map("desktop_commands")
}

model LoopExecutionCredentialConsumption {
  commandId       String   @id @map("command_id") @db.Uuid
  loopId          String   @map("loop_id") @db.Uuid
  computeTargetId String   @map("compute_target_id") @db.Uuid
  gatewayId       String   @map("gateway_id")
  action          String
  consumedAt      DateTime @default(now()) @map("consumed_at")

  command       DesktopCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)
  computeTarget ComputeTarget  @relation(fields: [computeTargetId], references: [id], onDelete: Cascade)
  loop          Loop           @relation(fields: [loopId], references: [id], onDelete: Cascade)

  @@index([loopId])
  @@index([computeTargetId, gatewayId], map: "loop_execution_credential_consumptions_compute_target_id_gatewa")
  @@map("loop_execution_credential_consumptions")
}

model DesktopCommandEvent {
  commandId    String   @map("command_id") @db.Uuid
  sequence     Int
  eventType    String   @map("event_type")
  eventPayload Json     @map("event_payload")
  createdAt    DateTime @default(now()) @map("created_at")

  command DesktopCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@id([commandId, sequence])
  @@map("desktop_command_events")
}

model Project {
  id                  String        @id @default(uuid(7)) @db.Uuid
  organizationId      String        @map("organization_id") @db.Uuid
  name                String
  description         String?
  priority            Priority      @default(MEDIUM)
  status              ProjectStatus @default(NOT_STARTED)
  assigneeId          String?       @map("assignee_id") @db.Uuid
  createdById         String        @map("created_by_id") @db.Uuid
  slug                String?
  targetDate          DateTime?     @map("target_date")
  codebaseSummary     String?       @map("codebase_summary")
  lastIndexedAt       DateTime?     @map("last_indexed_at")
  settings            Json          @default("{}")
  sortOrder           Int?          @map("sort_order")
  isTemplatesSentinel Boolean       @default(false) @map("is_templates_sentinel")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id])
  assignee     User?             @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  createdBy    User              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  workstreams  Workstream[]
  artifacts    Artifact[]
  teams        ProjectTeam[]
  favoritedBy  FavoriteProject[]

  @@unique([organizationId, slug])
  @@index([assigneeId])
  @@index([createdById])
  @@index([organizationId, isTemplatesSentinel])
  @@map("projects")
}

// =============================================================================
// TEAMS
// =============================================================================

model Team {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id])
  members      TeamMember[]
  projects     ProjectTeam[]
  repositories TeamRepository[]

  @@unique([organizationId, slug])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid(7)) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

/// Per-team curated list of GitHub repositories with default-selection and primary designation
model TeamRepository {
  id                       String   @id @default(uuid(7)) @db.Uuid
  teamId                   String   @map("team_id") @db.Uuid
  installationRepositoryId String   @map("installation_repository_id") @db.Uuid
  isDefaultSelected        Boolean  @default(false) @map("is_default_selected")
  isPrimary                Boolean  @default(false) @map("is_primary")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  team       Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  repository GitHubInstallationRepository @relation(fields: [installationRepositoryId], references: [id], onDelete: Cascade)

  @@unique([teamId, installationRepositoryId])
  @@index([installationRepositoryId])
  @@map("team_repositories")
}

/// Many-to-many relationship for projects belonging to multiple teams
model ProjectTeam {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@unique([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

/// Per-user favorite projects for quick access in the sidebar
model FavoriteProject {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("favorite_projects")
}

// =============================================================================
// WORKSTREAM
// =============================================================================

model Workstream {
  id             String          @id @default(uuid(7)) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  title          String
  description    String?
  type           WorkstreamType  @default(FEATURE_DELIVERY)
  state          WorkstreamState @default(INITIATED)
  stateChangedAt DateTime        @default(now()) @map("state_changed_at")
  createdById    String          @map("created_by_id") @db.Uuid
  assigneeId     String?         @map("assigned_to_id") @db.Uuid
  priority       Priority        @default(MEDIUM)
  slug           String?
  hasUIChanges   Boolean         @default(false) @map("has_ui_changes")
  startedAt      DateTime        @default(now()) @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metrics        Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("WorkstreamCreatedBy", fields: [createdById], references: [id])
  assignee     User?        @relation("WorkstreamAssignee", fields: [assigneeId], references: [id])
  artifacts    Artifact[]
  loops        Loop[]

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, state])
  @@index([organizationId, assigneeId])
  @@index([projectId])
  @@map("workstreams")
}

model WorkstreamEvent {
  id           String              @id @default(uuid(7)) @db.Uuid
  workstreamId String              @map("workstream_id") @db.Uuid
  type         WorkstreamEventType
  fromState    WorkstreamState?    @map("from_state")
  toState      WorkstreamState?    @map("to_state")
  actorId      String?             @map("actor_id") @db.Uuid
  actorType    String              @default("system") @map("actor_type")
  data         Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([workstreamId, type])
  @@index([workstreamId, createdAt])
  @@map("workstream_events")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model DocumentGenerationStatusDismissal {
  id            String   @id @default(uuid(7)) @db.Uuid
  artifactId    String   @unique @map("artifact_id") @db.Uuid
  dismissedById String   @map("dismissed_by_id") @db.Uuid
  runKey        String   @map("run_key")
  dismissedAt   DateTime @default(now()) @map("dismissed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  artifact    Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  dismissedBy User     @relation(fields: [dismissedById], references: [id], onDelete: Restrict)

  @@index([dismissedById])
  @@map("artifact_generation_status_dismissals")
}

model DocumentVersion {
  id          String   @id @default(uuid(7)) @db.Uuid
  documentId  String   @map("artifact_id") @db.Uuid
  version     Int
  content     String?  @db.Text
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  documentDetail DocumentDetail @relation(fields: [documentId], references: [artifactId], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

model Artifact {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  projectId      String           @map("project_id") @db.Uuid
  workstreamId   String?          @map("workstream_id") @db.Uuid
  type           ArtifactType
  subtype        ArtifactSubtype?
  name           String
  slug           String?
  assigneeId     String?          @map("assignee_id") @db.Uuid
  status         String
  priority       Priority?
  dueDate        DateTime?        @map("due_date")
  externalUrl    String?          @map("external_url")
  sortOrder      Int?             @map("sort_order")
  createdAt      DateTime         @default(now()) @map("created_at")
  createdById    String?          @map("created_by_id") @db.Uuid
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  organization              Organization                       @relation(fields: [organizationId], references: [id])
  project                   Project                            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workstream                Workstream?                        @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  assignee                  User?                              @relation("ArtifactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy                 User?                              @relation("ArtifactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  document                  DocumentDetail?
  pullRequest               PullRequestDetail?
  deployment                DeploymentDetail?
  deployments               DeploymentDetail[]                 @relation("DeploymentOfPullRequest")
  sourceLinks               ArtifactLink[]                     @relation("ArtifactLinkSource")
  targetLinks               ArtifactLink[]                     @relation("ArtifactLinkTarget")
  ratings                   ArtifactRating[]
  evaluations               ArtifactEvaluation[]
  commentThreads            CommentThread[]
  fileAttachments           FileAttachment[]
  loops                     Loop[]
  generationStatusDismissal DocumentGenerationStatusDismissal?

  @@unique([organizationId, slug])
  @@index([organizationId, projectId, type])
  @@index([organizationId, workstreamId, type])
  @@index([organizationId, type, status])
  @@index([organizationId, assigneeId])
  @@map("artifacts")
}

// Type-specific detail for DOCUMENT-typed artifacts. 1:1 with `Artifact` via
// shared `artifact_id` primary key. Other detail tables (pull_request_detail,
// deployment_detail) arrive in Chunk 2b.
model DocumentDetail {
  artifactId      String           @id @map("artifact_id") @db.Uuid
  fileName        String?          @map("file_name")
  approverId      String?          @map("approver_id") @db.Uuid
  templateForType ArtifactSubtype? @map("template_for_type")
  latestVersion   Int              @default(1) @map("latest_version")
  targetRepo      String?          @map("target_repo")
  targetBranch    String?          @map("target_branch")

  artifact     Artifact                     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  approver     User?                        @relation("DocumentDetailApprover", fields: [approverId], references: [id], onDelete: SetNull)
  versions     DocumentVersion[]
  performances GitHubActionRunPerformance[]

  @@map("document_detail")
}

// Type-specific detail for PULL_REQUEST-typed artifacts. 1:1 with `Artifact`
// via shared `artifact_id` primary key. Rows are backfilled from the legacy
// `github_pull_requests` table in Chunk 2B; that table is retired in the
// final contract migration.
model PullRequestDetail {
  artifactId           String          @id @map("artifact_id") @db.Uuid
  repositoryId         String          @map("repository_id") @db.Uuid
  githubId             String          @unique @map("github_id")
  number               Int
  body                 String?         @db.Text
  headBranch           String          @map("head_branch")
  baseBranch           String          @map("base_branch")
  headSha              String?         @map("head_sha")
  prState              GitHubPRState   @default(OPEN) @map("pr_state")
  isDraft              Boolean         @default(false) @map("is_draft")
  checksStatus         ChecksStatus    @default(UNKNOWN) @map("checks_status")
  reviewDecision       ReviewDecision? @map("review_decision")
  closedAt             DateTime?       @map("closed_at")
  mergedAt             DateTime?       @map("merged_at")
  mergeCommitSha       String?         @map("merge_commit_sha")
  lastVerifiedAt       DateTime?       @map("last_verified_at")
  lastRefreshAttemptAt DateTime?       @map("last_refresh_attempt_at")

  artifact       Artifact                     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  repository     GitHubInstallationRepository @relation(fields: [repositoryId], references: [id])
  reviews        GitHubPRReview[]
  reviewComments GitHubPRReviewComment[]

  @@unique([repositoryId, number])
  @@index([headSha])
  @@map("pull_request_detail")
}

// Type-specific detail for DEPLOYMENT-typed artifacts. 1:1 with `Artifact`
// via shared `artifact_id` primary key. Rows are backfilled from the
// PREVIEW_DEPLOYMENT rows in the legacy `external_links` table in
// Chunk 2B. All columns nullable because today's `DeploymentMetadata` is
// loosely shaped. Deployment state lives only on the parent `artifact.status`
// (plain TEXT so any vendor value round-trips).
model DeploymentDetail {
  artifactId            String   @id @map("artifact_id") @db.Uuid
  environment           String?
  ref                   String?
  sha                   String?
  githubStatusUrl       String?  @map("github_status_url")
  githubDeploymentUrl   String?  @map("github_deployment_url")
  transient             Boolean?
  production            Boolean?
  pullRequestArtifactId String?  @map("pull_request_artifact_id") @db.Uuid

  artifact            Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  pullRequestArtifact Artifact? @relation("DeploymentOfPullRequest", fields: [pullRequestArtifactId], references: [id], onDelete: SetNull)

  @@index([pullRequestArtifactId])
  @@index([ref, sha])
  @@map("deployment_detail")
}

// Replacement for polymorphic `EntityLink` with real FKs. Rows for
// DOCUMENT↔DOCUMENT links are backfilled in 2A; PR/Deployment links are
// added in 2B. Legacy `entity_links` table continues to coexist until 2F.
model ArtifactLink {
  id             String   @id @default(uuid(7)) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sourceId       String   @map("source_id") @db.Uuid
  targetId       String   @map("target_id") @db.Uuid
  linkType       LinkType @map("link_type")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  source Artifact @relation("ArtifactLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Artifact @relation("ArtifactLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([organizationId, sourceId, linkType])
  @@index([organizationId, targetId, linkType])
  @@map("artifact_links")
}

model ArtifactEvaluation {
  id             String               @id @default(uuid(7)) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
