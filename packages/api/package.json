{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node scripts/smoke-dist-imports.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@closedloop-ai/loops-api": "workspace:*",
    "@repo/shared-platform": "workspace:@closedloop-ai/shared-platform@*",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
