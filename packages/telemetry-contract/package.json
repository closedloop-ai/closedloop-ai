  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "pnpm run build:code && pnpm run build:artifacts",
    "build:code": "tsup",
    "build:artifacts": "pnpm run generate:schemas && pnpm run check:schemas && pnpm run check:collector-allowlist && pnpm run check:collector-posthog-routing && pnpm run check:collector-tail-sampling && pnpm run copy:samples",
    "generate:schemas": "tsx scripts/generate-json-schemas.ts",
    "generate:collector-allowlist": "tsx scripts/generate-collector-allowlist.ts",
    "generate:collector-posthog-routing": "tsx scripts/generate-collector-posthog-routing.ts",
    "generate:collector-tail-sampling": "tsx scripts/generate-collector-tail-sampling.ts",
    "check:schemas": "tsx scripts/check-json-schemas.ts",
    "check:collector-allowlist": "tsx scripts/check-collector-allowlist.ts",
    "check:collector-posthog-routing": "tsx scripts/check-collector-posthog-routing.ts",
    "check:collector-tail-sampling": "tsx scripts/check-collector-tail-sampling.ts",
    "verify:collector-tail-sampling": "tsx scripts/verify-collector-tail-sampling.ts",
    "copy:samples": "tsx scripts/copy-samples.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run",
    "test:types": "tsc --noEmit --project tsconfig.type-tests.json",
    "test:samples:source": "tsx scripts/test-perf-jsonl-sample.ts --mode source",
    "test:samples": "pnpm run build:artifacts && tsx scripts/test-perf-jsonl-sample.ts --mode dist",
    "test:package-resolution": "pnpm run build && tsx scripts/test-package-resolution.ts",
    "test:package-content": "pnpm run build && tsx scripts/test-package-content.ts",
    "validate": "pnpm run test:samples:source && pnpm run typecheck && pnpm run test && pnpm run test:types && pnpm run build && pnpm run test:samples && pnpm run test:package-resolution && pnpm run test:package-content"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@opentelemetry/semantic-conventions": "1.39.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "ajv": "^8.18.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": ">=2.8.3",
    "zod": "^4.3.6"
  },
  "telemetryContract": {
    "otelSemanticConventionsVersion": "1.39.0"
  }
