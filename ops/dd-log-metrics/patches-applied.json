            },
            "group_by": [
              {
                "path": "@commandId",
                "tag_name": "command_id"
              },
              {
                "path": "@computeTargetId",
                "tag_name": "compute_target_id"
              },
              {
                "path": "@eventType",
                "tag_name": "event_type"
              }
            ]
          }
        }
      }
    },
