    "includes": [
      "**/*",
      // shadcn/ui upstream conventions: these directories use interface declarations,
      // barrel exports, and patterns that conflict with project Biome rules
      "!packages/design-system/components/ui",
      "!packages/design-system/lib",
      "!packages/design-system/hooks",
      // Generated by apps/storybook/scripts/sync-component-catalog.mjs
      "!packages/design-system/storybook/component-catalog.ts",
      // Generated keyless-telemetry collector artifacts (FEA-2170/FEA-1991): their
      // exact bytes are owned by the contract codegen and asserted by the drift
      // guards — Biome must NOT reformat them or the byte-identity checks break.
      "!packages/telemetry-contract/collector",
      "!packages/collaboration/config.ts",
      "!docs/components/ui",
      "!docs/lib",
      "!docs/hooks",
      "!apps/app/public/*.svg",
      "!apps/docs/**/*.json",
      "!apps/docs/**/*.svg",
      "!apps/desktop/app-icon.svg",
      "!apps/desktop/resources/*.svg",
      "!apps/desktop/src/renderer/design-system/index.html",
      "!apps/email/.react-email",
      "!apps/storybook/.storybook/preview-head.html",
      "!apps/web/public/**/*.html",
      "!apps/web/public/**/*.svg",
      "!packages/design-system/brand/icons/**/*.svg",
      "!packages/design-system/brand/logos/**/*.svg",
      "!**/playwright-report",
      "!**/playwright-report-e2e"
    ]
  }
