{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/core", "ultracite/react", "ultracite/next"],
  "linter": {
    "domains": {
      "project": "recommended",
      "types": "recommended"
    },
    "rules": {
      "style": {
        "useConsistentTypeDefinitions": {
          "level": "warn",
          "options": {
            "style": "type"
          }
        },
        "noNonNullAssertion": "off",
        // Biome 2.4: defer substring→slice migration to separate PR
        "noSubstr": "warn",
        "noDescendingSpecificity": "warn"
      },
      "suspicious": {
        "noEmptyBlockStatements": "off",
        // Biome 2.4: defer array-index-key fixes to separate PR
        "noArrayIndexKey": "warn"
      }
    }
  },
  "javascript": {
    "globals": ["Liveblocks"]
  },
  "overrides": [
    {
      "includes": [
        "**/__tests__/**",
        "**/test/**",
        "**/*.spec.cts",
        "**/*.spec.js",
        "**/*.spec.jsx",
        "**/*.spec.mjs",
        "**/*.spec.mts",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.test.cts",
        "**/*.test.js",
        "**/*.test.jsx",
        "**/*.test.mjs",
        "**/*.test.mts",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/vitest.setup.cts",
        "**/vitest.setup.js",
        "**/vitest.setup.jsx",
        "**/vitest.setup.mjs",
        "**/vitest.setup.mts",
        "**/vitest.setup.ts",
        "**/vitest.setup.tsx"
      ],
      "javascript": {
        "globals": [
          "Liveblocks",
          "afterAll",
          "afterEach",
          "assert",
          "beforeAll",
          "beforeEach",
          "describe",
          "expect",
          "it",
          "suite",
          "test",
          "vi"
        ]
      }
    },
    {
      // Static brand/icon assets (*.svg) and HTML templates (storybook
      // preview-head, the desktop renderer index, public/*.html) are not code.
      // ultracite enables Biome's html/svg support, but its formatter / assist
      // (attribute sorting) / a11y (noSvgWithoutTitle) findings aren't
      // meaningful for committed assets — disable them so the repo-wide lint
      // doesn't fail on assets.
      "includes": ["**/*.svg", "**/*.html"],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      },
      "assist": {
        "enabled": false
      }
    },
    {
      "includes": ["**/*", "!apps/desktop/**"],
      "linter": {
        "domains": {
          // FEA-1544: activate project/type inference only for Desktop so
          // noFloatingPromises replaces the removed package-local ESLint rule.
          "project": "none",
          "types": "none"
        }
      }
    },
    {
      "includes": [
        "apps/app/components/engineer/**",
        "apps/app/components/chat/**",
        "apps/app/hooks/engineer/**",
        // Narrowed from hooks/chat/** to the single remaining offender
        "apps/app/hooks/chat/use-stream-dispatch.ts",
        "apps/app/lib/engineer/**",
        "apps/app/lib/chat/**"
      ],
      "linter": {
        "rules": {
          "performance": {
            // Keep engineer/chat noBarrel carve-out while compatibility shims and
            // existing barrel patterns remain in this scope.
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/app/components/chat/CollapsibleBlock.tsx",
        "apps/app/components/chat/MessageContent.tsx",
        "apps/app/components/engineer/CommentChat.tsx",
        "apps/app/components/engineer/JudgesViewer.tsx",
        "apps/app/components/engineer/PlanViewer.tsx",
        "apps/app/components/engineer/RepoPickerDialog.tsx",
        "apps/app/components/engineer/ReviewChatPane.tsx",
        "apps/app/components/engineer/ClosedloopChat.tsx",
        "apps/app/components/engineer/TerminalChatDialog.tsx",
        "apps/app/components/engineer/TicketCard.tsx",
        "apps/app/components/engineer/TicketList.tsx",
        "apps/app/components/engineer/TicketListRow.tsx",
        "apps/app/components/engineer/__tests__/HealthCheckDialog.test.tsx",
        "apps/app/components/engineer/run-viewer/RunViewerDialog.tsx",
        "apps/app/components/engineer/run-viewer/viewers/JudgesViewer.tsx",
        "apps/app/components/engineer/run-viewer/viewers/MarkdownViewer.tsx",
        "apps/app/hooks/engineer/use-codex-debate.ts",
        "apps/app/hooks/engineer/use-review-chat.ts",
        "apps/app/hooks/engineer/use-slash-commands.ts",
        "apps/app/lib/chat/chat-markdown.tsx",
        "apps/app/lib/chat/chat-utils.ts",
        "apps/app/lib/engineer/deploy-detect.ts",
        "apps/app/lib/engineer/relay-client.ts",
        "apps/app/lib/engineer/repos.ts",
        "apps/app/lib/engineer/review-split.ts",
        "apps/app/lib/engineer/worktree-utils.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            // FEA-520: keep regex-hoisting carve-out limited to files still requiring
            // behavior-safe parser/streaming refactors.
            "useTopLevelRegex": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/app/components/chat/SubagentBlock.tsx",
        "apps/app/components/engineer/ActiveTicketCard.tsx",
        "apps/app/components/engineer/CommentChat.tsx",
        "apps/app/components/engineer/DeployDialog.tsx",
        "apps/app/components/engineer/JsonlLogViewer.tsx",
        "apps/app/components/engineer/LearningsDialog.tsx",
        "apps/app/components/engineer/PRCommentCard.tsx",
        "apps/app/components/engineer/RepoPickerDialog.tsx",
        "apps/app/components/engineer/ReviewChatPane.tsx",
        "apps/app/components/engineer/ClosedloopChat.tsx",
        "apps/app/components/engineer/ClosedloopStatus.tsx",
        "apps/app/components/engineer/TerminalChatDialog.tsx",
        "apps/app/components/engineer/TicketChatDialog.tsx",
        "apps/app/components/engineer/TicketList.tsx",
        "apps/app/components/engineer/TicketListRow.tsx",
        "apps/app/hooks/chat/use-stream-dispatch.ts",
        "apps/app/hooks/engineer/use-codex-debate.ts",
        "apps/app/hooks/engineer/use-engineer-features.ts",
        "apps/app/hooks/engineer/use-review-chat.ts",
        "apps/app/hooks/engineer/use-review-execution.ts",
        "apps/app/hooks/engineer/use-start-plan-loop.ts",
        "apps/app/hooks/engineer/useCommentChat.ts",
        "apps/app/hooks/engineer/useClosedloopLaunch.ts",
        "apps/app/lib/chat/chat-utils.ts",
        "apps/app/lib/engineer/claude-stream-utils.ts",
        "apps/app/lib/engineer/deploy-detect.ts",
        "apps/app/lib/engineer/engineer-fetch-interceptor.ts",
        "apps/app/lib/engineer/queries/health-check.ts",
        "apps/app/lib/engineer/relay-client.ts",
        "apps/app/lib/engineer/review-stream.ts",
        "apps/app/lib/engineer/sessions.ts",
        "apps/app/lib/engineer/stream-events.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            // FEA-520: keep cognitive-complexity carve-out only on current
            // orchestration/parser hotspots that still need module-level refactors.
            "noExcessiveCognitiveComplexity": {
              "level": "error",
              "options": { "maxAllowedComplexity": 106 }
            }
          }
        }
      }
    },
    {
      "includes": [
        // FEA-520: postpone PascalCase -> kebab-case migration to a dedicated rename pass.
        "apps/app/components/chat/**",
        "apps/app/components/engineer/**",
        "apps/app/hooks/engineer/__tests__/useClosedloopLaunch.test.ts",
        "apps/app/hooks/engineer/useCommentChat.ts",
        "apps/app/hooks/engineer/useGitOperations.ts",
        "apps/app/hooks/engineer/useMediaQuery.ts",
        "apps/app/hooks/engineer/useClosedloopLaunch.ts",
        "apps/app/hooks/engineer/useTerminalStatus.ts",
        "apps/app/hooks/engineer/useUpdateChecker.ts",
        "apps/app/lib/chat/runner-token/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        // PLN-806 / FEA-1509: client navigation goes through the
        // @repo/navigation port. Only the Next adapter may import next/link
        // or next/navigation client hooks; server components keep importing
        // redirect/notFound from next/navigation (allowImportNames below).
        "apps/app/**",
        "!apps/app/lib/navigation/next-adapter.tsx",
        // Test setup shims delegate port hooks back to next/navigation mocks.
        "!apps/app/vitest.setup.ts",
        // Tests may reference next/navigation to drive vi.mock factories —
        // both __tests__/ directories and colocated *.test.* files.
        "!apps/app/**/__tests__/**",
        "!apps/app/**/*.test.ts",
        "!apps/app/**/*.test.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "next/link": "Use Link from @repo/navigation/link instead (navigation port, PLN-806). Only lib/navigation/next-adapter.tsx may import next/link.",
                  "next/navigation": {
                    "message": "Use @repo/navigation hooks instead (navigation port, PLN-806). Only server redirect/notFound may be imported from next/navigation; client hooks live in lib/navigation/next-adapter.tsx.",
                    "allowImportNames": ["redirect", "notFound"]
                  }
                },
                // FEA-1511 / PRD-430 (AC-040.4): the privileged Desktop gateway
                // tree (apps/desktop/src/server/operations/*) runs in the
                // Electron main process with local filesystem/process access and
                // can spawn CLI processes — apps/app must never import it. These
                // patterns MUST live in the SAME options block as the navigation
                // `paths` above: Biome does not deep-merge a rule's options
                // across overlapping overrides, so a second apps/app override for
                // noRestrictedImports would clobber the navigation ban. The
                // apps/api half of the boundary lives in its own override below
                // (no navigation ban there to conflict with).
                "patterns": [
                  {
                    // Realistic case today: a relative deep path. The specifier
                    // has no leading `apps/`, but always contains the
                    // `desktop/src/server/operations/` segment, so a `**/` prefix
                    // matches every relative depth as well as the bare
                    // `apps/desktop/src/server/operations/...` form.
                    "group": ["**/desktop/src/server/operations/**"],
                    "message": "apps/app must never import the privileged Desktop gateway tree (FEA-1511, PRD-430 AC-040.4): apps/desktop/src/server/operations/* runs in the Electron main process with local filesystem/process access and can spawn CLI processes — importing it opens an arbitrary local command execution path. See apps/desktop/AGENTS.md."
                  },
                  {
                    // Future-proofing: a bare/aliased form (a package export or
                    // tsconfig path alias) that drops the `src/` segment.
                    "group": ["**/desktop/server/operations/**"],
                    "message": "apps/app must never import the privileged Desktop gateway tree (FEA-1511, PRD-430 AC-040.4): apps/desktop/src/server/operations/* runs in the Electron main process with local filesystem/process access and can spawn CLI processes — importing it opens an arbitrary local command execution path. See apps/desktop/AGENTS.md."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // PLN-806: the navigation port must stay framework-agnostic — it is
        // consumed by non-Next shells (desktop renderer). No next/* imports;
        // the Next-specific implementation lives in the web adapter
        // (apps/app/lib/navigation/next-adapter.tsx).
        "packages/navigation/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "next/link": "The navigation port is framework-agnostic; next/link belongs only in the web adapter (apps/app/lib/navigation/next-adapter.tsx).",
                  "next/navigation": "The navigation port is framework-agnostic; next/navigation belongs only in the web adapter (apps/app/lib/navigation/next-adapter.tsx)."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // PLN-810 / FEA-1510 migration seam: this file temporarily re-exports
        // the shared app-core transport port (useApiClient) so existing
        // importers keep working until it is removed in PLN-810 Phase 6. The
        // query-key-factory and auth seams were removed once their importers
        // were rewritten; this is the last one.
        "apps/app/hooks/use-api-client.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        // PLN-810 / FEA-1510: the shared app-core layer is surface-agnostic —
        // it renders in both the web app and the desktop renderer (no SSR).
        // No Next.js, Clerk, or server-only imports; transport and auth are
        // injected via the shared/api and shared/auth adapter ports, with
        // surface adapters living in each app (web: apps/app/lib/app-core-adapters.tsx).
        "packages/app/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                // Pattern groups (gitignore-style) so the guardrail bans whole
                // forbidden families, not just exact specifiers: any `next/*`
                // subpath, every `@clerk/*`, `@repo/auth/*`, `@repo/database/*`,
                // and any app-local `@/*` alias are rejected, however deep.
                // Groups are disjoint so an import matches exactly one message.
                "patterns": [
                  {
                    "group": ["next", "next/**"],
                    "message": "@repo/app is surface-agnostic (FEA-1510): no Next.js imports. Use @repo/navigation (Link, hooks); next/image, fonts, and server APIs (next/headers, next/server, next/cache) stay in apps/app."
                  },
                  {
                    "group": ["@clerk/**"],
                    "message": "@repo/app never imports Clerk (FEA-1510): consume the shared/auth adapter port."
                  },
                  {
                    "group": ["@repo/auth", "@repo/auth/**"],
                    "message": "@repo/app never imports the auth SDK (FEA-1510): consume @repo/app/shared/auth/use-auth-snapshot via the injected adapter."
                  },
                  {
                    "group": ["@repo/database", "@repo/database/**"],
                    "message": "@repo/app is client code (FEA-1510): all data access goes through apps/api via useApiClient (no @repo/database, incl. /generated)."
                  },
                  {
                    "group": ["@repo/analytics", "@repo/analytics/**"],
                    "message": "@repo/app never imports the analytics SDK (FEA-1510): @repo/analytics pulls in PostHog/Next/server-only. Consume @repo/app/shared/feature-flags/use-feature-flag-enabled via the injected adapter; surface telemetry stays in apps/app."
                  },
                  {
                    "group": [
                      "@repo/collaboration/server",
                      "@repo/collaboration/server/**"
                    ],
                    "message": "@repo/app is client/renderer code (FEA-1510): @repo/collaboration/server/* pulls in @liveblocks/node + server-only. Use @repo/collaboration/client/* and /shared/*; room auth goes through apps/api via the injected api client."
                  },
                  {
                    "group": ["server-only"],
                    "message": "@repo/app runs in browser/renderer contexts only (FEA-1510)."
                  },
                  {
                    "group": ["@/**"],
                    "message": "@repo/app must not reach into an app's @/ alias (FEA-1510): shared code cannot depend on a specific shell."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // FEA-1510: @repo/collaboration is split into server/ (Node-only,
        // server-only) and client/ + shared/ (surface-agnostic — they render in
        // both the web app and the desktop renderer). Keep the client/shared
        // surfaces portable: no server-only, Next.js, DB, auth SDK, the package's
        // own server/ tree, or app-local aliases. Room auth is injected (the
        // authEndpoint prop) and resolved by apps/api, not imported here.
        "packages/collaboration/client/**",
        "packages/collaboration/shared/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["next", "next/**"],
                    "message": "@repo/collaboration client/shared is surface-agnostic (FEA-1510): no Next.js imports. Surface concerns (navigation, the auth endpoint) are injected by the shell."
                  },
                  {
                    "group": ["@clerk/**"],
                    "message": "@repo/collaboration client/shared never imports Clerk (FEA-1510): the shell injects the authEndpoint; room auth is resolved by apps/api."
                  },
                  {
                    "group": ["@repo/auth", "@repo/auth/**"],
                    "message": "@repo/collaboration client/shared never imports the auth SDK (FEA-1510): the shell injects the authEndpoint; room auth is resolved by apps/api."
                  },
                  {
                    "group": ["@repo/database", "@repo/database/**"],
                    "message": "@repo/collaboration client/shared is client/renderer code (FEA-1510): no @repo/database (incl. /generated). Data access goes through apps/api."
                  },
                  {
                    "group": ["@repo/analytics", "@repo/analytics/**"],
                    "message": "@repo/collaboration client/shared never imports the analytics SDK (FEA-1510): @repo/analytics pulls in PostHog/Next/server-only."
                  },
                  {
                    "group": [
                      "@repo/collaboration/server",
                      "@repo/collaboration/server/**"
                    ],
                    "message": "@repo/collaboration client/shared must not import the package's own server/ tree (FEA-1510): server/* pulls in @liveblocks/node + server-only. Cross-layer data is injected or resolved via apps/api."
                  },
                  {
                    "group": ["server-only"],
                    "message": "@repo/collaboration client/shared runs in browser/renderer contexts only (FEA-1510)."
                  },
                  {
                    "group": ["@/**"],
                    "message": "@repo/collaboration client/shared must not reach into an app's @/ alias (FEA-1510): shared code cannot depend on a specific shell."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // FEA-1511 / PRD-430 (AC-040.4): apps/desktop/src/server/operations/*
        // runs in the Electron main/server process with local filesystem +
        // process access and can spawn local CLI processes. The browser-reachable
        // apps/api surface must never import that privileged tree — a direct or
        // transitive import would open an arbitrary local command execution path.
        // This makes the prose rule in apps/desktop/AGENTS.md a build-enforced
        // guardrail. The apps/app half of the boundary is enforced in the
        // navigation override above (merged into the same noRestrictedImports
        // options so Biome does not clobber the navigation ban); apps/api has no
        // navigation ban, so it gets its own dedicated override here.
        "apps/api/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                // Disjoint groups so an import matches exactly one message.
                // Biome matches the literal specifier string, not the resolved
                // path, so both the realistic relative-deep-path form and a
                // future bare/aliased form are banned.
                "patterns": [
                  {
                    // Realistic case today: a relative deep path. From
                    // apps/api/lib/foo.ts the specifier is
                    // `../../desktop/src/server/operations/...` — it has no
                    // leading `apps/`, but always contains the
                    // `desktop/src/server/operations/` segment, so a `**/`
                    // prefix matches every relative depth as well as the
                    // `apps/desktop/src/server/operations/...` form.
                    "group": ["**/desktop/src/server/operations/**"],
                    "message": "apps/api must never import the privileged Desktop gateway tree (FEA-1511, PRD-430 AC-040.4): apps/desktop/src/server/operations/* runs in the Electron main process with local filesystem/process access and can spawn CLI processes — importing it opens an arbitrary local command execution path. See apps/desktop/AGENTS.md."
                  },
                  {
                    // Future-proofing: a bare/aliased form (a package export or
                    // tsconfig path alias) that drops the `src/` segment.
                    "group": ["**/desktop/server/operations/**"],
                    "message": "apps/api must never import the privileged Desktop gateway tree (FEA-1511, PRD-430 AC-040.4): apps/desktop/src/server/operations/* runs in the Electron main process with local filesystem/process access and can spawn CLI processes — importing it opens an arbitrary local command execution path. See apps/desktop/AGENTS.md."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // Prototype sandbox (docs/design/prototype-sandbox.md): prototypes are
        // presentational, mock-data-only references. The dependency boundary
        // (these packages are not installed in apps/prototypes) is the primary
        // enforcement; this guardrail catches copy-paste from the real app.
        "apps/prototypes/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@repo/database", "@repo/database/**"],
                    "message": "Prototypes are an isolated sandbox: no database access. Use inline mock data (docs/design/prototype-sandbox.md)."
                  },
                  {
                    "group": ["@repo/api", "@repo/api/**"],
                    "message": "Prototypes never call the API: props in, mock data inline (docs/design/prototype-sandbox.md)."
                  },
                  {
                    "group": ["@repo/auth", "@repo/auth/**"],
                    "message": "Prototypes have no auth: they render static mock data only (docs/design/prototype-sandbox.md)."
                  },
                  {
                    "group": ["@repo/collaboration", "@repo/collaboration/**"],
                    "message": "Prototypes are presentational only: no collaboration or real-time wiring (docs/design/prototype-sandbox.md)."
                  },
                  {
                    "group": ["server-only"],
                    "message": "Prototypes are a pure presentational sandbox: no server-only modules (docs/design/prototype-sandbox.md)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        // Machine-written by apps/prototypes/scripts/generate-registry.mjs.
        // The generator's output is canonical: keep Biome (and the pre-commit
        // hook) from reformatting it, which would make the next regeneration
        // produce a spurious diff.
        "apps/prototypes/lib/registry.generated.ts"
      ],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      },
      "assist": {
        "enabled": false
      }
    },
    {
      "includes": ["e2e/**", "playwright.config.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          },
          "a11y": {
            "useButtonType": "off",
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/**/*.ts", "apps/desktop/**/*.tsx"],
      "linter": {
        "domains": {
          "project": "recommended",
          "types": "recommended"
        },
        "rules": {
          "nursery": {
            // FEA-1544: preserve Desktop's former ESLint
            // @typescript-eslint/no-floating-promises coverage.
            "noFloatingPromises": "error"
          }
        }
      }
    },
    {
      "includes": [
        "apps/desktop/src/main/**/*.ts",
        "apps/desktop/src/server/**/*.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            // FEA-1544: preserve Desktop's former main/server no-console policy.
            "noConsole": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/main/gateway-logger.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            // GatewayLogger is the documented Desktop console transport.
            "noConsole": {
              "level": "error",
              "options": {
                "allow": ["error", "warn", "log"]
              }
            }
          }
        }
      }
    },
    // FEA-1544: exact-file legacy Desktop diagnostics retained during ESLint removal.
    // These are explicit file-list carve-outs for pre-existing non-safety diagnostics;
    // Desktop safety rules restored by this plan remain active.
    {
      "includes": [
        "apps/desktop/src/main/agent-session-sync-service.ts",
        "apps/desktop/src/main/anthropic-admin-client.ts",
        "apps/desktop/src/main/app.ts",
