CLOSEDLOOP_API_URL="http://localhost:3002"
INTERNAL_API_SECRET="change-me-in-production"

# --- Cross-instance dispatch runtime (optional) ----------------------------
# Read in apps/relay/src/index.ts. Controls how desktop target ownership is
# tracked across relay tasks. Set by infrastructure (ECS task definition) in
# stage/prod; left unset locally.
#
# RELAY_RUNTIME_MODE selects the registry backend:
#   absent / "inmemory" (default): single-instance only; a dispatch can only be
#            delivered by the task that holds the desktop socket.
#   "redis": share a target/instance registry via REDIS_URL so any relay task
#            can proxy a dispatch to the task that owns the socket. Degrades to
#            inmemory if REDIS_URL is unset, no routable private IP can be
#            resolved (see RELAY_INSTANCE_ID below), or the connection fails.
# RELAY_RUNTIME_MODE="redis"
#
# REDIS_URL is the ElastiCache/Valkey connection string (use rediss:// for TLS).
# Required only when RELAY_RUNTIME_MODE="redis".
# REDIS_URL="rediss://host:6379"
#
# RELAY_INTERNAL_ALLOWED_IPS is an optional comma-separated CIDR allowlist. It
# gates the POST /internal/dispatch endpoint (ingress) AND the egress allowlist
# used when proxying to a peer relay. When empty, ingress is authorized by the
# shared INTERNAL_API_SECRET alone and egress is restricted to RFC1918 private
# ranges on the relay port.
# RELAY_INTERNAL_ALLOWED_IPS="10.0.0.0/8"
#
# RELAY_INSTANCE_ID overrides the instance id used in the registry. Read in
# apps/relay/src/instance-discovery.ts; defaults to the ECS task id, else a
# random "local-" id. The instance's routable private IP is read from ECS task
# metadata (ECS_CONTAINER_METADATA_URI_V4).
# RELAY_INSTANCE_ID=""
