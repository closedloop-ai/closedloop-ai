# Server
# Uncomment and fill these when you have service credentials:
# CLERK_SECRET_KEY="sk_..."
# CLERK_WEBHOOK_SECRET="whsec_..."
# RESEND_FROM=""
DATABASE_URL="postgresql://postgres:password@localhost:5432/symphony"
# RESEND_TOKEN=""
# SVIX_TOKEN=""
# LIVEBLOCKS_SECRET=""
VERCEL_PROJECT_PRODUCTION_URL="http://localhost:3000"
CLOSEDLOOP_RUNNER_JWT_SECRET=""

# Desktop trusted-config relay origin. Leave unset for ClosedLoop production,
# which defaults to https://relay.closedloop.ai. Set this for self-hosted,
# staging, or custom relay deployments. Local `just dev` provides
# RELAY_API_URL=http://localhost:3020 automatically; without that, localhost
# falls back to NEXT_PUBLIC_API_URL.
CL_RELAY_ORIGIN=""

# Client
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-..."
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_DOCS_URL="http://localhost:3004"

# E2E testing (Playwright) — required for `pnpm test:e2e`
# DEVOPS_CLOSEDLOOP_APP_PWD: password for the shared devops+testing@closedloop.ai Clerk account
# CLERK_TESTING_TOKEN: Clerk testing token from https://dashboard.clerk.com → Testing
DEVOPS_CLOSEDLOOP_APP_PWD=""
CLERK_TESTING_TOKEN=""

# Linear OAuth initiation (client_id only - secret stays in API)
LINEAR_CLIENT_ID=""

# GitHub App (slug for install URL - OAuth credentials are in API only)
NEXT_PUBLIC_GITHUB_APP_SLUG=""
