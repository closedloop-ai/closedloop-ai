{
  "name": "desktop",
  "version": "0.16.71",
  "description": "Closedloop Desktop",
  "author": "Closedloop AI <support@closedloop.ai>",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev-launch.mjs",
    "dev:prepare": "node scripts/dev-launch.mjs --prepare-only",
    "dev:static": "node scripts/dev-launch.mjs --static-renderer",
    "dev:static:prepare": "node scripts/dev-launch.mjs --static-renderer --prepare-only",
    "start": "electron .",
    "start:no-auth": "CL_LOCAL_GATEWAY_NO_AUTH=1 pnpm run start",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "clean:coverage": "node -e \"require('fs').rmSync('coverage',{recursive:true,force:true});require('fs').mkdirSync('coverage',{recursive:true})\"",
    "clean:package": "node -e \"require('fs').rmSync('dist-dmg',{recursive:true,force:true})\"",
    "prebuild": "node scripts/write-build-info.mjs && node scripts/generate-migrations-manifest.mjs",
    "build": "pnpm run build:deps && pnpm run clean:dist && pnpm run prebuild && pnpm run db:generate && pnpm run build:main && pnpm run build:renderer",
    "build:main": "electron-vite build",
    "build:main:dev": "node scripts/build-main-dev.mjs",
    "build:deps": "cd ../.. && pnpm exec turbo build --filter=@closedloop-ai/loops-api --filter=@closedloop-ai/design-system --filter=@closedloop-ai/shared-platform --filter=@closedloop-ai/telemetry-contract --filter=@repo/api --output-logs=errors-only",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "dashboard:reset": "node scripts/reset-dashboard-db.mjs",
    "db:generate": "node scripts/generate-prisma-client.mjs",
    "db:dev": "prisma dev",
    "db:migrate:dev": "prisma migrate dev",
    "stage:package": "node scripts/stage-packaging-app.mjs",
    "typecheck": "pnpm prebuild && pnpm db:generate && tsc -p tsconfig.json --noEmit && pnpm typecheck:renderer && pnpm typecheck:type-tests",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "typecheck:type-tests": "tsc -p tsconfig.type-tests.json --noEmit",
    "lint": "pnpm prebuild && pnpm --dir ../.. exec ultracite check apps/desktop",
    "assert:design-system-boundary": "tsx --test test/agent-dashboard-boundary.test.ts",
    "check:design-system-drift": "node scripts/check-design-system-drift.mjs",
    "test:boot:design-system-off": "node --import tsx scripts/assert-design-system-boot-off.mjs",
    "test:boot:dist": "node scripts/assert-design-system-boot-off.mjs --target dist",
    "measure:agent-dashboard-storage": "node scripts/measure-agent-dashboard-storage.mjs",
    "verify:electron-binary": "node scripts/ensure-electron-binary.mjs",
    "test": "pnpm prebuild && pnpm db:generate && pnpm clean:coverage && pnpm test:prisma-baseline && pnpm test:node && pnpm test:boot:design-system-off && pnpm test:renderer",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:node": "node scripts/run-covered-node-tests.mjs",
    "test:prisma-baseline": "tsx --test --test-concurrency=1 test/prisma-baseline-equivalence.test.ts",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "package": "pnpm clean:package && pnpm build && pnpm stage:package && pnpm package:builder",
    "package:builder": "node scripts/run-electron-builder.mjs",
    "package:turbo": "node scripts/run-electron-builder.mjs",
    "release": "pnpm package"
  },
  "dependencies": {
    "@closedloop-ai/design-system": "workspace:*",
    "@closedloop-ai/loops-api": "workspace:*",
    "@closedloop-ai/telemetry-contract": "workspace:*",
    "@libsql/client": "0.17.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/otlp-transformer": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-logs": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@prisma/adapter-libsql": "~7.8.0",
    "@prisma/client": "~7.8.0",
    "@pydantic/genai-prices": "0.0.66",
    "@repo/api": "workspace:*",
    "@repo/app": "workspace:*",
    "@repo/shared-platform": "workspace:@closedloop-ai/shared-platform@*",
    "@tanstack/react-query": "^5.90.20",
    "busboy": "^1.6.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "glob": "^11.0.1",
    "lucide-react": "^0.556.0",
    "next-themes": "^0.4.6",
    "protobufjs": "^7.5.8",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-grid-layout": "^1.5.2",
    "react-hook-form": "^7.76.1",
    "react-resizable": "^3.2.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "@playwright/test": "^1.60.0",
    "@repo/navigation": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/busboy": "^1.5.4",
    "@types/node": "24.12.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "10.4.20",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "postcss": "8.5.1",
    "prisma": "~7.8.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-legacy": "npm:tailwindcss@3.4.17",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "yaml": ">=2.8.3"
  }
}
