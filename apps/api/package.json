{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:server:dev\" \"npm:stripe\"",
    "server:dev": "NODE_ENV=development tsx watch server.ts",
    "server:start": "NODE_ENV=production tsx server.ts",
    "next": "next dev -p 3002",
    "build": "next build",
    "start": "npm run server:start",
    "analyze": "ANALYZE=true npm run build",
    "test": "NODE_ENV=test vitest run",
    "test:compatibility": "NODE_ENV=test vitest run --config vitest.config.compatibility.mts",
    "stripe": "stripe listen --forward-to localhost:3002/webhooks/payments",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@closedloop-ai/loops-api": "workspace:*",
    "@aws-sdk/client-ecs": "^3.985.0",
    "@aws-sdk/client-kms": "^3.985.0",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@paralleldrive/cuid2": "^2.3.1",
    "@prisma/client": "~7.5.0",
    "@repo/ai": "workspace:*",
    "@repo/analytics": "workspace:*",
    "@repo/api": "workspace:*",
    "@repo/auth": "workspace:*",
    "@repo/aws": "workspace:*",
    "@repo/collaboration": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/design-system": "workspace:*",
    "@repo/github": "workspace:*",
    "@repo/google": "workspace:*",
    "@repo/linear": "workspace:*",
    "@repo/next-config": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/payments": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@vercel/functions": "^3.4.3",
    "adm-zip": "^0.5.16",
    "import-in-the-middle": "^2.0.6",
    "jose": "^5.2.1",
    "nanoid": "^5.1.6",
    "next": "16.2.3",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "require-in-the-middle": "8.0.1",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.1",
    "svix": "^1.84.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "@repo/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0",
    "vitest": "^4.0.18"
  }
}
