{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "node scripts/skip-ci.js",
  "crons": [
    {
      "path": "/cron/keep-alive",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/cron/timeout-loops",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/sample-heartbeat-lag",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/cleanup-preview-schemas",
      "schedule": "17 6 * * *"
    }
  ]
}
