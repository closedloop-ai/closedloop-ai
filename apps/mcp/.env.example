CLOSEDLOOP_API_URL="http://localhost:3002"
INTERNAL_API_SECRET="change-me-in-production"
WEBAPP_ENV="local"

# --- Cross-task session store (optional) -----------------------------------
# Read in apps/mcp/src/index.ts. Caches verified auth contexts so a POST that
# lands on a different ECS task (ALB without session stickiness) can skip a full
# API-key verification round-trip. Set by infrastructure (ECS task definition)
# in stage/prod; left unset locally.
#
# MCP_SESSION_STORE selects the backend:
#   absent / "memory" (default): per-process in-memory cache; no cross-task sharing.
#   "redis": use REDIS_URL below. Degrades to memory mode if REDIS_URL is unset
#            or the Redis connection fails.
# MCP_SESSION_STORE="redis"
#
# REDIS_URL is the ElastiCache/Valkey connection string (use rediss:// for TLS).
# Required only when MCP_SESSION_STORE="redis"; absent => memory mode. The cached
# bearer API key is AES-256-GCM encrypted (with the OAuth signing keys) before it
# is written to Redis.
# REDIS_URL="rediss://host:6379"
