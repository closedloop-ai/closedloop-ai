{
  "name": "mcp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --require ./src/preload.cjs --env-file=.env.local src/index.ts",
    "build": "tsc && cp src/server-only-noop.cjs dist/apps/mcp/src/server-only-noop.cjs",
    "start": "tsx --require ./dist/apps/mcp/src/preload.js dist/apps/mcp/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@repo/api": "workspace:*",
    "@repo/database": "workspace:*",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
