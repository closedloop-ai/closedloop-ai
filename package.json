{
  "name": "closedloop-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "cd packages/database && AWS_ROLE_ARN=${AWS_ROLE_ARN:-arn:aws:iam::000000000000:role/placeholder} AWS_REGION=${AWS_REGION:-us-east-1} PGHOST=${PGHOST:-localhost} PGPORT=${PGPORT:-5432} PGUSER=${PGUSER:-postgres} PGDATABASE=${PGDATABASE:-app} npx prisma generate --schema=./prisma/schema.prisma",
    "build": "turbo build",
    "predev": "for f in apps/app apps/api apps/web apps/mcp apps/relay; do test -f $f/.env.local || cp $f/.env.example $f/.env.local 2>/dev/null; done; test -f packages/database/.env || cp packages/database/.env.example packages/database/.env 2>/dev/null; true",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "figma:typecheck": "pnpm --filter @repo/design-system figma:typecheck",
    "lint": "npx ultracite@latest check",
    "lint:fix": "npx ultracite@latest fix",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "npx npm-check-updates --deep -u -x recharts && pnpm install",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && pnpm prisma migrate dev",
    "migrate:status": "cd packages/database && pnpm prisma migrate status",
    "clean": "git clean -xdf node_modules",
    "prepare": "husky",
    "start-apps": "turbo dev",
    "check-deps": "npx check-dependency-version-consistency"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@clerk/testing": "^2.0.25",
    "@playwright/test": "^1.58.2",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "check-dependency-version-consistency": "^6.0.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "next": "16.2.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "ultracite": "7.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@prisma/engines",
      "bufferutil",
      "core-js",
      "core-js-pure",
      "es5-ext",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "utf-8-validate"
    ],
    "overrides": {
      "next": "$next",
      "vite": ">=7.3.2",
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13",
      "handlebars": ">=4.7.9",
      "fast-xml-parser": ">=5.7.0",
      "defu": ">=6.1.5",
      "dompurify": ">=3.4.0",
      "protobufjs": ">=7.5.5 <8.0.0",
      "undici": ">=7.24.0 <8.0.0",
      "flatted": ">=3.4.0",
      "socket.io-parser": ">=4.2.6",
      "express-rate-limit": ">=8.2.2",
      "effect": ">=3.20.0",
      "yaml": ">=2.8.3",
      "minimatch": ">=10.2.3",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=2.0.3",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "axios": ">=1.15.2",
      "tar": ">=6.2.1 <7.0.0",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1"
    }
  },
  "type": "module"
}
