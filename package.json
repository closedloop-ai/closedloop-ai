{
  "name": "next-forge",
  "version": "5.3.2",
  "bin": {
    "next-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "postinstall": "cd packages/database && AWS_ROLE_ARN=${AWS_ROLE_ARN:-arn:aws:iam::000000000000:role/placeholder} AWS_REGION=${AWS_REGION:-us-east-1} PGHOST=${PGHOST:-localhost} PGPORT=${PGPORT:-5432} PGUSER=${PGUSER:-postgres} PGDATABASE=${PGDATABASE:-app} npx prisma generate --schema=./prisma/schema.prisma",
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "figma:typecheck": "pnpm --filter @repo/design-system figma:typecheck",
    "lint": "npx ultracite@latest check",
    "lint:fix": "npx ultracite@latest fix",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "npx npm-check-updates --deep -u -x recharts && pnpm install",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && pnpm prisma migrate dev",
    "migrate:status": "cd packages/database && pnpm prisma migrate status",
    "clean": "git clean -xdf node_modules",
    "prepare": "husky",
    "start-apps": "turbo dev --filter=app --filter=api",
    "dev:engineer": "NEXT_PUBLIC_API_URL=https://api.closedloop-stage.ai turbo dev --filter=app",
    "check-deps": "npx check-dependency-version-consistency"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "^1.58.2",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "check-dependency-version-consistency": "^6.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "next": "16.1.6",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.13",
      "@types/react-dom": "19.2.3",
      "parse5": "^7.2.1"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@prisma/engines",
      "bufferutil",
      "core-js",
      "core-js-pure",
      "es5-ext",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  },
  "type": "module"
}
